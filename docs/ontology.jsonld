  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A synthetic polymer molecule that is the main output of a recycling process of synthetic polymer molecule."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000201",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Reference to specific types of recycling processes, such as chemical recycling and mechanical recycling, can be added as needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "recycling process of synthetic polymer molecules"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@language" : "en",
    "@value" : "https://www.w3id.org/climoo#ClimOO_0000279"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid769"
  }, {
    "@id" : "_:genid787"
  }, {
    "@id" : "_:genid788"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A material processing that leads to the recovery of recyclable polymer molecules from waste pieces of synthetic polymer-based material."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000202",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@language" : "en",
    "@value" : "release of plastic-carried pollutants"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Implementations may revise this class axiomatization with reference to more adequate and specific object properties to represent variations of levels of plastic debris presence. Revisions will primarily target the object property “increased levels of”.\nAlso, see comments to the object property “increased levels of”.\n\nhttp://purl.obolibrary.org/obo/ENVO_02000200"
  }, {
    "@language" : "en",
    "@value" : "Pollutants may have synergizing or antagonizing effects on each other. We envision implementations to expand the representation in such a direction."
  }, {
    "@language" : "en",
    "@value" : "This class axiomatization requires revisions. Implementations are needed to further restrict the class coverage to cases of interest. Currently the model allows some undesirable cases, such as when pollutants released and acquired are not the same."
  }, {
    "@language" : "en",
    "@value" : "We envision extending this class by including references to specific sources and sinks as well as debris surface mechanisms of sorption of pollutants."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "release process of plastic debris-carried pollutants into the environment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000265"
  }, {
    "@id" : "_:genid793"
  }, {
    "@id" : "_:genid811"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A transportation process that has some portion of synthetic polymer-based material (generally synthetic plastic) composing some plastic debris and having some pollutants as part, as participant, and, as output, 1) that portion of synthetic polymer-based material with a decreased level of those pollutants as part, and 2) some other portion(s) of material with an increased level of those pollutants (both compared to levels prior participating into that process)."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000072"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000074"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000075"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000228"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000203",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An upper-level class concerning residues included in polymer materials other than plastics can be added as needed."
  }, {
    "@language" : "en",
    "@value" : "Here the focus is on the actual molecules that are residual molecules incorporated into the plastic materials. If the need arises for a more meso- or macroscopical representation of residues, the ClimOO Ontology will implement the current model."
  }, {
    "@language" : "en",
    "@value" : "References to molecules that are accidentally incorporated but are not an output or are consideraed asby-product of the manufacturing process can be added if needed."
  }, {
    "@language" : "en",
    "@value" : "References to molecules that are not incorporated yet can be added if needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "residue molecule of synthetic plastic manufacturing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/CHEBI_23367"
  }, {
    "@id" : "_:genid812"
  }, {
    "@id" : "_:genid820"
  }, {
    "@id" : "_:genid830"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A molecule that is a waste of some plastic manufacturing process and is incorporated into some portion of synthetic plastic material."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000204",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@language" : "en",
    "@value" : "submicronplastic debris, submicronplastic litter"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "submicron plastic debris particle"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000261"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
