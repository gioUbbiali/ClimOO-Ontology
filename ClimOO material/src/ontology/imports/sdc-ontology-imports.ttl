<http://ClimOO/climoo/imports/sdc-ontology-imports> rdf:type owl:Ontology ;
                                                     owl:versionIRI <http://ClimOO/climoo/imports/sdc-ontology-imports#2025-06-25> ;
                                                     rdfs:comment """This file contains ClimOO Ontology imports from the Sustainable Development and Climate ontology (SDC ontology). It also contains some imports reused by SDC ontology from the Phenotype And Trait Ontology (PATO). Imports were manually collected and revised.

Ontology source: https://raw.githubusercontent.com/hbabaie1/Sustainable-Development-and-Climate-SDC-ontology/refs/heads/main/SDC_v1.owl
Other ontology sources:
https://ontobee.org/ontology/PATO"""@en ;
                                                     rdfs:seeAlso "https://github.com/hbabaie1/Sustainable-Development-and-Climate-SDC-ontology/tree/main" ;
                                                     owl:versionInfo "2025-06-16" .

