###  https://www.w3id.org/climoo#ClimOO_0000246
:ClimOO_0000246 rdf:type owl:Class ;
                rdfs:subClassOf <http://www.semanticweb.org/bionik/portion_of_material> ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
