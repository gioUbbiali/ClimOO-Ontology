}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002409",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#TransitiveProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "p indirectly negatively regulates q iff p is indirectly causally upstream of q and p negatively regulates q."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@value" : "indirectly inhibits"
