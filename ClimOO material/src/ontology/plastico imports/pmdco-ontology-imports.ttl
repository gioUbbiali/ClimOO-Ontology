                                            rdfs:subClassOf <http://purl.obolibrary.org/obo/UO_1000076> ;
                                            <http://purl.obolibrary.org/obo/IAO_0000115> "A concentration unit which denotes the number of moles of solute as a proportion of the total number of moles in a solution." ;
                                            <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "(x)" ,
                                                                                                           "chi" ;
                                            rdfs:label "mole fraction" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://purl.obolibrary.org/obo/UO_0000076> ;
