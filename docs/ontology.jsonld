  } ],
  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "q1 reciprocal_of q2 if and only if : q1 and q2 are relational qualities and a phenotype e q1 e2 mutually implies a phenotype e2 q2 e."
  } ]
}, {
