###  http://purl.obolibrary.org/obo/ENVO_01000371
<http://purl.obolibrary.org/obo/ENVO_01000371> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_00002264> ;
                                               <http://purl.obolibrary.org/obo/IAO_0000115> "Agricultural waste is waste produced as a result of various agricultural operations. It includes manure and other wastes from farms, poultry houses and slaughterhouses; harvest waste; fertilizer run- off from fields; pesticides that enter into water, air or soils; and salt and silt drained from fields." ;
                                               <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> "agricultural waste" ;
                                               rdfs:comment "As with other wastes, this is more a role than a material in itself. This should be revised." ;
                                               rdfs:label "agricultural waste material" .

