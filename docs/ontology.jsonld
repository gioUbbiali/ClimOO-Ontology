    "@value" : "has ID range allocated"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@language" : "en",
    "@value" : "Datatype: idrange:1\nAnnotations: 'has ID range allocated to': \"Chris Mungall\"\nEquivalentTo: xsd:integer[> 2151 , <= 2300]\n"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "Relates a datatype that encodes a range of integers to the name of the person or organization who can use those ids constructed in that range to define new terms"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@language" : "en",
    "@value" : "Person:Alan Ruttenberg"
  } ]
}, {
