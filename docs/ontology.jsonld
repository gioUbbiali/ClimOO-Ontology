  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_8000000",
  "http://purl.obolibrary.org/obo/IAO_0000111" : [ {
    "@language" : "en",
    "@value" : "ontology module"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@language" : "en",
    "@value" : "I have placed this under 'data about an ontology part', but this can be discussed. I think this is OK if 'part' is interpreted reflexively, as an ontology module is the whole ontology rather than part of it."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@language" : "en",
    "@value" : "ontology file"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_8000001",
  "http://purl.obolibrary.org/obo/IAO_0000111" : [ {
    "@language" : "en",
    "@value" : "base ontology module"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "An ontology module that comprises only of asserted axioms local to the ontology, excludes import directives, and excludes axioms or declarations from external ontologies."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_8000002",
  "http://purl.obolibrary.org/obo/IAO_0000111" : [ {
    "@language" : "en",
    "@value" : "editors ontology module"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "An ontology module that is intended to be directly edited, typically managed in source control, and typically not intended for direct consumption by end-users."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@language" : "en",
    "@value" : "source ontology module"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_8000003",
  "http://purl.obolibrary.org/obo/IAO_0000111" : [ {
    "@language" : "en",
    "@value" : "main release ontology module"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "An ontology module that is intended to be the primary release product and the one consumed by the majority of tools."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@language" : "en",
    "@value" : "TODO: Add logical axioms that state that a main release ontology module is derived from (directly or indirectly) an editors module"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_8000004",
  "http://purl.obolibrary.org/obo/IAO_0000111" : [ {
    "@language" : "en",
    "@value" : "bridge ontology module"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "An ontology module that consists entirely of axioms that connect or bridge two distinct ontology modules. For example, the Uberon-to-ZFA bridge module."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_8000005",
  "http://purl.obolibrary.org/obo/IAO_0000111" : [ {
