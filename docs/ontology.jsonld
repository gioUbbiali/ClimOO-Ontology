  } ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@language" : "de",
    "@value" : "Plastikstück"
  }, {
    "@language" : "es",
    "@value" : "pedazo de plástico"
  }, {
    "@language" : "it",
    "@value" : "pezzo di plastica"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#inSubset" : [ {
    "@language" : "es",
    "@value" : "envoPlastics"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "ClimOO Ontology:\nWe imported this hierarchy of EnvO classes with the purpose of including an alternative system of classification of plastic debris particles and mapping it with that proposed by Hartmann et al. (2019), covered within the ClimOO Ontology. The alignment applies only with regard to particle size as a matter of example.\n\nEnvO classes for plastic debris particles do not present axioms besides the subsumption relation to the “piece of plastic” class. Class meaning concerning particle size only resides within the definitions.\n\nWe import the “piece of plastic” class without including the related axiomatization and subsume this class directly to BFO: object class, as we imported it solely for grouping purposes. It is not relevant for the alignment.\n\nWe envision discussions with EnvO's curators to consolidate this alignment, especially in terms of class axiomatization."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "piece of plastic"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000030"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/ENVO_01000777",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A plastic pellet which is produced such that its size allows it to be rapidly melted and used as input for further downstream manufacturing processes."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/envo.owl"
  } ],
  "http://purl.org/dc/elements/1.1/contributor" : [ {
    "@id" : "https://orcid.org/0000-0002-2996-719X"
  }, {
    "@id" : "https://orcid.org/0000-0002-4366-3088"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#inSubset" : [ {
    "@value" : "envoPlastics"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "nurdle"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
