###  https://www.w3id.org/climoo/climoo-sdc2#Atmospheric_Component
:Atmospheric_Component rdf:type owl:Class ;
                       rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000024> ,
                                       [ rdf:type owl:Class ;
                                         owl:unionOf ( [ rdf:type owl:Class ;
                                                         owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                                       <https://www.w3id.org/sco#SCO_0000006>
                                                                     )
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                         owl:someValuesFrom [ rdf:type owl:Class ;
                                                                              owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                                                            <https://www.w3id.org/sco#SCO_0000006>
                                                                                          )
                                                                            ]
                                                       ]
                                                     )
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                         owl:someValuesFrom :Gas
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000177> ;
                                         owl:someValuesFrom :atmosphere
                                       ] ;
                       rdfs:label "atmospheric component" ;
                       <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo/climoo-sdc2#Atmospheric_Evaporative_Demand
:Atmospheric_Evaporative_Demand rdf:type owl:Class ;
                                rdfs:subClassOf :Demand ;
                                rdfs:label "atmospheric evaporative demand"@en ;
                                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> .


###  https://www.w3id.org/climoo/climoo-sdc2#Atmospheric_Oxygen
:Atmospheric_Oxygen rdf:type owl:Class ;
                    rdfs:subClassOf :Oxygen ,
