###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000315
:ClimOO_0000315 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( <https://www.w3id.org/sco#SCO_0000023>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000184> ;
                                                             owl:someValuesFrom :ClimOO_0000298
