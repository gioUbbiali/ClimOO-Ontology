  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000285"
  }, {
    "@id" : "_:genid1270"
  }, {
    "@id" : "_:genid1271"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A transportation process that concerns a piece of synthetic plastic."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000290",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "synthetic polymerization process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000182"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1272"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A polymerization process that is human-driven and has some synthetic polymer molecules as output."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000291",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "transportation process of a plastic debris particle"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000285"
  }, {
    "@id" : "_:genid1276"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A transportation process that concerns a plastic debris particle."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000292",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "usage process of some piece of synthetic plastic"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000221"
  }, {
    "@id" : "_:genid1277"
  }, {
    "@id" : "_:genid1278"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A planned process that involves some piece of synthetic polymer-based material employed for some purpose."
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000293",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A portion of thermoplastic polymer-based material produced by polymerization of ethylene monomers including further crosslinking and modifications using other comonomers ( with exclusion of ultra-high molecular polyethylene)."
  }, {
    "@language" : "en",
    "@value" : "This class has been created to overcome shortcomings of the PMD:polyethylene class axiomatization (inclusion of ChEBI:polymerization monomer; modelling monomers in terms of role instead of their disposition to polymerize). Subclasses of the PMD:polyethylene class have been included as subclasses of this class.\n\nWe plan to deprecate this class and reuse the PMDco class as soon as this latter is revised."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "portion of polyethylene"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000211"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000252"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000294",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic weathering"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000295"
  }, {
    "@id" : "_:genid1279"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A weathering process of a piece of synthetic polymer-based material that applies to a piece of plastic."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000295",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "http://dx.doi.org/10.1351/PAC-REC-10-12-04"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "weathering process of a piece of synthetic polymer-based material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "http://purl.obolibrary.org/obo/ENVO_06105119 \nhttp://purl.obolibrary.org/obo/ENVO_06105126"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000015"
  }, {
    "@id" : "_:genid1280"
  }, {
    "@id" : "_:genid1281"
  } ],
  "http://www.w3.org/2004/02/skos/core#comment" : [ {
    "@language" : "en",
    "@value" : "References to weatherability can be included as needed."
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A process driven by natural forces that applies to a piece of synthetic polymer-based material and results in changing appearance or mechanical properties of that piece."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000296",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic debris weathering"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000295"
  }, {
    "@id" : "_:genid1286"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A weathering process of a piece of synthetic polymer-based material that applies to a plastic debris particle."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000001",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "In the original definition, INO developers define this class with respect to interactors involved in the interaction process. INO includes the classes “interactor” and “interactor role” (see SeeAlso note). Here, we generalize this definition, excluding reference to interactors. In the context of SCO, we aim to provide users with an upper-level class that generally points to the involvement of material entities in an interaction process mutually influencing each other. We suggest not using this class directly but, instead, extending SCO-provided subclasses as needed. We wish users to classify interactions according to whether they occur among system components, among system environment components, or between system and system environment components.\nOriginal definition: “Interaction is a processual entity that has two or more participants (i.e., interactors) that have an effect upon one another.”"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "interaction"
  }, {
    "@language" : "fr",
    "@value" : "interaction"
  }, {
    "@language" : "it",
    "@value" : "interazione"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "http://purl.obolibrary.org/obo/INO_0000015 \nhttp://purl.obolibrary.org/obo/INO_0000016"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000015"
  }, {
    "@id" : "_:genid1292"
  }, {
    "@id" : "_:genid1300"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1287"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A process that has at least two independent continuants (no spatial regions) as participants that have an effect upon one another."
  }, {
    "@language" : "it",
    "@value" : "Un processo che ha almeno due continuanti indipendenti (no regioni spaziali) come partecipanti, aventi un effetto l’una sull’altra."
  }, {
    "@language" : "fr",
    "@value" : "Un processus qui a au moins deux continuants indépendants (pas de régions spatiales) comme participants, ayant un effet l’une sur l’autre."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom" : [ {
    "@value" : "http://purl.obolibrary.org/obo/INO_0000002"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000002",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "SCO must extend its representation to (complex) system behaviors. A possible starting point may be the work of Calhau et al. (2023) and Calhau et al. (2024).\n\nCalhau, R., Sales, T. P., Almeida, J. P. A., & Guizzardi, G. (2023). Exploring system behavior in a system ontology. Int Conf Concept Model.\n\nCalhau, R. F., Prince Sales, T., Oliveira, Í., Kokkula, S., Ferreira Pires, L., Cameron, D., Guizzardi, G., & Almeida, J. P. A. (2024). A System Core Ontology for Capability Emergence Modeling. In H. A. Proper, L. Pufahl, D. Karastoyanova, M. Van Sinderen, & J. Moreira (A c. Di), Enterprise Design, Operations, and Computing (Vol. 14367, pp. 3–20). Springer Nature Switzerland. https://doi.org/10.1007/978-3-031-46587-1_1"
  }, {
    "@value" : "This class aims to be the starting point for developing a representation of system change. Future SCO implementations will provide additional classes and object properties addressing system behaviors, system processes, system scales and levels, and related themes.\n\nRelated axioms must be revised accordingly."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "développement de système"
  }, {
    "@language" : "it",
    "@value" : "sviluppo del sistema"
  }, {
    "@language" : "en",
    "@value" : "system development"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000015"
  }, {
    "@id" : "_:genid1308"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000011"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A process whose specific outcome is the progression of a system over time from an initial condition to a later condition."
  }, {
    "@language" : "it",
    "@value" : "Un processo il cui specifico risultato è la progressione di un sistema nel tempo da una condizione iniziale a una condizione successiva."
  }, {
    "@language" : "fr",
    "@value" : "Un processus dont le résultat spécifique est la progression d’un système dans le temps, depuis une condition initiale à une condition suivante."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom" : [ {
    "@value" : "http://purl.obolibrary.org/obo/GO_0032502"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000003",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym" : [ {
    "@value" : "indicator information"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "il valore dell'indicatore"
  }, {
    "@language" : "en",
    "@value" : "indicator value"
  }, {
    "@language" : "fr",
    "@value" : "la valeur de l’indicateur"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@language" : "en",
    "@value" : "See the comments under the corresponding \"indicator\" class."
  }, {
    "@value" : "http://purl.unep.org/sdg/SDGIO_00000000\nhttp://purl.unep.org/sdg/SDGIO_00000001 \nhttp://purl.unep.org/sdg/SDGIO_00000003"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/RepresentationalInformationContentEntity"
  }, {
    "@id" : "_:genid1319"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1312"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A representational information content entity that generically depends on some indicator and is about, providing insights into, the complex system to which the indicator belongs."
  }, {
    "@language" : "fr",
    "@value" : "Un contenu représentatif d’information qui dépend de façon générique d’un indicateur et qui concerne, fournissant des indications/renseignements, sur le système complexe auquel l’indicateur appartient."
  }, {
    "@language" : "it",
    "@value" : "Un contenuto informativo rappresentativo che genericamente dipende da un indicatore e riguarda, fornisce informazioni sul, sistema complesso a cui l'indicatore appartiene."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000004",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "contenu informatif de la perspective"
  }, {
    "@language" : "it",
    "@value" : "contenuto informativo della prospettiva"
  }, {
    "@language" : "en",
    "@value" : "perspective information content entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/InformationContentEntity"
  }, {
    "@id" : "_:genid1327"
  }, {
    "@id" : "_:genid1334"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000005"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1323"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An information content entity that generically depends on some complex system component or complex system environment component and is about the perspective (that concretizes it) of that complex system component or complex system environment component."
  }, {
    "@language" : "fr",
    "@value" : "Un contenu d’information qui dépend de façon générique d’une composante de système complexe ou d’une composant d’environnement de système complexe et qui concerne la perspective (qui le concrétise) de cette composante de système complexe ou de cette composante environnement de système complexe."
  }, {
    "@language" : "it",
    "@value" : "Un contenuto informativo che dipende genericamente da una componente del sistema complesso o da una componente dell'ambiente del sistema complesso e riguarda la prospettiva (che lo concretizza) di tale componente del sistema complesso o dell’ambiente del sistema complesso."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000005",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "contenu informatif de la valeur"
  }, {
    "@language" : "it",
    "@value" : "contenuto informativo del valore"
  }, {
    "@language" : "en",
    "@value" : "worth information content entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/InformationContentEntity"
  }, {
    "@id" : "_:genid1342"
  }, {
    "@id" : "_:genid1352"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1338"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An information content entity that generically depends on a complex system or a complex system environment (or some part(s) of them) and is about the worth (that concretizes it) that some complex system component or complex system environment component recognizes that that complex system or complex system environment (or some part(s) of them) bearer."
  }, {
    "@language" : "fr",
    "@value" : "Un contenu d’information qui dépend de façon générique d’un système complexe ou de l’environnement de système complexe (ou une ou plus parties de ceux-ci) et qui concerne la valeur (qui le concrétise) qu’une composante de système complexe ou de son environnement reconnaît d’avoir à ce système complexe-là ou à ce-t-environnement de système complexe-là (ou une ou plus parties de celux-ci)."
  }, {
    "@language" : "it",
    "@value" : "Un contenuto informativo che dipende genericamente dal sistema complesso o dall'ambiente del sistema complesso (o una o più parti di essi) e riguarda il valore (che lo concretizza) che una componente del sistema complesso del suo ambiente riconosce di avere a quel sistema complesso o ambiente del sistema complesso (o una o più parti di essi)."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000006",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@value" : "system context"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "See the comment under the \"system\" class."
  }, {
    "@language" : "en",
    "@value" : "We envision discussions with subject matter experts regarding whether the current SCO representation of system-system component (and related environment) parthood is suitable or whether a proper parthood-based representation is more adequate. Insights for discussion may be found in Calhau et al. (2024) and Ubbiali et al. (2024).\n\nCalhau, R. F., Prince Sales, T., Oliveira, Í., Kokkula, S., Ferreira Pires, L., Cameron, D., Guizzardi, G., & Almeida, J. P. A. (2024). A System Core Ontology for Capability Emergence Modeling. In H. A. Proper, L. Pufahl, D. Karastoyanova, M. Van Sinderen, & J. Moreira (A c. Di), Enterprise Design, Operations, and Computing (Vol. 14367, pp. 3–20). Springer Nature Switzerland. https://doi.org/10.1007/978-3-031-46587-1_1\n\nUbbiali, G. A., Borghini, A., & Lange, M. C. (2024). Ontologies for Sustainability: Theoretical Challenges. https://doi.org/10.31219/osf.io/z8uqr"
  } ],
