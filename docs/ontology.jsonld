    "@value" : "planned transportation process of a piece of synthetic plastic"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000284"
  }, {
    "@id" : "_:genid1268"
  }, {
