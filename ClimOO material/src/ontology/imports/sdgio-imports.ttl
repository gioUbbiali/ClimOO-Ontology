  owl:annotatedTarget "persistent organic pollutants";
  <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ChEBI" .

<http://purl.obolibrary.org/obo/CHEBI_78298> a owl:Class .

<http://purl.obolibrary.org/obo/ENVO_00010483> a owl:Class .

