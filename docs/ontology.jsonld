  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relation between a cell and molecule or complex such that every instance of the cell has a low number of instances of that molecule expressed on the cell surface."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0016002",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relationship that holds between an organism and a disease. Here a disease is construed broadly as a disposition to undergo pathological processes that exists in an organism because of one or more disorders in that organism."
  } ]
}, {
