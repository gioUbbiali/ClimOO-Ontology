                                            <http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/valid_for_go_annotation_extension> ,
                                                                                                    <http://purl.obolibrary.org/obo/valid_for_gocam> ;
                                            rdfs:label "causally upstream of"@en .


