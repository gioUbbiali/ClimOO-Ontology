    "@id" : "_:genid890"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A portion of synthetic polymer-based material that bears a disposition to be elastic (elasticity) and a dispostion to be thermoplastic (thermoplasticity)."
  } ],
