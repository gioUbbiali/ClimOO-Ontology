                                                                            ]
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002234> ;
                                                         owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/CHEBI_24431>
                                                                                                   [ rdf:type owl:Class ;
                                                                                                     owl:complementOf [ rdf:type owl:Restriction ;
                                                                                                                        owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                                                                                        owl:someValuesFrom :ClimOO_0000163
                                                                                                                      ]
                                                                                                   ]
                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/RO_0000087> ;
                                                                                                     owl:someValuesFrom <http://purl.obolibrary.org/obo/CHEBI_78298>
                                                                                                   ]
                                                                                                 ) ;
                                                                              rdf:type owl:Class
                                                                            ]
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0002427> ;
                                  owl:someValuesFrom :ClimOO_0000266
                                ] ;
                <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "release of plastic-carried pollutants"@en ;
                rdfs:comment """Implementations may revise this class axiomatization with reference to more adequate and specific object properties to represent variations of levels of plastic debris presence. Revisions will primarily target the object property “increased levels of”.
Also, see comments to the object property “increased levels of”.

http://purl.obolibrary.org/obo/ENVO_02000200"""@en ,
                             "Pollutants may have synergizing or antagonizing effects on each other. We envision implementations to expand the representation in such a direction."@en ,
                             "This class axiomatization requires revisions. Implementations are needed to further restrict the class coverage to cases of interest. Currently the model allows some undesirable cases, such as when pollutants released and acquired are not the same."@en ,
                             "We envision extending this class by including references to specific sources and sinks as well as debris surface mechanisms of sorption of pollutants."@en ;
                rdfs:label "release process of plastic debris-carried pollutants into the environment"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A transportation process that has some portion of synthetic polymer-based material (generally synthetic plastic) composing some plastic debris and having some pollutants as part, as participant, and, as output, 1) that portion of synthetic polymer-based material with a decreased level of those pollutants as part, and 2) some other portion(s) of material with an increased level of those pollutants (both compared to levels prior participating into that process)."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .


###  https://www.w3id.org/climoo#ClimOO_0000203
:ClimOO_0000203 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/CHEBI_23367> ,
                                [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/CHEBI_23367>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                         owl:someValuesFrom :ClimOO_0000248
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000087> ;
                                                         owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_01000665>
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002353> ;
                                                         owl:someValuesFrom :ClimOO_0000278
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                  owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0000125>
                                ] ;
                rdfs:comment "An upper-level class concerning residues included in polymer materials other than plastics can be added as needed."@en ,
                             "Here the focus is on the actual molecules that are residual molecules incorporated into the plastic materials. If the need arises for a more meso- or macroscopical representation of residues, the ClimOO Ontology will implement the current model."@en ,
                             "References to molecules that are accidentally incorporated but are not an output or are consideraed asby-product of the manufacturing process can be added if needed."@en ,
                             "References to molecules that are not incorporated yet can be added if needed."@en ;
                rdfs:label "residue molecule of synthetic plastic manufacturing"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A molecule that is a waste of some plastic manufacturing process and is incorporated into some portion of synthetic plastic material."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


