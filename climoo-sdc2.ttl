                                                                                                :ClimOO_0000318
                                                                                              )
                                                                                ]
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :ClimOO_0000302 ;
                owl:disjointWith :ClimOO_0000314 ;
                rdfs:label "climate system agent"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An climate system component that is an agent in an interaction among climate system components or in an interaction between climate system components and climate system environment components."@en ;
