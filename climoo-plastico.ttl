                <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "plastic weathering"@en ;
                rdfs:label "plastic degradation process"@en ;
                rdfs:seeAlso "http://purl.allotrope.org/ontologies/process#AFP_0003641" ;
                <http://www.w3.org/2004/02/skos/core#definition> "An process that leads some polymer molecules constituting some portion of plastic to vary their physical and chemical qualities due to interactions with factors such as heat, light, or chemical entities, resulting in a decrease in their molecular weight."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
