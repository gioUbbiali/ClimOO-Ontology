###  http://purl.obolibrary.org/obo/RO_0003000
<http://purl.obolibrary.org/obo/RO_0003000> rdf:type owl:ObjectProperty ;
                                            owl:inverseOf <http://purl.obolibrary.org/obo/RO_0003001> ;
