    "@value" : "An interaction relationship in which the two partners are molecular entities that directly physically interact with each other for example via a stable binding interaction or a brief interaction during which one modifies the other."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
