    "@language" : "en",
    "@value" : "may be identical to"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A annotation relationship between two terms in an ontology that may refer to the same (natural) type but where more evidence is required before terms are merged."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@language" : "en",
    "@value" : "David Osumi-Sutherland"
  } ]
}, {
