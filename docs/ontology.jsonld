    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x developmentally replaces y if and only if there is some developmental process that causes x to move or to cease to exist, and for the site that was occupied by x to become occupied by y, where y either comes into existence in this site or moves to this site from somewhere else"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "This relation is intended for cases such as when we have a bone element replacing its cartilage element precursor. Currently most AOs represent this using 'develops from'. We need to decide whether 'develops from' will be generic and encompass replacement, or whether we need a new name for a generic relation that encompasses replacement and development-via-cell-lineage"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@value" : "replaces"
  } ]
