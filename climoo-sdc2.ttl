                                                             owl:someValuesFrom :ClimOO_0000297
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf <https://www.w3id.org/sco#SCO_0000015> ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                                         owl:someValuesFrom :ClimOO_0000302
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000111> ;
                                                         owl:someValuesFrom :ClimOO_0000310
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000166> ;
                                                         owl:someValuesFrom :ClimOO_0000319
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000185> ;
                                                         owl:someValuesFrom :ClimOO_0000315
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000211> ;
                                                         owl:someValuesFrom :ClimOO_0000311
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002163> ;
                                                         owl:someValuesFrom :ClimOO_0000313
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000185> ;
                                                         owl:allValuesFrom :ClimOO_0000315
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                owl:disjointWith :ClimOO_0000313 ;
                rdfs:label "climate system"@en ;
                rdfs:seeAlso "http://purl.obolibrary.org/obo/ENVO_01001364" ,
                             "http://www.semanticweb.org/Davarpanah-Babaie/ontologies/2021/9/ClimateOnSDG1267#Climate_System_Role and subclasses" ;
                <http://www.w3.org/2004/02/skos/core#definition> "A complex system that bears a climate disposition. Earth climate systemt is mainly composed of the atmosphere, the hydrosphere, the cryosphere, the lithosphere and the biosphere."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "https://www.ipcc.ch/report/ar6/syr/downloads/report/IPCC_AR6_SYR_FullVolume.pdf" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000306 ,
                                                       :ClimOO_0000307 ,
                                                       :ClimOO_0000308 .


###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000299
:ClimOO_0000299 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( <http://www.ontologyrepository.com/CommonCoreOntologies/MeasurementInformationContentEntity>
                                                           [ rdf:type owl:Restriction ;
