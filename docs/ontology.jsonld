}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000012",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@value" : "complex system context"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "ambiente del sistema complesso"
  }, {
    "@language" : "en",
    "@value" : "complex system environment"
  }, {
    "@language" : "fr",
    "@value" : "environnement de système complexe"
  } ],
