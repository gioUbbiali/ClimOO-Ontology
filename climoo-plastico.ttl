                                                       :ClimOO_0000228 .


###  https://www.w3id.org/climoo#ClimOO_0000254
:ClimOO_0000254 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000030> ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                         owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0000052>
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                         owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0000117>
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                         owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0000125>
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                         owl:someValuesFrom [ rdf:type owl:Class ;
                                                                              owl:unionOf ( <http://purl.obolibrary.org/obo/PATO_0000141>
                                                                                            <http://purl.obolibrary.org/obo/PATO_0001332>
                                                                                          )
                                                                            ]
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000091> ;
                                                         owl:someValuesFrom <http://www.ontologyrepository.com/CommonCoreOntologies/Color>
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                  owl:someValuesFrom :ClimOO_0000246
                                ] ;
                rdfs:comment """ClimOO Ontology comment:
Reference to weight can be added as needed."""@en ,
                             "Implementations require to address composition threshold. We envision discussion with subject matter experts."@en ,
                             "We intend this class, and subclasses, as denoting generic identifiable causally unitary bona fide portions of (made of) plastic materials. This could be a fragment of natural or synthetic plastic material, or a plastic object, such as a plastic bottle."@en ;
                rdfs:label "piece of polymer-based material"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An object that is made of some portion of polymer-based material." ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .


###  https://www.w3id.org/climoo#ClimOO_0000255
:ClimOO_0000255 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000153 ;
                rdfs:label "plastic film"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A piece of synthetic plastic which is flexible, thin, and planar."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "http://purl.obolibrary.org/obo/ENVO_06105007" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000256
:ClimOO_0000256 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :ClimOO_0000253
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/RO_0002353> ;
                                                             owl:someValuesFrom :ClimOO_0000169
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :ClimOO_0000253 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                  owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0005020>
                                ] ;
                rdfs:label "plastic fragment"@en ;
                rdfs:seeAlso "http://purl.obolibrary.org/obo/ENVO_06105008" ;
                <http://www.w3.org/2004/02/skos/core#definition> "A piece of plastic that is an output of a plastic fragmentation process."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000257
:ClimOO_0000257 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000253 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                  owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0001199>
                                ] ;
                rdfs:label "plastic line"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A piece of plastic which is linear and flexible."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "http://purl.obolibrary.org/obo/ENVO_06105009" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000258
:ClimOO_0000258 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000153 ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                         owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0001546>
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                         owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0001865>
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:comment "Pellets are normally produced as such. They are often used as raw materials for further manufacturing processes. Pellets are of a small size (threshold to be defined)."@en ;
                rdfs:label "plastic pellet"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A piece of solid (at room temperature) synthetic plastic which is 1) hard, 2) has a smooth external surface, and 3) has a roughly spherical or granular shape."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "http://purl.obolibrary.org/obo/ENVO_06105010" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> .


###  https://www.w3id.org/climoo#ClimOO_0000259
:ClimOO_0000259 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000258 ;
                <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "pre-production plastic pellets"@en ;
                rdfs:label "plastic nurdle"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A plastic pellet that is manufactured in such a way that its size enables quick melting thereby making it usable for further downstream manufacturing processes."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "http://purl.obolibrary.org/obo/ENVO_01000777" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000260
:ClimOO_0000260 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000230 ;
                rdfs:label "secondary microplastic particle"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A microplastic debris particle that derives from a fragmentation process occurring in an environment (no human intention involved) or results from the usage of some items made of polymer-based materials."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "http://purl.obolibrary.org/obo/ENVO_01000946" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000073 .


###  https://www.w3id.org/climoo#ClimOO_0000261
:ClimOO_0000261 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000231 ;
                rdfs:label "nanoplastic particle - Hartmann et al. (2019) classification"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A plastic debris particle that is between 1 and 1000 nm in its largest dimension."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000073 .


###  https://www.w3id.org/climoo#ClimOO_0000262
:ClimOO_0000262 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000230 ;
                rdfs:label "primary microplastic particle"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A microplastic debris particle that was, at the origin, intentionally designed and produced of this size (1-1000 µm)."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "http://purl.obolibrary.org/obo/ENVO_01000945" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000073 .


###  https://www.w3id.org/climoo#ClimOO_0000263
:ClimOO_0000263 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/GO_0008150> ;
                rdfs:comment """Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.

It is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.

We envision implementing such definitions in accordance with regulation revisions and novel research findings."""@en ;
                rdfs:label "biodegradation process"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A process driven by biological entities that changes the physical and chemical qualities of some molecular entities, resulting in a decrease in their molecular weight."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000264
:ClimOO_0000264 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :ClimOO_0000180
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                             owl:someValuesFrom [ owl:intersectionOf ( :ClimOO_0000109
                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000177> ;
                                                                                                         owl:someValuesFrom :ClimOO_0000107
                                                                                                       ]
                                                                                                     ) ;
                                                                                  rdf:type owl:Class
                                                                                ]
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf [ owl:intersectionOf ( :ClimOO_0000168
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                         owl:someValuesFrom [ owl:intersectionOf ( :ClimOO_0000109
                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000177> ;
                                                                                                     owl:someValuesFrom :ClimOO_0000107
                                                                                                   ]
                                                                                                 ) ;
                                                                              rdf:type owl:Class
                                                                            ]
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:comment "To date, the ClimOO ontology does not restrict such classes to solely refer to wasted plastics. Implementations may extend the current representation in such a direction, if needed. The only exception is the “plastic composting process” class, given that the aimed specific focus on composting of waste plastics."@en ,
                             "We primarily focused on biodegradability in relation to synthetic plastics, related polymers and items. Reference to biodegradability concerning plastics more in general, for instance in relation to natural plastics, or in relation to polymer-based materials can be added as needed."@en ;
                rdfs:label "biodegradation process of plastic"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "a polymer biodegradation that applies to some biodegradable polymer molecules constituting a portion of biodegradable plastic."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000265
:ClimOO_0000265 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
                rdfs:comment "According to EnvO, we consider this class as provisional. We envision implementations."@en ;
                rdfs:label "transportation process"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A process during which material entities are displaced from a location and moved either to a new location or back to the original location."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "http://purl.obolibrary.org/obo/ENVO_03000010" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> .


###  https://www.w3id.org/climoo#ClimOO_0000266
:ClimOO_0000266 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000167> ;
                                                         owl:someValuesFrom :ClimOO_0000164
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000167> ;
                                                         owl:someValuesFrom :ClimOO_0000166
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:comment "Implementations will expand current representation to distinguish intentional from unintentional plastic pollution processes."@en ;
                rdfs:label "plastic pollution process"@en ;
                rdfs:seeAlso "http://purl.obolibrary.org/obo/ENVO_02500040"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A process during which plastic debris particles are released into and possibly accumulated in an environment, from some plastic debris source to some plastic debris sink."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .


###  https://www.w3id.org/climoo#ClimOO_0000267
:ClimOO_0000267 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :ClimOO_0000246
                                                           [ rdf:type owl:Restriction ;
