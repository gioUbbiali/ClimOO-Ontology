                rdfs:subClassOf :ClimOO_0000247 ;
                rdfs:label "portion of natural plastic material"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A potion of plastic that is constituted of polymer molecules produced by processes whose agents do not include humans or their technologies."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "http://purl.obolibrary.org/obo/ENVO_06105111" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000250
:ClimOO_0000250 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :ClimOO_0000246
                                                           [ rdf:type owl:Restriction ;
