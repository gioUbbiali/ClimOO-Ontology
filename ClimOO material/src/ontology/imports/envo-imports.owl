                                                               ] ;
                                               <http://purl.obolibrary.org/obo/IAO_0000115> "A mass of solid material which is primarily composed of plastic."@en ;
                                               <http://purl.org/dc/elements/1.1/contributor> <https://orcid.org/0000-0002-2996-719X> ,
                                                                                             <https://orcid.org/0000-0002-8166-0486> ,
                                                                                             <https://orcid.org/0000-0003-1072-8081> ;
                                               <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "Plastikstück"@de ,
                                                                                                              "pedazo de plástico"@es ,
                                                                                                              "pezzo di plastica"@it ;
                                               <http://www.geneontology.org/formats/oboInOwl#inSubset> "envoPlastics"@es ;
                                               rdfs:label "piece of plastic"@en .

_:genid178 owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_01001687>
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                   owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_06105101>
                                 ]
                               ) ;
            rdf:type owl:Class .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://purl.obolibrary.org/obo/ENVO_01000776> ;
   owl:annotatedProperty owl:equivalentClass ;
   owl:annotatedTarget _:genid178 ;
   rdfs:comment """ClimOO developer comment:
We expand coverage of this class, generalizing this axiom to refer to plastic in general rather than to solely synthetic plastic. We also changed the object property with a more general one, as some piece of plastic may contain amount of other material, for instance additives, exceeding 50%."""@en
 ] .


