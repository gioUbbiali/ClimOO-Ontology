                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000253
:ClimOO_0000253 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000254 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                  owl:someValuesFrom :ClimOO_0000247
                                ] ;
                rdfs:comment "Not all plastics are solid and not under all conditions and temperatures."@en ;
                rdfs:label "piece of plastic"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A piece of polymer-based material that is made of plastic."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
