    "@value" : "2018-12-13T11:26:32Z"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#inSubset" : [ {
    "@id" : "http://purl.oboInOwllibrary.org/oboInOwl/valid_for_go_ontology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "has primary output"
  } ],
