:ClimOO_0000231 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000163 ;
                rdfs:comment "This class has only been created for grouping purposes. Do not use it directly."@en ,
                             "We included the double-inheritance axiom, even if it’s not the preferred practice, because some of these classes pertain to both classification systems."@en ;
                rdfs:label "plastic debris particle - Hartmann et al. (2019) size classification"@en ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000073 .


