  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "References to slightly natural polymers can be added as needed."
  }, {
    "@value" : "References to related processes can be added as needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
