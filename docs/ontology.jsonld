  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid75"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "location of at all times"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid79"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000124"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b location of c at all times =Def for all times t, b exists at t implies (c located in b at t)"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "location of at all times"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/BFO_0000171",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "234-BFO"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid83"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "located in"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid87"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b located in c =Def b is an independent continuant & c is an independent & neither is a spatial region & there is some time t such that the spatial region which b occupies at t is continuant part of the spatial region which c occupies at t"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "located in at some time"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/BFO_0000172",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "231-BFO"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000040"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has member part at all times"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000040"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000110"
  }, {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000115"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b has member part c at all times =Def for all times t, b exists at t implies (c member part b at t)"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "has member part at all times"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/BFO_0000173",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "229-BFO"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000040"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "member part of at all times"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000040"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000129"
  }, {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000177"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b member part of c at all times =Def for all times t, b exists at t implies (b is an object & c is an object aggregate & there is at t a mutually exhaustive and pairwise disjoint partition of c into objects x1,..., xn (for some n ≠ 1) with b = xi (for some 1 <= i <= n))"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "member part of at all times"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/BFO_0000174",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "226-BFO"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000002"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has proper continuant part at some time"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000002"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000178"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000175"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b has proper continuant part c at some time =Def c proper continuant part of b at some time"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "has proper continuant part at some time"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/BFO_0000175",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "224-BFO"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000002"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "proper continuant part of at some time"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000002"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000176"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b proper continuant part of c at some time =Def for some time t (b continuant part of c at t & not (c continuant part of b at t)"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "proper continuant part of at some time"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/BFO_0000176",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "221-BFO"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000002"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "continuant part of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000002"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000178"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b continuant part of c =Def b and c are continuants & there is some time t such that b and c exist at t & b continuant part of c at t"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "Milk teeth continuant part of human; surgically removed tumour continuant part of organism"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "continuant part of at some time"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/BFO_0000177",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#TransitiveProperty" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "222-BFO"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000002"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "continuant part of at all times"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000002"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000176"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b continuant part of c at all times =Def for all times t, (b exists at t, implies b continuant part of c at t & t is a temporal region & b and c are continuants)"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "Centre of mass of a material entity continuant part of material entity at all times; continuant fiat external boundary of an object continuant part of object at all times."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "continuant part of at all times"
  } ]
