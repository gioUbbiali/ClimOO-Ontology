                                       owl:equivalentClass [ owl:intersectionOf ( <https://www.w3id.org/sco#SCO_0000031>
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000137> ;
                                                                                    owl:someValuesFrom <https://w3id.org/sumso#SuMSO_0000004>
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ] ;
                                       rdfs:subClassOf <https://www.w3id.org/sco#SCO_0000031> ;
                                       rdfs:label "food system boundary"@en ;
