<http://ClimOO/climoo/imports/envo-imports/envo-imports> rdf:type owl:Ontology ;
                                                          owl:versionIRI <http://ClimOO/climoo/imports/envo-imports/envo-imports#2026-02-24> ;
                                                          rdfs:comment """This file contains ClimOO Ontology imports fletched from the Environment Ontology (EnvO) via OntoFox (https://ontofox.hegroup.org/index.php). This file also contains some ClimOO Ontology imports from the Environmental Ontology (EnvO) and some imports, reused by this ontology, from the Relation Ontology (RO) that were manually collected and revised.

Ontology source: https://ontobee.org/ontology/ENVO http://purl.obolibrary.org/obo/envo.owl
Other ontology sources: https://oborel.github.io/"""@en ;
                                                          rdfs:seeAlso """The related imports file
https://github.com/ClimOO/ClimOO-Ontology/tree/main/ClimOO%20material/src/ontology/imports/plastico%20imports/envo-imports-2.ttl
https://github.com/ClimOO/ClimOO-Ontology/tree/main/ClimOO%20material/src/ontology/imports/plastico%20imports/envo-imports-2.ttl"""@en ,
                                                                       "https://github.com/EnvironmentOntology/envo" ;
                                                          owl:versionInfo "2026-02-24" .

