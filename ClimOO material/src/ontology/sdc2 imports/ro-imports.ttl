               oboInOwl:inSubset <http://purl.oboInOwllibrary.org/oboInOwl/ro/subsets#ro-eco> ;
               rdfs:comment "X ends_after Y iff: end(Y) before_or_simultaneous_with end(X)"@en ;
               rdfs:label "ends after"@en .


