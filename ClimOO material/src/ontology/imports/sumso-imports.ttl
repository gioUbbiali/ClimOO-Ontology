                                       <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://w3id.org/sumso#SuMSO_0000028
<https://w3id.org/sumso#SuMSO_0000028> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://www.w3id.org/sco#SCO_0000021> ,
                                                       [ owl:intersectionOf ( <https://www.w3id.org/sco#SCO_0000021>
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <https://www.w3id.org/sco#SCO_0000037> ;
                                                                                owl:someValuesFrom <https://w3id.org/sumso#SuMSO_0000032>
                                                                              ]
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <https://www.w3id.org/sco#SCO_0000037> ;
                                                                                owl:allValuesFrom <https://w3id.org/sumso#SuMSO_0000032>
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ] ;
                                       owl:disjointWith <https://w3id.org/sumso#SuMSO_0000029> ;
                                       rdfs:label "interaction among food system environment components"@en ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "An interaction among complex system environment components that occurs among at least two food system environment components."@en ;
