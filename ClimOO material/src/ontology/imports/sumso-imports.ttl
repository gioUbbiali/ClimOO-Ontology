<http://purl.obolibrary.org/obo/ENVO_00000114> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_01000352> ,
                                                               [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_01000352>
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
