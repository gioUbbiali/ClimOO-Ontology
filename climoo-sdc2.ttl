                                                             owl:someValuesFrom :ClimOO_0000300
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf <http://www.ontologyrepository.com/CommonCoreOntologies/MeasurementInformationContentEntity> ;
                rdfs:label "climate variability - measurement"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An information content entity that is a measurement of the deviations of climate over a period of time from the long-term climate statistics for the corresponding calendar period.An information content entity that is a measurement of the deviations of climate over a period of time from the long-term climate statistics for the corresponding calendar period."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "https://unterm.un.org/unterm2/en/view/e0be578f-2cfc-401c-b536-7d5de7fe8559" ;
