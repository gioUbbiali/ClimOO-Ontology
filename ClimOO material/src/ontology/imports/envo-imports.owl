###  http://purl.obolibrary.org/obo/ENVO_01001110
<http://purl.obolibrary.org/obo/ENVO_01001110> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_01000254> ;
                                               <http://purl.obolibrary.org/obo/IAO_0000115> "An environmental system which includes both living and non-living components." ;
                                               <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "LTER:173" ;
