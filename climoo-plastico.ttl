###  https://www.w3id.org/climoo#ClimOO_0000097
:ClimOO_0000097 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000248 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                  owl:someValuesFrom :ClimOO_0000100
                                ] ;
                <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "bio-based plastic"@en ,
                                                                               "bioplastic"@en ;
                rdfs:label "portion of bio-based plastic material"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A portion of synthetic plastic material that is composed of biobased polymer molecules."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000098
:ClimOO_0000098 rdf:type owl:Class ;
                rdfs:subClassOf [ owl:intersectionOf ( :ClimOO_0000143
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000085> ;
                                                         owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000034>
                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                     owl:someValuesFrom :ClimOO_0000173
                                                                                                   ]
                                                                                                 ) ;
                                                                              rdf:type owl:Class
                                                                            ]
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:label "bio-based plastic object"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A plastic object that is primarily made of bio-based plastic."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000099
:ClimOO_0000099 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :ClimOO_0000278
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/RO_0004008> ;
                                                             owl:someValuesFrom :ClimOO_0000097
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :ClimOO_0000278 ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0004008> ;
                                                         owl:someValuesFrom :ClimOO_0000097
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0004009> ;
                                                         owl:someValuesFrom :ClimOO_0000100
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:comment "Reference to fossil and nonfossil feedstocks, such asrenewable feedstock, fossil fuel feedstock, biomass feedstock, related roles, and specific types, such as petroleum and biomasses, can be added as needed."@en ;
                rdfs:label "bio-based plastic manufacturing process"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A plastic manufacturing process that has some bio-based plastic polymer molecules as the main input and some portion of bio-based plastic material as the main output."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000100
:ClimOO_0000100 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000210 ;
                rdfs:comment "Reference to specif feedstock and related production processes can be added, as needed."@en ;
                rdfs:label "bio-based polymer molecule"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A synthetic polymer molecule that is derived from some nonfossil feedstock."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000104
:ClimOO_0000104 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000016> ;
                rdfs:comment """Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.

It is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.

We envision implementing such definitions in accordance with regulation revisions and novel research findings."""@en ,
                             "References to degradable polymers and degradability can be added as needed."@en ,
                             "We primarily focused on biodegradability in relation to synthetic plastics, related polymers and items. Reference to biodegradability concerning plastics more in general, for instance in relation to natural plastics, or in relation to polymer-based materials can be added as needed."@en ;
                rdfs:label "biodegradability"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A disposition that is realised in a biodegradation process."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .


###  https://www.w3id.org/climoo#ClimOO_0000107
:ClimOO_0000107 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000247 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                  owl:someValuesFrom :ClimOO_0000109
                                ] ;
                <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "biodegradable plastic"@en ;
                rdfs:label "portion of biodegradable plastic material"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A portion of plastic material that is constituted by biodegradable polymer molecules, is the main input of a process of biodegradation of plastic, and is the main output of a production process of biodegradable plastic."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000108
:ClimOO_0000108 rdf:type owl:Class ;
                rdfs:subClassOf [ owl:intersectionOf ( :ClimOO_0000145
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0000085> ;
                                                         owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000034>
                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                     owl:someValuesFrom :ClimOO_0000173
                                                                                                   ]
                                                                                                 ) ;
                                                                              rdf:type owl:Class
                                                                            ]
                                                       ]
