                                            rdfs:subPropertyOf <http://purl.obolibrary.org/obo/RO_0002500> ;
                                            <http://purl.obolibrary.org/obo/IAO_0000112> "pyrethroid -> growth" ;
                                            <http://purl.obolibrary.org/obo/IAO_0000115> "Holds between c and p if and only if c is capable of some activity a, and a regulates p." ;
                                            <http://purl.obolibrary.org/obo/IAO_0000119> <http://purl.obolibrary.org/obo/ro/docs/causal-relations> ;
                                            rdfs:label "capable of regulating" .


