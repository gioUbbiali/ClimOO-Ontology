<https://www.w3id.org/climoo/climoo-picco> rdf:type owl:Ontology ;
                                            owl:versionIRI :picco-v1.0.0 ;
                                            owl:imports <https://www.w3id.org/climoo/climoo-plastico#plastico-v1.0.0> ,
