:Cryosphere rdf:type owl:Class ;
            rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000024> ,
                            [ rdf:type owl:Class ;
                              owl:unionOf ( [ rdf:type owl:Class ;
                                              owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                            <https://www.w3id.org/sco#SCO_0000006>
                                                          )
                                            ]
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                              owl:someValuesFrom [ rdf:type owl:Class ;
                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                                                 <https://www.w3id.org/sco#SCO_0000006>
                                                                               )
                                                                 ]
                                            ]
                                          )
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                              owl:someValuesFrom :ClimOO_0000298
                            ] ;
            rdfs:label "portion of cryosphere"@en ;
            rdfs:seeAlso """http://www.ontologyrepository.com/CommonCoreOntologies/PortionOfCryosphere 
http://purl.obolibrary.org/obo/ENVO_03000143""" ;
            <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo/climoo-sdc2#Cryospheric_Change
:Cryospheric_Change rdf:type owl:Class ;
                    rdfs:subClassOf :ClimOO_0000304 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                      owl:someValuesFrom :Cryospheric_Material_Entity
                                    ] ;
                    rdfs:comment """ClimOO Ontology comment: 
We excluded the upper-level class “change in climate system” as misinformative with respect to BFO representation of change and processes. We reclassified these classes as a subclass of the climate system process class https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000304. We plan to discuss with subject matter experts to revise the model, implementing the current representation of changes and processes in the climate system. 

See https://www.w3id.org/climoo/climoo-sdc2#Change_in_Climate_System and https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000304"""@en ;
                    rdfs:label "cryospheric change"@en ;
                    <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> .


###  https://www.w3id.org/climoo/climoo-sdc2#Cryospheric_Material_Entity
:Cryospheric_Material_Entity rdf:type owl:Class ;
                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ,
                                             [ rdf:type owl:Class ;
                                               owl:unionOf ( [ rdf:type owl:Class ;
                                                               owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                                             <https://www.w3id.org/sco#SCO_0000006>
                                                                           )
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                               owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                    owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                                                                  <https://www.w3id.org/sco#SCO_0000006>
                                                                                                )
                                                                                  ]
                                                             ]
                                                           )
                                             ] ;
                             rdfs:comment """ClimOO Ontology comment:
We delete reference to the resource role, as not all cryospheric material entities necessarily bear this role. Same for the subclass with respect to the freshwater resource role."""@en ,
                                          """ClimOO Ontology comment:
we revised subclass labels to comply with BFO and OBO-Foundry best practices."""@en ;
                             rdfs:label "cryospheric material entity"@en ;
                             <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


