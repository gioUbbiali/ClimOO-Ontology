  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "biomineralization process of piece of synthetic biodegradable plastic"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000236"
  }, {
    "@id" : "_:genid1170"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1155"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A synthetic plastic biomineralization process that applies to some biodegradable synthetic polymer molecules constituting some potions of biodegradable synthetic plastic composing some piece of biodegradable synthetic plastic."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
