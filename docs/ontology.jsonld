  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Relates a gene to condition, such that a variation in this gene predisposes to the development of a condition."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0020101",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "brachial artery vessel supplies blood to brachialis muscle"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x vessel supplies blood to y if and only if x is a vessel that supplies blood directly or indirectly to an anatomical structure y."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0020102",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
