<http://ClimOO/climoo/imports/pmdco-imports> rdf:type owl:Ontology ;
                                                                          owl:versionIRI <http://ClimOO/climoo/imports/pmdco-imports#2026-03-02> ;
                                            rdfs:seeAlso """This file contains ClimOO Ontology imports from the Platform MaterialDigital Core Ontology (PMDco). Imports were manually collected and revised. it also includes some imports from ChEBI, RO, UO, IAO, and OBI reused by PMDco.

Ontology source: 
https://github.com/materialdigital/core-ontology/releases/tag/v3.0.0-rc2"""@en ;
                                            owl:versionInfo "2026-03-02" .

