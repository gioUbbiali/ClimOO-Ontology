}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000226",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "To date, the ClimOO Ontology does not cover related classes for synthetic polymer-based materials, as out of the current scope. Implementations can go in this direction if needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "manufacturing process of a piece of synthetic plastic"
  } ],
