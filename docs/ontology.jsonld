    "@language" : "en-us",
    "@value" : "entity responsible for making contributions to the resource"
  } ]
}, {
  "@id" : "http://purl.org/dc/terms/creator",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://purl.org/dc/terms/creator"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "creator"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.org/dc/terms/contributor"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "entity responsible for making the resource"
  } ]
}, {
  "@id" : "http://purl.org/dc/terms/date",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/description",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/license",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/dc/terms/source",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://purl.org/dc/terms/source"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "source"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "related resource from which the described resource is derived"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/explanatoryNote" : [ {
    "@language" : "en-us",
    "@value" : "The intent is to provide a user with a reference as to how the thing being annotated was derived or arrived at. \n - The source can be a URL to a standard, common dictionary (e.g. Oxford), or similar reference. Or it can be a short description of where the entity being annotated was derived from.\n - The 'Source' annotation would most likely be used as an annotation on an annotation. For instance annotating a Natural Language definition annotation."
  } ]
}, {
  "@id" : "http://purl.org/dc/terms/title",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.org/spar/cito/citesAsAuthority",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.unep.org/sdg/SDGIO_00000014",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000428"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A process which is causally within or downstream of another process whose direct or indirect effects cause one or more entities to realise one or more of their dispositions."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "The semantics of this class are being discussed and are very likely to change. Obsolescence is possible."
  }, {
    "@value" : "This class may be replaced by a class in EXO, pending a clarification on the scope of its meaning. Right now it is essentially the same as 'interaction'.\nhttps://github.com/SDG-InterfaceOntology/sdgio/issues/21"
  } ],
  "http://purl.unep.org/sdg/SDGIO_00000064" : [ {
    "@value" : "https://uneplive.unep.org/community/discussion/view/23253/exposure"
  } ],
  "http://purl.unep.org/sdg/SDGIO_00010058" : [ {
    "@value" : "A process during which an entity is impacted by some agent or preceeding event."
  } ],
  "http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym" : [ {
    "@value" : "exposure"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Consider that when \"E died of exposure to P\", E died as an outcome of the processes which were initiated by E's participation in P, in which E's dispositions to react to P (or its parts or participants) were realised."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "exposure process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000015"
  } ]
}, {
  "@id" : "http://purl.unep.org/sdg/SDGIO_00000020",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A disposition of a bearer to realise one or more of its vulnerabilities when participating in a process which exposes the bearer to a hazard or combination of hazards."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "https://github.com/SDG-InterfaceOntology/sdgio/issues/22"
  } ],
  "http://purl.unep.org/sdg/SDGIO_00000064" : [ {
    "@value" : "https://uneplive.unep.org/community/discussion/view/23229/risk"
  } ],
  "http://purl.unep.org/sdg/SDGIO_00010058" : [ {
    "@value" : "The possibility that an entity's vulnerabilities will be realised when exposed to a hazard."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Risk is increased when harm or damage is realised and when an entity is likely to encounter a hazard in some process.  The probability of this disposition being realised can be assigned on the information or data level."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000016"
  } ]
}, {
  "@id" : "http://purl.unep.org/sdg/SDGIO_00000024",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000428"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A disposition of an entity to undergo undesirable change in response to some exposure."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@language" : "en",
    "@value" : "Note that the definition endorsed by the UN General Assembly references the conditions that increase susceptibility to the impacts of hazards, rather than the susceptibilities themselves. The links between vulnerability, exposure, risk, and hazard are being developed. This definition will be updated accordingly. The definition currently used could be used for 'susceptible' too. Vulnerable has negative connotations."
  } ],
  "http://purl.unep.org/sdg/SDGIO_00000066" : [ {
    "@value" : "The conditions determined by physical, social, economic and environmental factors or processes which increase the susceptibility of an individual, a community, assets or systems to the impacts of hazards."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "vulnerability"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000016"
  }, {
    "@id" : "_:genid324"
  } ]
}, {
  "@id" : "http://purl.unep.org/sdg/SDGIO_00000064",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.unep.org/sdg/SDGIO_00000066",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://purl.unep.org/sdg/SDGIO_00010021",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A disposition of an entity to recover its previous composition, qualities, and functionality following some perturbation."
  } ],
  "http://purl.unep.org/sdg/SDGIO_00000064" : [ {
    "@value" : "https://uneplive.unep.org/community/discussion/view/23243/resilience"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This disposition is distinct from robustness, which pertains to an entity's ability to resist change when encountering perturbing forces."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "resilience"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000016"
  } ]
}, {
