  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has temporal part"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000003"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000117"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000139"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b has temporal part c =Def c temporal part of b"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "Your life has temporal part the first year of your life."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "has temporal part"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/BFO_0000124",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "236-BFO"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid45"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "location of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid49"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000171"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b location of c =Def c located in b"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "location of at some time"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/BFO_0000127",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "244-BFO"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000040"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "material basis of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000016"
  } ],
