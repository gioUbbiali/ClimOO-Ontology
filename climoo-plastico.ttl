                                                         owl:someValuesFrom [ owl:intersectionOf ( [ owl:intersectionOf ( :ClimOO_0000109
                                                                                                                          :ClimOO_0000210
                                                                                                                        ) ;
                                                                                                     rdf:type owl:Class
                                                                                                   ]
                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000177> ;
                                                                                                     owl:someValuesFrom :ClimOO_0000205
                                                                                                   ]
