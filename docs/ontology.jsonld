  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "An interaction that holds between two genetic entities (genes, alleles) through some genetic interaction (e.g. epistasis)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
