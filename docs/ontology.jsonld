}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002134",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "Relation between a 'neuron projection bundle' and a region in which one or more of its component neuron projections either synapses to targets or receives synaptic input.\nT innervates some R\nExpands_to: T has_fasciculating_neuron_projection that synapse_in some R."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-7073-9172"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002150",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#SymmetricProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "X continuous_with Y if and only if X and Y share a fiat boundary."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-7073-9172"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@value" : "connected to"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000232" : [ {
    "@value" : "The label for this relation was previously connected to. I relabeled this to \"continuous with\". The standard notion of connectedness does not imply shared boundaries - e.g. Glasgow connected_to Edinburgh via M8; my patella connected_to my femur (via patellar-femoral joint)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://purl.obolibrary.org/obo/RO_0001900" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0001901"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "continuous with"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "FMA:85972"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002323"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002151",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x partially overlaps y iff there exists some z such that z is part of x and z is part of y, and it is also the case that neither x is part of y or y is part of x"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "We would like to include disjointness axioms with part_of and has_part, however this is not possible in OWL2 as these are non-simple properties and hence cannot appear in a disjointness axiom"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@value" : "proper overlaps"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000426" : [ {
    "@value" : "(forall (?x ?y) \n\t(iff \n\t\t(proper_overlaps ?x ?y)\n\t\t(and \n\t\t\t(overlaps ?x ?y)\n\t\t\t(not (part_of ?x ?y)) \n\t\t\t(not (part_of ?y ?x)))))"
  } ],
  "http://purl.obolibrary.org/obo/RO_0001900" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0001901"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#inSubset" : [ {
    "@id" : "http://purl.oboInOwllibrary.org/oboInOwl/ro/subsets#ro-eco"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "partially overlaps"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002131"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002156",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "d derived_by_descent_from a if d is specified by some genetic program that is sequence-inherited-from a genetic program that specifies a."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@value" : "ancestral_stucture_of"
  }, {
    "@value" : "evolutionarily_descended_from"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002157",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "inverse of derived by descent from"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002158",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "two individual entities d1 and d2 stand in a shares_ancestor_with relation if and only if there exists some a such that d1 derived_by_descent_from a and d2 derived_by_descent_from a."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002159",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002160",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "lactation SubClassOf 'only in taxon' some 'Mammalia'"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x only in taxon y if and only if x is in taxon y, and there is no other organism z such that y!=z a and x is in taxon z."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "The original intent was to treat this as a macro that expands to 'in taxon' only ?Y - however, this is not necessary if we instead have supplemental axioms that state that each pair of sibling tax have a disjointness axiom using the 'in taxon' property - e.g.\n\n 'in taxon' some Eukaryota DisjointWith 'in taxon' some Eubacteria"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/17921072"
  }, {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/20973947"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002161",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "tooth SubClassOf 'never in taxon' value 'Aves'"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x never in taxon T if and only if T is a class, and x does not instantiate the class expression \"in taxon some T\". Note that this is a shortcut relation, and should be used as a hasValue restriction in OWL."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/17921072"
  }, {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/20973947"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002162",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x is in taxon y if an only if y is an organism, and the relationship between x and y is one of: part of (reflexive), developmentally preceded by, derives from, secreted by, expressed."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0001-9227-417X"
  }, {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/17921072"
  }, {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/20973947"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002163",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A is spatially_disjoint_from B if and only if they have no parts in common"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@language" : "en",
    "@value" : "There are two ways to encode this as a shortcut relation. The other possibility to use an annotation assertion between two classes, and expand this to a disjointness axiom. "
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/22293552"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000232" : [ {
    "@value" : "Note that it would be possible to use the relation to label the relationship between a near infinite number of structures - between the rings of saturn and my left earlobe. The intent is that this is used for parsiomoniously for disambiguation purposes - for example, between siblings in a jointly exhaustive pairwise disjointness hierarchy"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000424" : [ {
    "@value" : "BFO_0000051 exactly 0 (BFO_0000050 some ?Y)"
  } ],
  "http://purl.obolibrary.org/obo/RO_0001900" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0001901"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#inSubset" : [ {
    "@id" : "http://purl.oboInOwllibrary.org/oboInOwl/ro/subsets#ro-eco"
  }, {
    "@id" : "http://purl.obolibrary.org/obo/ro/subsets#ro-eco"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "spatially disjoint from"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "https://github.com/obophenotype/uberon/wiki/Part-disjointness-Design-Pattern"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002323"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002170",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "a 'toe distal phalanx bone' that is connected to a 'toe medial phalanx bone' (an interphalangeal joint *connects* these two bones)."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "a is connected to b if and only if a and b are discrete structure, and there exists some connecting structure c, such that c connects a and b"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/22293552"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "connected to"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "https://github.com/obophenotype/uberon/wiki/Connectivity-Design-Pattern"
  }, {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "https://github.com/obophenotype/uberon/wiki/Modeling-articulations-Design-Pattern"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002323"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002171",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A is mutually_spatially_disjoint_with B if both A and B are classes, and there exists no p such that p is part_of some A and p is part_of some B."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@value" : "non-overlapping with"
  }, {
    "@value" : "shares no parts with"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/22293552"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002172",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "An assertion that holds between an ontology class and an organism taxon class, which is intepreted to yield some relationship between instances of the ontology class and the taxon."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002173",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "S ambiguous_for_taxon T if the class S does not have a clear referent in taxon T. An example would be the class 'manual digit 1', which encompasses a homology hypotheses that is accepted for some species (e.g. human and mouse), but does not have a clear referent in Aves - the referent is dependent on the hypothesis embraced, and also on the ontogenetic stage.  [PHENOSCPAE:asilomar_mtg]"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002174",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "S dubious_for_taxon T if it is probably the case that no instances of S can be found in any instance of T."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/22293552"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002175",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "S present_in_taxon T if some instance of T has some S. This does not means that all instances of T have an S - it may only be certain life stages or sexes that have S"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/22293552"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002176",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "The M8 connects Glasgow and Edinburgh"
  }, {
    "@value" : "a 'toe distal phalanx bone' that is connected to a 'toe medial phalanx bone' (an interphalangeal joint *connects* these two bones)."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "c connects a if and only if there exist some b such that a and b are similar parts of the same system, and c connects b, specifically, c connects a with b. When one structure connects two others it unites some aspect of the function or role they play within the system."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/22293552"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "connects"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "https://github.com/obophenotype/uberon/wiki/Connectivity-Design-Pattern"
  }, {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "https://github.com/obophenotype/uberon/wiki/Modeling-articulations-Design-Pattern"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002323"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002177",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "a is attached to part of b if a is attached to b, or a is attached to some p, where p is part of b."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002178",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Relation between an arterial structure and another structure, where the arterial structure acts as a conduit channeling fluid, substance or energy."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "Individual ontologies should provide their own constraints on this abstract relation. For example, in the realm of anatomy this should hold between an artery and an anatomical structure"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/20064205"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002179",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Relation between an collecting structure and another structure, where the collecting structure acts as a conduit channeling fluid, substance or energy away from the other structure."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "Individual ontologies should provide their own constraints on this abstract relation. For example, in the realm of anatomy this should hold between a vein and an anatomical structure"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@id" : "http://www.ncbi.nlm.nih.gov/pubmed/20064205"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002180",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "w 'has component' p if w 'has part' p and w is such that it can be directly disassembled into into n parts p, p2, p3, ..., pn, where these parts are of similar type."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "The definition of 'has component' is still under discussion. The challenge is in providing a definition that does not imply transitivity."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000232" : [ {
    "@language" : "en",
    "@value" : "For use in recording has_part with a cardinality constraint, because OWL does not permit cardinality constraints to be used in combination with transitive object properties. In situations where you would want to say something like 'has part exactly 5 digit, you would instead use has_component exactly 5 digit."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://purl.obolibrary.org/obo/RO_0001900" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0001901"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#inSubset" : [ {
    "@id" : "http://purl.oboInOwllibrary.org/oboInOwl/ro/subsets#ro-eco"
  }, {
    "@id" : "http://purl.obolibrary.org/obo/ro/subsets#ro-eco"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has component"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "http://ontologydesignpatterns.org/wiki/Submissions:Componency"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000051"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002200",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relationship that holds between a biological entity and a phenotype. Here a phenotype is construed broadly as any kind of quality of an organism part, a collection of these qualities, or a change in quality or qualities (e.g. abnormally increased temperature). The subject of this relationship can be an organism (where the organism has the phenotype, i.e. the qualities inhere in parts of this organism), a genomic entity such as a gene or genotype (if modifications of the gene or the genotype causes the phenotype), or a condition such as a disease (such that if the condition inheres in an organism, then the organism has the phenotype)."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002201",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "inverse of has phenotype"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002202",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x develops from y if and only if either (a) x directly develops from y or (b) there exists some z such that x directly develops from z and z develops from y"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0001-9114-8737"
  }, {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  }, {
    "@id" : "https://orcid.org/0000-0002-7073-9172"
  }, {
    "@id" : "https://orcid.org/0000-0003-1980-3228"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002203",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "inverse of develops from"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  }, {
    "@id" : "https://orcid.org/0000-0002-7073-9172"
  }, {
    "@id" : "https://orcid.org/0000-0003-1980-3228"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002204",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000125"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "definition \"x has gene product of y if and only if y is a gene (SO:0000704) that participates in some gene expression process (GO:0010467) where the output of that process is either y or something that is ribosomally translated from x\""
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "We would like to be able to express the rule: if t transcribed from g, and t is a noncoding RNA and has an evolved function, then t has gene product g."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002205",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "every HOTAIR lncRNA is the gene product of some HOXC gene"
  }, {
    "@value" : "every sonic hedgehog protein (PR:000014841) is the gene product of some sonic hedgehog gene"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
