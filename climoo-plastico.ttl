                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <http://purl.obolibrary.org/obo/ENVO_02000200> ;
                                                                              owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/CHEBI_24431>
                                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                                          owl:onProperty <http://purl.obolibrary.org/obo/RO_0000087> ;
                                                                                                                          owl:someValuesFrom <http://purl.obolibrary.org/obo/CHEBI_78298>
                                                                                                                        ]
                                                                                                                      ) ;
                                                                                                   rdf:type owl:Class
                                                                                                 ]
                                                                            ]
                                                                          ) ;
                                                       rdf:type owl:Class
                                                     ]
                                ] ;
                <http://purl.org/dc/terms/source> "Fu, L., Li, J., Wang, G., Luan, Y., & Dai, W. (2021). Adsorption behavior of organic pollutants on microplastics. Ecotoxicology and Environmental Safety, 217, 112207. https://doi.org/10.1016/j.ecoenv.2021.112207" ;
                rdfs:comment "Reference to specific types of sorption, such as absorption and adsorption, can be added as needed."@en ,
                             "We envision implementing this representation by including references to specific sources and sinks. Correspondences with plastic debris sources/sinks can be clarified as well."@en ,
                             """Implementations will consider extending this representation to model the relation with environmental pollution as well.
According to the current axiomatization and definition, this class may be a subclass of the “environmental pollution” class. However, this seems a little bit counterintuitive.""" ;
                rdfs:label "synthetic polymer-based material sorption process of pollutants"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A material transport process that has as output some portion of synthetic polymer-based material with an increased level of pollutants as part (compared to levels prior to participating in that process). Pollutants can both penetrate the material matrix (absorption) or remain confined on its surface (adsorption). This process generally concerns plastic materials composing plastic debris and litter."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .


