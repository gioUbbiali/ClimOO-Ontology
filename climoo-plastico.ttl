###  https://www.w3id.org/climoo#ClimOO_0000238
:ClimOO_0000238 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/COB_0000035> ;
                rdfs:comment "Extensions of the model will address 3R and 6R principles frameworks."@en ;
                rdfs:label "plastic pollution prevention process"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A planned process that avoids the release of plastic debris particles into a plastic debris sink, suppressing some plastic pollution process."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> .


###  https://www.w3id.org/climoo#ClimOO_0000241
:ClimOO_0000241 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000016> ;
                rdfs:comment "Reference to corresponding motion processes can be added as needed."@en ;
                rdfs:label "disposition to motion in the environment"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A disposition that realizes in a bearer when participating in a process of motion that occurs in an environmental system/environmental system environment."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000242
:ClimOO_0000242 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/CHEBI_23367> ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                  owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0000125>
                                ] ;
                rdfs:comment "Currently, there is no standard-length threshold in the literature."@en ,
                             "Usage of the term “polymer” with regard to macromolecules is mainly for emphasizing that it is the result of a polymerization process.  "@en ;
                rdfs:label "polymer molecule"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A polymer molecule is a long chain of macromolecules, usually of different species, named monomers, that is synthesized through polymerization processes (it is generally a result of a polymerization process; it may be the case that a polymer molecule derives from the breaking of a longer molecule."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .


###  https://www.w3id.org/climoo#ClimOO_0000243
:ClimOO_0000243 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000016> ;
                rdfs:comment "A disposition that realizes in a process of combustion."@en ,
                             "PATO does cover a class for combustibility but this class is mistakenly categorized as a subclass of BFO:quality rather than BFO:disposition.. We ahve created a new class adapting PATO class."@en ;
                rdfs:label "combustibility"@en ;
                rdfs:seeAlso "http://purl.obolibrary.org/obo/PATO_0015021" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "http://purl.obolibrary.org/obo/PATO_0015021" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000244
:ClimOO_0000244 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/bionik/portion_of_material>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                             owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0001546>
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf <http://www.semanticweb.org/bionik/portion_of_material> ;
