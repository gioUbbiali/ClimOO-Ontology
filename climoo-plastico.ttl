<https://www.w3id.org/climoo/climoo-plastico> rdf:type owl:Ontology ;
                                               owl:versionIRI :V1.0.0 ;
                                               owl:imports <https://raw.githubusercontent.com/ClimOO/ClimOO-Ontology/refs/heads/main/ClimOO%20material/src/ontology/plastico%20imports/bionik-imports.ttl> ,
                                                           <https://raw.githubusercontent.com/ClimOO/ClimOO-Ontology/refs/heads/main/ClimOO%20material/src/ontology/plastico%20imports/cco-imports.ttl> ,
                                                           <https://raw.githubusercontent.com/ClimOO/ClimOO-Ontology/refs/heads/main/ClimOO%20material/src/ontology/plastico%20imports/chebi-imports.ttl> ,
                                                           <https://raw.githubusercontent.com/ClimOO/ClimOO-Ontology/refs/heads/main/ClimOO%20material/src/ontology/plastico%20imports/envo-imports-merged.ttl> ,
                                                           <https://raw.githubusercontent.com/ClimOO/ClimOO-Ontology/refs/heads/main/ClimOO%20material/src/ontology/plastico%20imports/iao-imports.ttl> ,
                                                           <https://raw.githubusercontent.com/ClimOO/ClimOO-Ontology/refs/heads/main/ClimOO%20material/src/ontology/plastico%20imports/obi-cob-ro-go-imports.ttl> ,
                                                           <https://raw.githubusercontent.com/ClimOO/ClimOO-Ontology/refs/heads/main/ClimOO%20material/src/ontology/plastico%20imports/pato-imports-merged.ttl> ,
                                                           <https://raw.githubusercontent.com/ClimOO/ClimOO-Ontology/refs/heads/main/ClimOO%20material/src/ontology/plastico%20imports/ro-imports-merged.ttl> ,
                                                           <https://raw.githubusercontent.com/ClimOO/ClimOO-Ontology/refs/heads/main/ClimOO%20material/src/ontology/plastico%20imports/sdgio-imports.ttl> ,
                                                           <https://www.w3id.org/sco/sco-b#v1.1.0/sco-b> ;
                                               <http://purl.org/dc/terms/contributor> "Giorgio A. Ubbiali" ,
                                                                                      "Ludger Jansen" ;
                                               <http://purl.org/dc/terms/creator> "Giorgio A. Ubbiali" ;
                                               <http://purl.org/dc/terms/description> "ClimOO Ontology is a reference ontology, modeling plastics, (micro-)plastic pollution, climate change, and their interrelation, with a primary focus on agricultural systems. The ClimOO Ontology is structured in a suite of nested ontological modules. The PlasticO module centers on representing polymer molecules, plastic materials, pieces of plastic, and plastic objects, along with corresponding life cycles and pollution processes. Emphasis is also dedicated to relevant assessment devices and related data, especially with regard to sustainability."@en ;
                                               <http://purl.org/dc/terms/license> "https://creativecommons.org/licenses/by/4.0/" ;
                                               <http://purl.org/dc/terms/title> "ClimOO Ontology - PlasticO module"@en ;
                                               owl:versionInfo "2026-02-25"@en ,
                                                               "V1.0.0."@en ;
                                               <http://www.w3.org/2004/02/skos/core#note> """Repository: https://github.com/ClimOO/ClimOO-Ontology
Documentation webpage: https://www.w3id.org/climoo/docs"""@en ,
                                                                                          "The most recent version of this file is available on GitHub at the following link: https://www.w3id.org/climoo/climoo-plastico."@en .

