  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "The relationship that links an entity with the process that results in the formation and shaping of that entity over time from an immature to a mature state."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
