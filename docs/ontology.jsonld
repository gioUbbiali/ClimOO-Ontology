  }, {
    "@value" : "http://purl.obolibrary.org/obo/OBI_0302890; http://purl.obolibrary.org/obo/NCIT_C34072; http://purl.obolibrary.org/obo/REX_0000251; http://purl.obolibrary.org/obo/MOP_0000629."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0010033"
  }, {
    "@id" : "_:genid697"
  }, {
    "@id" : "_:genid702"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
