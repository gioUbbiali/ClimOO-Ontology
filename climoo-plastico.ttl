                                  rdf:type owl:Class
                                ] ;
                rdfs:label "biodegradable plastic object"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A plastic object that is primarily made of biodegradable plastic."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000109
:ClimOO_0000109 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000242 ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0000091> ;
                                  owl:someValuesFrom :ClimOO_0000104
                                ] ;
                rdfs:comment "References to degradable polymers and degradability can be added as needed."@en ;
