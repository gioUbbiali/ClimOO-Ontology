  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A Color that consists of dark orange and red, and of very low intensity."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Color",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
