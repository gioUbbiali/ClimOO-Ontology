  "http://purl.obolibrary.org/obo/IAO_0000111" : [ {
    "@language" : "en",
    "@value" : "subset ontology module"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "An ontology module that is extracted from a main ontology module and includes only a subset of entities or axioms."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@language" : "en",
    "@value" : "ontology slim"
  }, {
    "@language" : "en",
    "@value" : "subset ontology"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_8000007",
  "http://purl.obolibrary.org/obo/IAO_0000111" : [ {
    "@language" : "en",
    "@value" : "curation subset ontology module"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A subset ontology that is intended as a whitelist for curators using the ontology. Such a subset will exclude classes that curators should not use for curation."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_8000008",
  "http://purl.obolibrary.org/obo/IAO_0000111" : [ {
    "@language" : "en",
    "@value" : "analysis ontology module"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "An ontology module that is intended for usage in analysis or discovery applications."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_8000009",
  "http://purl.obolibrary.org/obo/IAO_0000111" : [ {
    "@language" : "en",
    "@value" : "single layer ontology module"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A subset ontology that is largely comprised of a single layer or strata in an ontology class hierarchy. The purpose is typically for rolling up for visualization. The classes in the layer need not be disjoint."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@language" : "en",
    "@value" : "ribbon subset"
  } ]
}, {
