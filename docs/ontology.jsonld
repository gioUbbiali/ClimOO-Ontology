  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1442"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A material entity that belongs to a system environment."
  }, {
    "@language" : "it",
    "@value" : "Un'entità materiale che appartiene all’ambiente di un sistema."
  }, {
    "@language" : "fr",
    "@value" : "Une entité matérielle qui appartient à l’environnement d’un système."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000015",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@language" : "en",
    "@value" : "Ubbiali, G. A., Borghini, A., & Lange, M. C. (2024). Ontologies for Sustainability: Theoretical Challenges. https://doi.org/10.31219/osf.io/z8uqr"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#hasNarrowSynonym" : [ {
    "@value" : "socio-ecological system, social-ecological system"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "complex system"
  }, {
    "@language" : "it",
    "@value" : "sistema complesso"
  }, {
    "@language" : "fr",
    "@value" : "système complexe"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "IOBC: http://purl.jp/bio/4/id/200906033993517889\nIOBC: http://purl.jp/bio/4/id/201406059151625127\nEnvThes: http://vocabs.lter-europe.net/EnvThes/21908\nI2SV: https://i2insights.org/index/integration-and-implementation-sciences-vocabulary#complex-systems"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002577"
  }, {
    "@id" : "_:genid1458"
  }, {
    "@id" : "_:genid1462"
  }, {
    "@id" : "_:genid1466"
  }, {
    "@id" : "_:genid1470"
  }, {
    "@id" : "_:genid1476"
  }, {
    "@id" : "_:genid1480"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1451"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A system whose system components interact dynamically and nonlinearly, causing the emergence of a collective nontrivial and self-organized behavior. No internal/external centralized controls are required."
  }, {
    "@language" : "it",
    "@value" : "Un sistema le cui componenti interagiscono dinamicamente e non linearmente, causando l’emergere di un comportamento collettivo, non banale e auto-organizzato. Non è richiesto nessun controllo centralizzato, né interno né esterno."
  }, {
    "@language" : "fr",
    "@value" : "Un système dont les composantes interagissent dynamiquement et non linéairement, causant l’émergence d’un comportement collectif, non trivial et auto-organisé. Aucun contrôle interne ou externe centralisé n’est requis."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000016",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "SCO currently accounts for perspectives of complex system components and complex system environment components because the focus of this ontology is on complex systems. Future versions of this ontology may explore extending reference more broadly to systems."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "perspective"
  }, {
    "@language" : "fr",
    "@value" : "perspective"
  }, {
    "@language" : "it",
    "@value" : "prospettiva"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000039"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000016"
  }, {
    "@id" : "_:genid1484"
  }, {
    "@id" : "_:genid1488"
  }, {
    "@id" : "_:genid1495"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A disposition whose realization leads the complex system component or the complex system environment component to (re)position itself within and regarding the complex system or complex system environment it belongs to (or a part of it) and possibly act accordingly."
  }, {
    "@language" : "it",
    "@value" : "Una disposizione la cui realizzazione porta la componente del sistema complesso o la componente dell’ambiente del sistema complesso a (ri)posizionarsi nel e rispetto al sistema complesso o all’ ambiente del sistema complesso a cui appartiene (o parte di esso) ed eventualmente ad agire di conseguenza."
  }, {
    "@language" : "fr",
    "@value" : "Une disposition dont la réalisation conduit la composante de système complexe ou la composante de l’environnement du système complexe à se (re)positionner dans et par rapport au système complexe ou à l’environnement du système complexe auquel elle appartient (ou d’une partie de celui-ci) et, éventuellement, à agir en conséquence."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000017",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "To distinguish and account for indicators according to the perspectives of different complex systems (and environment) components, we suggest proceeding following the indications provided under the “according to the perspective” annotation property. In this case, regarding the subclasses to create, we recommend establishing axioms restricting to this class."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "indicateur (rôle)"
  }, {
    "@language" : "en",
    "@value" : "indicator-role"
  }, {
    "@language" : "it",
    "@value" : "ruolo di indicatore"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@language" : "en",
    "@value" : "See the comments under the corresponding \"indicator\" class."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000023"
  }, {
    "@id" : "_:genid1499"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A role whose realization leads the complex system component to be recognized as a carrier of an indicator value, by some complex system component or complex system environment component according to its/their perspective."
  }, {
    "@language" : "fr",
    "@value" : "Un rôle dont la réalisation conduit la composante de système complexe à être reconnu comme porteuse d’une valeur de l’indicateur, par quelque composante de système complexe ou de son l’environnement, selon sa/leur propre perspective."
  }, {
    "@language" : "it",
    "@value" : "un ruolo la cui realizzazione porta la componente del sistema complesso ad essere riconosciuto come portatore di un valore dell’indicatore, da parte di qualche componente del sistema complesso o del suo ambiente, secondo la propria prospettiva."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000018",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "ruolo di parte interessata (stakeholder)"
  }, {
    "@language" : "fr",
    "@value" : "rôle de partie prenante (stakeholder)"
  }, {
    "@language" : "en",
    "@value" : "stakeholder-role"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000023"
  }, {
    "@id" : "_:genid1503"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A role whose realization leads the complex system component to be recognized as a bearer, in the belonging complex system, of at least one role (different from the role of stakeholder) and/or disposition (primarily a disposition to benefit/be damaged as being part of that complex system)."
  }, {
    "@language" : "it",
    "@value" : "Un ruolo la cui realizzazione porta la componente del sistema complesso ad essere riconosciuta come detentrice, nel sistema complesso a cui appartiene, di almeno un ruolo (diverso dal ruolo di stakeholder) e/o disposizione (in primo luogo una predisposizione a beneficiare/essere danneggiata in quanto parte di tale sistema complesso)."
  }, {
    "@language" : "fr",
    "@value" : "Un rôle dont la réalisation conduit la composante du système complexe à être reconnue, dans le système complexe auquel elle appartient, comme porteuse d’au moins un rôle (différent du rôle de partie prenante) et/ou d’une disposition (principalement une disposition à bénéficier ou à être endommagé parce qu’elle fait partie de ce système complexe)."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000019",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym" : [ {
    "@value" : "value"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Due to the SCO focus on complex systems, the worth-role class have been designed referring specifically to complex systems. Nevertheless, future implementations may broaden the space of application to also systems. Implementations may equally deepen this representation, detailing and elucidating the distinction and connection between worth and value(s)."
  }, {
    "@value" : "To distinguish and account for what is considered worthy of value for different complex systems (and environment) components according to proper perspectives,we suggest proceeding following the indications provided under the “according to the perspective” annotation property. In this case, regarding the subclasses to create, we recommend establishing axioms restricting to this class."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Valeur (sens donner de la valeur)"
  }, {
    "@language" : "it",
    "@value" : "valore (senso dare valore)"
  }, {
    "@language" : "en",
    "@value" : "worth-role"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "(related)\nhttp://humanbehaviourchange.org/ontology/BCIO_006063"
  }, {
    "@value" : "https://bio.scai.fraunhofer.de/ontology/epilepsy#worthiness"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000023"
  }, {
    "@id" : "_:genid1507"
  }, {
    "@id" : "_:genid1511"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A role whose realization leads the complex system or the complex system environment (or some part(s) of them) to be recognized to bearer relevance by some complex system component or complex system environment component according to its/their perspective."
  }, {
    "@language" : "it",
    "@value" : "Un ruolo la cui realizzazione porta il sistema complesso o l'ambiente del sistema complesso (o una o più delle parti di essi) ad essere riconosciuto come rilevante da parte di qualche componente del sistema complesso o del suo ambiente, secondo la propria prospettiva."
  }, {
    "@language" : "fr",
    "@value" : "Un rôle dont la réalisation conduit le système complexe ou l’environnement de système complexe (ou une ou plus parties de ceux-ci) à être reconnu comme significatif par quelque composante de système complexe ou de son l’environnement, selon sa/leur propre perspective."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000020",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym" : [ {
    "@value" : "relation between complex system components and complex system environment components, interconnection between complex system components and complex system environment components"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Interaction entre les composantes de système complexe et  les composantes de environnement de système complexe"
  }, {
    "@language" : "en",
    "@value" : "interaction between complex system components and complex system environment components"
  }, {
    "@language" : "it",
    "@value" : "interazione tra le componenti del sistema complesso e le componenti dell’ambiente del sistema complesso"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000009"
  }, {
    "@id" : "_:genid1515"
  }, {
    "@id" : "_:genid1519"
  }, {
    "@id" : "_:genid1523"
  }, {
    "@id" : "_:genid1530"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000021"
  }, {
    "@id" : "https://www.w3id.org/sco#SCO_0000022"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An interaction that occurs between at least one complex system component and one complex system environment component where the latter belongs to the complex system environment of the complex system to which the complex system component belongs."
  }, {
    "@language" : "fr",
    "@value" : "Une interaction qui se produit entre au moins une composante d’un système complexe et au moins une composante de l’environnement du système complexe auquel la composante de système complexe appartient."
  }, {
    "@language" : "it",
    "@value" : "Un’interazione che avviene tra almeno una componente di un sistema complesso e almeno una componente dell’ambiente del sistema complesso a cui la componente del sistema complesso appartiene."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000021",
