    "@value" : "A relation between a cell and molecule or complex such that every instance of the cell has a high number of instances of that molecule expressed on the cell surface."
  } ]
}, {
  "@id" : "_:genid1732",
  "@type" : [ "http://www.w3.org/2002/07/owl#Axiom" ],
