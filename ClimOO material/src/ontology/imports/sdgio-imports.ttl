<http://ClimOO/climoo/imports/sdgio-imports> a owl:Ontology;
  owl:versionIRI <http://ClimOO/climoo/imports/sdgio-imports#2025-06-26>;
  rdfs:comment """This file contains ClimOO Ontology imports from the Sustinable Development Goals Interface Ontology (SDGIO). It also contains some imports reused by SDGIO from the Chemical Entities of Biological Interest Ontology (ChEBI), and the Environment Ontology (EnvO). Imports were manually collected and revised.

Ontology source: https://raw.githubusercontent.com/SDG-InterfaceOntology/sdgio/refs/heads/master/sdgio.owl
Other ontology sources: https://ontobee.org/ontology/CHEBI
http://purl.obolibrary.org/obo/envo.owl"""@en;
  rdfs:seeAlso """Additional imports from ChEBI and EnvO can be found here.
https://github.com/ClimOO/ClimOO-Ontology/tree/main/ClimOO%20material/src/ontology/imports/envo-imports.ttl
https://github.com/ClimOO/ClimOO-Ontology/tree/main/ClimOO%20material/src/ontology/imports/chebi-imports.ttl"""@en,
    """Additional imports from SDGIO can be found here.
https://github.com/ClimOO/ClimOO-Ontology/tree/main/ClimOO%20material/src/ontology/imports/sumso-imports.ttl"""@en,
    "https://github.com/SDG-InterfaceOntology/sdgio";
  owl:versionInfo "2025-06-26" .

