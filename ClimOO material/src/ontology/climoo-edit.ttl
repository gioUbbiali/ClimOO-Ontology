###  https://www.w3id.org/climoo#ClimOO_0000001
:ClimOO_0000001 rdf:type owl:Class ;
                rdfs:subClassOf <https://www.w3id.org/sco#SCO_0000034> ;
                rdfs:label "environmental system agent"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An environmental system component that is an agent in an interaction among environmental system components or in an interaction between environmental system components and environmental system environment components."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000002
:ClimOO_0000002 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000001 ;
                rdfs:label "ecosystem agent"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An ecosystem component that is an agent in an interaction among ecosystem components or in an interaction between ecosystem components and ecosystem system environment components."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


