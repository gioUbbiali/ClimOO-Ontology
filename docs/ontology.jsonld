  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "An interaction relationship in which at least one of the partners is an organism and the other is either an organism or an abiotic entity with which the organism interacts."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
