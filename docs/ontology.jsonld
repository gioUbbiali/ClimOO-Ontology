}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000254",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "ClimOO Ontology comment:\nReference to weight can be added as needed."
  }, {
    "@language" : "en",
    "@value" : "Implementations require to address composition threshold. We envision discussion with subject matter experts."
  }, {
    "@language" : "en",
    "@value" : "We intend this class, and subclasses, as denoting generic identifiable causally unitary bona fide portions of (made of) plastic materials. This could be a fragment of natural or synthetic plastic material, or a plastic object, such as a plastic bottle."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "piece of polymer-based material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000030"
  }, {
