###  http://purl.obolibrary.org/obo/RO_0020337
obo:RO_0020337 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf obo:RO_0002180 ;
               obo:IAO_0000112 "A polyubiquitin has_constituent_monomer some ubiquitin." ,
                               "An amino acid chain has_constituent_monomer at least two amino acid residues." ;
               obo:IAO_0000115 "A relation that holds between a polymer and its constituent monomers. P has_constituent_monomer 'm' if and only if P has_component multiple instances of 'm' and each instance of 'm' is covalently attached to another instance of 'm'."@en ;
               obo:IAO_0000412 obo:ro.owl ;
               oboInOwl:created_by <https://orcid.org/0000-0001-5809-9523> ;
               rdfs:comment "Usage note: The constituent monomers need not be covalently attached in an end-to-end manner; that is, polymers with internal connections (e.g., polyubiquitin) can use this relation, as can circular polymers (e.g., plasmids) and multi-branched polymers (e.g., glycans). This relation, as non-transitive, allows the number of instances of 'm' to be indicated." ;
               rdfs:label "has constituent monomer" .


