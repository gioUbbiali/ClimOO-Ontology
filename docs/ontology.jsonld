  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "b has proper occurrent part c =Def b has occurrent part c & b and c are not identical"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "As for has occurrent part."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "has proper occurrent part"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/BFO_0000121",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#TransitiveProperty" ],
  "http://purl.org/dc/elements/1.1/identifier" : [ {
    "@value" : "211-BFO"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
