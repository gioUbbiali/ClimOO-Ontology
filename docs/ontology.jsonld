  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "References to manufacturing processes of plastic objects made of specific type of plastics, such as recycled, virgin, biobased, and biodegradable can be added as needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic object manufacturing process"
  } ],
