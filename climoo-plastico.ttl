                                    ] ;
                rdfs:subClassOf :ClimOO_0000153 ;
                <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "plastic item"@en ;
                rdfs:comment "Further details concerning stakeholders and objective and action specifications can be added to the axiomatixation of this class, as needed."@en ,
                             "References to objects made of other synthetic polymer-based materials can be included if needed."@en ;
                rdfs:label "plastic object"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A piece of synthetic plastic that bears some function(s)."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000172
:ClimOO_0000172 rdf:type owl:Class ;
