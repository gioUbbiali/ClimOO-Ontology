  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An interaction that occurs among at least two system components of a complex system."
  }, {
    "@language" : "fr",
    "@value" : "Une interaction qui se produit entre au moins deux composantes de système d’un système complexe."
  }, {
    "@language" : "en",
