###  http://purl.obolibrary.org/obo/BFO_0000019
<http://purl.obolibrary.org/obo/BFO_0000019> owl:equivalentClass <http://purl.obolibrary.org/obo/PATO_0000001> .


###  http://purl.obolibrary.org/obo/BFO_0000023
<http://purl.obolibrary.org/obo/BFO_0000023> owl:equivalentClass <http://purl.obolibrary.org/obo/CHEBI_50906> .


###  http://purl.obolibrary.org/obo/CHEBI_24431
<http://purl.obolibrary.org/obo/CHEBI_24431> rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ;
                                             rdfs:comment """ClimOO developer comment:
Currently, we included only main classes from ChEBI relevant for ClimOO purposes."""@en .


###  http://purl.obolibrary.org/obo/CHEBI_50906
<http://purl.obolibrary.org/obo/CHEBI_50906> rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000017> .


###  http://purl.obolibrary.org/obo/ENVO_00000077
<http://purl.obolibrary.org/obo/ENVO_00000077> rdfs:subClassOf _:genid1 .

_:genid1 owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_01001828>
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000056> ;
                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/AGRO_00002071>
                               ]
                             ) ;
          rdf:type owl:Class .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://purl.obolibrary.org/obo/ENVO_00000077> ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1 ;
   rdfs:comment """ClimOO developer comment:
Adapted from equivalent class axiom from EnvO. Reference to agricultural land conversion process can be re-added, as needed."""@en
 ] .


###  http://purl.obolibrary.org/obo/ENVO_01000665
<http://purl.obolibrary.org/obo/ENVO_01000665> rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000023> .


###  http://purl.obolibrary.org/obo/ENVO_01001110
<http://purl.obolibrary.org/obo/ENVO_01001110> owl:equivalentClass _:genid6 .

_:genid6 owl:intersectionOf ( <http://purl.obolibrary.org/obo/ENVO_01000254>
                               [ rdf:type owl:Class ;
                                 owl:unionOf ( [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000051> ;
                                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/NCBITaxon_131567>
                                               ]
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000051> ;
                                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/PCO_0000000>
                                               ]
                                             )
                               ]
                             ) ;
          rdf:type owl:Class .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://purl.obolibrary.org/obo/ENVO_01001110> ;
   owl:annotatedProperty owl:equivalentClass ;
   owl:annotatedTarget _:genid6 ;
   rdfs:comment """ClimOO developer comment:
Re-added from EnvO."""@en
 ] .


###  http://purl.obolibrary.org/obo/GO_0008150
<http://purl.obolibrary.org/obo/GO_0008150> rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                            rdfs:comment """ClimOO developer comment:
We include this class as a subclass of BFO:process. Given its definition, it may be considered as a subclass of OBI:planned process. We envision discussions with subject matter experts."""@en .


