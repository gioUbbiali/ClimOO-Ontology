}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0020337",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "A polyubiquitin has_constituent_monomer some ubiquitin."
  }, {
    "@value" : "An amino acid chain has_constituent_monomer at least two amino acid residues."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A relation that holds between a polymer and its constituent monomers. P has_constituent_monomer 'm' if and only if P has_component multiple instances of 'm' and each instance of 'm' is covalently attached to another instance of 'm'."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#created_by" : [ {
    "@id" : "https://orcid.org/0000-0001-5809-9523"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Usage note: The constituent monomers need not be covalently attached in an end-to-end manner; that is, polymers with internal connections (e.g., polyubiquitin) can use this relation, as can circular polymers (e.g., plasmids) and multi-branched polymers (e.g., glycans). This relation, as non-transitive, allows the number of instances of 'm' to be indicated."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "has constituent monomer"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002180"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0040035",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "This relation groups  relations between diseases and any other kind of entity."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0040036",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "p has anatomical participant c iff p has participant c, and c is an anatomical entity"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0040042",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "part-of is homeomorphic for independent continuants."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "R is homemorphic for C iff (1) there exists some x,y such that x R y, and x and y instantiate C and (2) for all x, if x is an instance of C, and there exists some y some such that x R y, then it follows that y is an instance of C."
  } ],
  "http://www.geneontology.org/formats/oboInOwl#created_by" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#creation_date" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#dateTime",
    "@value" : "2018-10-21T19:46:34Z"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "R homeomorphic-for C expands to: C SubClassOf R only C. Additionally, for any class D that is disjoint with C, we can also expand to C DisjointWith R some D, D DisjointWith R some C."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "is homeomorphic for"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
