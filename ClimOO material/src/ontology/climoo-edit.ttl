   owl:annotatedSource <https://w3id.org/sumso#SuMSO_0000160> ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget <http://purl.obolibrary.org/obo/ENVO_01000665> ;
   rdfs:comment """ClimOO developer comment:
