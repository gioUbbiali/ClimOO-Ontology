               rdfs:subClassOf <http://www.ontologyrepository.com/CommonCoreOntologies/HydrographicFeature> ,
                               [ owl:intersectionOf ( :Hydrologic_Material_Entity
                                                      [ rdf:type owl:Restriction ;
