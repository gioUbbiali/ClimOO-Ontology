    "@id" : "http://purl.obolibrary.org/obo/RO_0002410"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002507",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "A coral reef environment is determined by a particular coral reef"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "s determined by f if and only if s is a type of system, and f is a material entity that is part of s, such that f exerts a strong causal influence on the functioning of s, and the removal of f would cause the collapse of s."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "The label for this relation is probably too general for its restricted use, where the domain is a system. It may be relabeled in future"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
