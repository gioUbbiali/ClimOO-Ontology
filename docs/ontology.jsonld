}, {
  "@id" : "http://purl.obolibrary.org/obo/PATO_0103000",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A quality of an entity that can be represented numerically, including anything that can be counted, measured, or given a numerical value."
  } ],
  "http://www.geneontology.org/formats/oboInOwl#created_by" : [ {
