  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An Optical Property that inheres in a bearer in virtue of that bearer's Color Hue, Color Saturation and Color Brightness."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/DescriptiveInformationContentEntity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Descriptive Information Content Entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/InformationContentEntity"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/DirectiveInformationContentEntity"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Descriptive ICE"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An Information Content Entity that consists of a set of propositions that describe some Entity."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/DirectiveInformationContentEntity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Directive Information Content Entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/InformationContentEntity"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid326"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Directive ICE"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An Information Content Entity that consists of a set of propositions or images (as in the case of a blueprint) that prescribe some Entity."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/ElectromagneticRadiationProperty",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/QualityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Electromagnetic Radiation Property"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000016"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A Disposition that inheres in an bearer in virtue of how that bearer interacts with electromagnetic radiation."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Green",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/QualityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Green"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Color"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A Color that is between Yellow and Cyan with a wavelength in the visible spectrum, typically between 520 to 560 nanometers."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Grey",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/QualityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Grey"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Color"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A Color between white and black colors."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/InformationContentEntity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/alternative_label" : [ {
    "@language" : "en",
    "@value" : "ICE"
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/definition" : [ {
    "@language" : "en",
    "@value" : "A Generically Dependent Continuant that generically depends on some Information Bearing Entity and stands in relation of aboutness to some Entity."
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/definition_source" : [ {
    "@value" : "http://purl.obolibrary.org/obo/IAO_0000030"
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/elucidation" : [ {
    "@language" : "en",
    "@value" : "Information Content Entity is here intended to be a class of Entities whose instances are the informational content of Information Bearing Entities. For example, three instances of information bearers -- such as a bar chart, color-coded map, and a written report -- each of which lists the GDP of Countries for the year 2010 are each different carriers of the same information content. It is this content that is generically dependent upon its carrier. This treatment of Informational Content Entity (cf. the Information Artifact Ontology) leads to a principle of subtyping based upon the relationship that ICE's have with the Entity they are about rather than characteristics such as format, language, measurement scale, or media. The latter are treated here as being Qualities of bearers."
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "SCO developer comment:\n\nCurrently, SCO-B reuses the representation of information that belongs to IAO/CCO. Nevertheless, debates are ongoing on whether information may be better represented through a type-token relationship within a multi-level type hierarchy. See the paper cited at the end of the comment.\n\nWe envision discussions with subject matter experts from both BFO and UFO communities regarding this point.\n\nWeigand, H. (2025). Generic Ontological Dependence⋆. https://www.utwente.nl/en/eemcs/vmbo2025/papers/vmbo-2025-paper-4-2.pdf"
  }, {
    "@language" : "en",
    "@value" : "SCO developer comment:\nSCO-B does not currently cover a class for information bearing entity. We directly refer ICE subclasses to corresponding information bearing entities."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Information Content Entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000031"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid330"
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/MeasurementInformationContentEntity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Measurement Information Content Entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/DescriptiveInformationContentEntity"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/RepresentationalInformationContentEntity"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid334"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Measurement ICE"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A Descriptive Information Content Entity that describes the extent, dimensions, quantity, or quality of an Entity relative to some standard."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/MeasurementUnit",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/definition_source" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "https://en.wikipedia.org/w/index.php?title=Unit_of_measurement&oldid=1061038125"
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Measurement Unit"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/DescriptiveInformationContentEntity"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A Descriptive Information Content Entity that describes a definite magnitude of a physical quantity, defined and adopted by convention and/or by law, that is used as a standard for measurement of the same physical quantity."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/OpticalProperty",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/QualityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Optical Property"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/ElectromagneticRadiationProperty"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An Electromagnetic Radiation Property that is realized when its bearer interacts with electromagnetic waves within the visible light spectrum."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Orange",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/QualityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Orange"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Color"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A Color that is between Red and Yellow with a wavelength in the visible spectrum typically between 590 to 635 nanometers."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Red",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/QualityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Red"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Color"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A Color that is above Orange with a wavelength in the visible spectrum typically between 635 to 700 nanometers."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/RepresentationalInformationContentEntity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/definition" : [ {
    "@language" : "en",
    "@value" : "An Information Content Entity that represents some Entity."
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/example_of_usage" : [ {
    "@value" : "the content of a court transcript represents a courtroom proceeding"
  }, {
    "@value" : "the content of a photograph of the Statue of Liberty represents the Statue of Liberty"
  }, {
    "@value" : "the content of a video of a sporting event represents that sporting event"
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Representational Information Content Entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/InformationContentEntity"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000004"
  }, {
    "@id" : "https://www.w3id.org/sco#SCO_0000005"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid338"
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/White",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/QualityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "White"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Color"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A Color of maximum brightness, the color of objects that reflect nearly all wavelengths of the visible light spectrum, thus considered achromatic."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Yellow",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/QualityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Yellow"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Color"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A Color that is between Orange and Green with a wavelength in the visible spectrum typically between 560 to 590 nanometers."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/alternative_label",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/definition",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/definition_source",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/described_by",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "described by"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/DescriptiveInformationContentEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_subject_of"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/describes"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "x described_by y iff y is an instance of Information Content Entity, and x is an instance of Entity, such that y is about the characteristics by which y can be recognized or visualized."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/describes",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "It is possible that this relation should be a functional property, that is for all x, y, z if x describes y and x describes z then y = z. For example, if a financial report x describes the quarterly results of a company y and that same financial report describes the quarterly results of a company z, then it should be inferred that companies y and z are the same. We refrained from classifying the relation as a functional property on the concern that descriptions are multifaceted and so consequently it may be that the same report would contain descriptions of multiple entities."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/DescriptiveInformationContentEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "describes"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_about"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "x describes y iff x is an instance of Information Content Entity, and y is an instance of Entity, such that x is about the characteristics by which y can be recognized or visualized."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "the content of a newspaper article describes some current event"
  }, {
    "@value" : "the content of a visitor's log describes some facility visit"
  }, {
    "@value" : "the content of an accident report describes some accident"
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/elucidation",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/example_of_usage",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_a_measurement_of",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This object property, as well as all of its children are typified as functional properties. This means that for instances x, y, and z if x is a measurement of y and x is a measurement of z, then y = z."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/MeasurementInformationContentEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "is a measurement of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/describes"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_measured_by"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "x is_a_measurement_of y iff x is an instance of Information Content Entity and y is an instance of Entity, such that x describes some attribute of y relative to some scale or classification scheme."
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "Given a stronger temporal interpretation, this property may be functional. For more info please refer to https://github.com/BFO-ontology/BFO-2020/tree/master/src/owl/temporal%20extensions."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_about",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/definition" : [ {
    "@language" : "en",
    "@value" : "A primitive relationship between an Information Content Entity and some Entity."
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/definition_source" : [ {
    "@value" : "http://purl.obolibrary.org/obo/IAO_0000136"
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/InformationContentEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "is about"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000001"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_subject_of"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A primitive relationship between an Information Content Entity and some Entity."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_measured_by",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "is measured by"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/MeasurementInformationContentEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/described_by"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "y is_measured_by x iff x is an instance of Information Content Entity and y is an instance of Entity, such that x describes some attribute of y relative to some scale or classification scheme."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_subject_of",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/definition" : [ {
    "@language" : "en",
    "@value" : "A primitive relationship between an instance of an Entity and an instance of an Information Content Entity."
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "is subject of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/InformationContentEntity"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A primitive relationship between an instance of an Entity and an instance of an Information Content Entity."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/prescribed_by",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "prescribed by"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/DirectiveInformationContentEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_subject_of"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/prescribes"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "x prescribed_by y iff y is an instance of Information Content Entity and x is an instance of Entity, such that y serves as a rule or guide for x if x is an Occurrent, or y serves as a model for x if x is a Continuant."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/prescribes",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/DirectiveInformationContentEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "prescribes"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_about"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "x prescribes y iff x is an instance of Information Content Entity and y is an instance of Entity, such that x serves as a rule or guide for y if y an Occurrent, or x serves as a model for y if y is a Continuant."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "A blueprint prescribes some artifact or facility by being a model for it."
  }, {
    "@value" : "A professional code of conduct prescribes some realizations of a profession (role) by giving rules for how the bearer should act in those realizations."
  }, {
    "@value" : "An operations plan prescribes an operation by enumerating the tasks that need to be performed in order to achieve the objectives of the operation."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/represented_by",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/definition" : [ {
    "@language" : "en",
    "@value" : "y represented_by x iff x is an instance of Information Content Entity, and y is an instance of Entity, and z is carrier of x, such that x is about y in virtue of there existing an isomorphism between characteristics of z and y."
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "See notes for inverse property."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "represented by"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/RepresentationalInformationContentEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_subject_of"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/represents"
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/represents",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/definition" : [ {
    "@language" : "en",
    "@value" : "x represents y iff x is an instance of Information Content Entity, y is an instance of Entity, and z is carrier of x, such that x is about y in virtue of there existing an isomorphism between characteristics of z and y."
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/elucidation" : [ {
    "@language" : "en",
    "@value" : "The relationship that is being defined here is that between the content of a photographic image and its object, between the content of a video and its objects and events, between the content of an audio recording and the sounds or events generating those sounds, or between the content of a written transcript and the verbal event that it transcribes."
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Isomorphism between the carrier of x and the represented entity can be via a direct similarity relation, e.g., grooves in a vinyl record corresponding to sound waves, or linguistic convention, e.g., a court stenographer's transcription of spoken words, as well as others, such as encoding processes for images."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/RepresentationalInformationContentEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "represents"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/is_about"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "Given a stronger temporal interpretation, this property may be functional. For more info please refer to https://github.com/BFO-ontology/BFO-2020/tree/master/src/owl/temporal%20extensions."
  } ]
}, {
  "@id" : "http://www.semanticweb.org/bionik/portion_of_material",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The class is introduced for householding purposes, such that all \"portion of\" classes can be subsumed under it."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000040"
  }, {
    "@id" : "https://w3id.org/pmd/co/PMD_0000001"
  }, {
    "@id" : "_:genid342"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "A portion of material is a material entity such that its identity depends only on the atoms or molecules present (whatever is the larger unit present), irrespective of size, shape, structure or kind membership of the whole portion."
  } ]
}, {
  "@id" : "http://www.w3.org/1999/02/22-rdf-syntax-ns#type",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2000/01/rdf-schema#comment",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2000/01/rdf-schema#label",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2000/01/rdf-schema#seeAlso",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#altLabel",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#closeMatch",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#comment",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#definition",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#example",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#note",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#prefLabel",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2004/02/skos/core#scopeNote",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/MaturityLevel",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "maturity level"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "classifier used to specify the state of a resource in its development process"
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/MaturityLevel"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "provisional"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "construct or ontology development state in which content is subject to change and may change considerably"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/explanatoryNote" : [ {
    "@language" : "en-us",
    "@value" : "IOF users should be aware that the resource is not dependable, but can be used for reference and for further work."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/MaturityLevel"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "released"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "construct or ontology development state in which the resource is stable, usable, and has been made available to external users"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/explanatoryNote" : [ {
    "@language" : "en-us",
    "@value" : "Release notes will be provided for any changes concerning released content, and any revisions will be backward compatible with the prior version to the degree possible."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "adapted from"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.org/dc/terms/source"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "source for the resource that was modified to create the subject resource"
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/directSource",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "direct source"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.org/dc/terms/source"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "definitive source of the subject resource"
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/excerptedFrom",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "excerpted from"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.org/dc/terms/source"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "source of a resource that was imported unmodified from an external ontology"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote" : [ {
    "@language" : "en-us",
    "@value" : "This annotation is to be used when an element from a non-IOF ontology is used in an IOF ontology (and the source ontology is not imported in its entirety)."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/explanatoryNote",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "explanatory note"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#note"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "note that provides additional explanatory information about a given notion or resource"
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/firstOrderLogicAxiom",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "first-order logic axiom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/logicAxiom"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "logic axiom annotation written in first order logic"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote" : [ {
    "@language" : "en-us",
    "@value" : "First-order logic axioms MAY be provided if the term is primitive ('is primitive' is true ) or non-primitive. A construct MAY include more than one first-order logic axiom annotation."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/firstOrderLogicDefinition",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "first order logic definition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/logicDefinition"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "logic definition that expresses the axioms of a class or an object property in first order logic"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en-us",
    "@value" : "An example of a First Order Logic definition for 'Product' might be (again bearing in mind the natural language terms appearing should be regarded as symbols in the IOF signature):\n - Continuant(x) ∧ ¬(SpecificallyDependentContinuant(x) ∨ Person(x) ∨ Organization(x)) ∧ ∃r (ProductRole(r) ∧ hasRole(x, r))"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote" : [ {
    "@language" : "en-us",
    "@value" : "The First Order Logic Definition annotation is comprised of the (complete) necessary and sufficient conditions.\n - This annotation is Required for each non-primitive (aka non-axiomatic) class (i.e. unary relation) of a published IOF OWL ontology. This is the most authoritative and comprehensive definition of an IOF element. \n - IOF Common Logic ontologies do not require this annotation, but if included it must be logically equivalent to the Common Logic definition.\n - A primitive (aka axiomatic) term will not have a First Order Logic definition in either an OWL or Common Logic IOF ontology.\n - There should be at most one First Order Logic definition.\n - The specific symbols to be used for existential and universal quantification along with those for conjunction, disjunction, negation, conditional (i.e. if-then), and equivalence will be those commonly used in the mathematical formulas and statement.\n - Conjunction - ∧; Disjunction - ∨; Negation - ¬; Existential Quantification - ∃; Universal Quantification - ∀; Conditional - →; Equivalence - ↔; Left/Right Parentheses - (,); Left/Right Brackets - {,}."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/isPrimitive",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "is primitive"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "boolean flag indicating that necessary and sufficient conditions are not provided"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote" : [ {
    "@language" : "en-us",
    "@value" : "'is primitive' must be present if the term does not have necessary and sufficient conditions and the value of the annotation must be set to true. When 'is primitive' is set to true, a value for a 'primitive rationale' annotation must also be provided."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/logicAxiom",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "logic axiom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#note"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "logical statements constraining the interpretation of the notion represented by the construct that do not provide necessary and sufficient conditions"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/explanatoryNote" : [ {
    "@language" : "en-us",
    "@value" : "This annotation property is an abstraction of the more specialized logic axiom annotations used in IOF. However, this annotation property can also be used to group together the logic axiom annotation values of different forms (such as FOL and natural language) that express the same meaning for a particular construct."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote" : [ {
    "@language" : "en-us",
    "@value" : "A first order logic axiom expression and a semi-formal natural language axiom expression should be added as Property values for each logic axiom annotation using 1 of each of the corresponding logic axiom annotation subproperties."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/logicDefinition",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "logic definition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#definition"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "definition in the form of a logical expression"
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "maturity"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "annotation property used to indicate the development status of a resource"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote" : [ {
    "@language" : "en-us",
    "@value" : "Any value for maturity MUST be an instance of MaturityLevel. All IOF ontologies MUST include exactly one maturity annotation. IOF constructs may include a maturity annotation."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "natural language definition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#definition"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "definition written in plain text for human understanding"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote" : [ {
    "@language" : "en-us",
    "@value" : "This annotation is Required for each non-primitive or non-axiomatic class of an IOF (OWL or Common Logic) ontology. \n - It is optional for primitive (aka axiomatic) classes since such the Elucidation annotation is required and will satisfy the role of a natural language definition.\n - It is optional, but recommended, for relations when the intent of a relation may be misunderstood.\n - There should be at most one.\n - This natural language definition should be subject matter expert friendly and consistent with any formal definition or elucidation.\n - Natural language definitions should use class and relation names with following caveats:\n a) Relations – For those relations whose label (i.e. local identifier) consist of multiple terms hyphenate the terms of the label: e.g. 'hasPlan' would be written as 'has-plan'\n b) Classes – For classes whose label has multiple distinct terms, e.g, ManufacturingOperationSpecification, separate the terms but bound them with apostrophe marks: 'Manufacturing Operation Specification'."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/primitiveRationale",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "primitive rationale"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#note"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "reason why necessary and sufficient conditions could not be provided"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote" : [ {
    "@language" : "en-us",
    "@value" : "When 'is primitive' is set to true, a value for 'primitive rationale' must be provided. The rationale should indicate what is missing if additional work is required to define necessary and sufficient conditions."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/semiFormalNaturalLanguageAxiom",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "semi-formal natural language axiom"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/logicAxiom"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "logic axiom expressed in natural language"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote" : [ {
    "@language" : "en-us",
    "@value" : "Semi-formal natural language axioms MAY be provided if the term is primitive (is primitive is true). A construct MAY include more than one semi-formal natural language axiom annotation."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/semiFormalNaturalLanguageDefinition",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "semi-formal natural language definition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/logicDefinition"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "logic definition that expresses a first order logic definition or common logic definition in natural language"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote" : [ {
    "@language" : "en-us",
    "@value" : "This annotation is required if an element in an IOF OWL ontology has a First Order Logic definition or in a IOF Common Logic (where the element is defined using Common Logic).\n - The intent of this annotation to provide a transition or bridge from the First Order Logic definition of a notion to the natural language definition. This definition is intended to help a user understand the intended interpretation of the notion.\n - As example using the First Order Logic definition of 'Product' above, a semi-formal translation of that might be: \n - Product =def. Continuant that is not a Person and not an Organization and not a Specifically Dependent Continuant and there is a Product Role that the thing has or bears."
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/subjectMatterExpertExplanation",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "subject matter expert explanation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#definition"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "definition of the term expressed in natural language that has the minimal usage of ontological terms and is intended to be a self-standing explanation"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote" : [ {
    "@value" : "Usage of this annotation is optional but is recommended in cases where:\n- the natural language definition or elucidation rely heavily on the terms defined in the ontology\n- there exists an explanation of the term that is more familiar to SMEs that does not coincide with the definition present in the ontology"
  } ]
}, {
  "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/usageNote",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en-us",
    "@value" : "usage note"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#note"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en-us",
    "@value" : "note that provides information about how a given notion or resource is used in the ontology's context"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000000",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Instances of Portions Of Matter whose shape is relevant for their dispostion to participate in a manufacturing process may be (subclasses of) objects that bear a 'blank role' in the context of the manufacturing process."
  }, {
    "@language" : "en",
    "@value" : "Material is defined in terms of the three main perspectives that material specifications rely on: the structure of the material (\"intensive quality\"), the performance of the material (\"behavoiral material property\") and the processing the material must have undergone (\"output of some process\").\n\nWhen defining specific materials/material taxonomies, these three aspects shall be taken into account in the aristotelian (\"per genus et differentiam\") as differentiation."
  }, {
    "@language" : "en",
    "@value" : "The sum of portions of matter of the same type form a portion of matter of that type."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Material"
  }, {
    "@language" : "en",
    "@value" : "material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000001"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Portion of Material"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A material is a portion of matter that may participate in some manufacturing process and whose shape is not relevant for its participation in the manufacturing process."
  } ],
  "https://w3id.org/pmd/co/PMD_0000060" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000001",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "It is also representing a distinct physical or conceptual part of a material or substance.\n\nThe open energy ontology OEO defines portion of matter as a subclass of object aggregate, which implies countability. Our portion is not (precisely) countable and thus bearer of intensive properties."
  }, {
    "@language" : "en",
    "@value" : "Lome explanation for portion of matter: \"What is a molecule cluster at the cellular level? Contrary to the molecular level, at the cellular level of granularity the boundary of each molecule is outside of the level of granular focus. What forms a discontinuous cluster of countable individual molecules and thus bona fide objects at the molecular level, is a continuous and non-countable molecular substance at coarser levels of\ngranularity. At these coarser levels, the individual molecules cannot be differentiated and demarcated anymore and the cluster as a whole possesses only fiat inner boundaries.\""
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "portion of matter"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000040"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A material entity that is not demarcated by any physical discontinuities. At some finer level of granularity it is an object aggregate, at some coarser level of granularity it is a fiat object part,but at this level of granularity it is neither."
  } ],
  "https://w3id.org/pmd/co/PMD_0000060" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000013",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "parameter specification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid352"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A directive information entity that specifies a parameter required or produced by a workflow function, including its intended role, position, and constraints."
  } ],
  "https://w3id.org/pmd/co/PMD_0001032" : [ {
    "@value" : "https://github.com/materialdigital/core-ontology/issues/246"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000014",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "input specification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000013"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A parameter specification that prescribes a data item required as input for the execution of a workflow function."
  } ],
  "https://w3id.org/pmd/co/PMD_0001032" : [ {
    "@value" : "https://github.com/materialdigital/core-ontology/issues/246"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000015",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "output specification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000013"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A parameter specification that prescribes a data item intended to be produced as output by the execution of a workflow function."
  } ],
  "https://w3id.org/pmd/co/PMD_0001032" : [ {
    "@value" : "https://github.com/materialdigital/core-ontology/issues/246"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000060",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000525",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Atomkraftmikroskop"
  }, {
    "@language" : "en",
    "@value" : "atomic force microscope"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000855"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A microscope that maps the surface topography of materials at the nanoscale by scanning it with a mechanical probe."
  }, {
    "@language" : "de",
    "@value" : "Ein Mikroskop, das die Oberflächentopographie von Materialien im Nanobereich durch Abtasten mit einer mechanischen Sonde kartiert."
  } ],
  "https://w3id.org/pmd/co/PMD_0050117" : [ {
    "@language" : "en",
    "@value" : "AFM"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000557",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Chromatographiesystem"
  }, {
    "@language" : "en",
    "@value" : "chromatography system"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000602"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A device used for separating mixtures into individual components using a chromatographic column and a mobile phase."
  }, {
    "@language" : "de",
    "@value" : "Ein Gerät zur Trennung von Gemischen in einzelne Komponenten unter Verwendung einer chromatographischen Säule und einer mobilen Phase."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000602",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Gerät"
  }, {
    "@language" : "en",
    "@value" : "device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000030"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A device is an object that is designed to perform a specific function or task involving measurement, manipulation, processing, or analysis."
  }, {
    "@language" : "de",
    "@value" : "Ein physisches oder virtuelles Objekt, das verwendet wird, um eine bestimmte Funktion oder Aufgabe auszuführen, häufig im Zusammenhang mit der Messung, Manipulation oder Analyse von Materialien."
  } ],
  "https://w3id.org/pmd/co/PMD_0000060" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000603",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Rolle eines Gerätes"
  }, {
    "@language" : "en",
    "@value" : "device role"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000023"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "de",
    "@value" : "Rolle, die ein Geräte inne haben kann."
  } ],
  "https://w3id.org/pmd/co/PMD_0000060" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000624",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@language" : "en",
    "@value" : "“Electron microscope.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/electron%20microscope. Accessed 24 Nov. 2022."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Elektronenmikroskop"
  }, {
    "@language" : "en",
    "@value" : "electron microscope"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000855"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A microscope that uses a beam of electrons to create high-resolution images of a sample's surface or structure."
  }, {
    "@language" : "en",
    "@value" : "An electron-optical instrument in which a beam of electrons is used to produce an enlarged image of a minute object."
  }, {
    "@language" : "de",
    "@value" : "Ein Gerät, das einen Elektronenstrahl verwendet, um hochauflösende Bilder der Oberfläche oder Struktur einer Probe zu erstellen."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000657",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Gaschromatographiesystem"
  }, {
    "@language" : "en",
    "@value" : "gas chromatography system"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000557"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A chromatography system used for separating and analyzing compounds in a gas mixture using a chromatographic column."
  }, {
    "@language" : "de",
    "@value" : "Ein Chromatographiesystem zur Trennung und Analyse von Verbindungen in einem Gasgemisch unter Verwendung einer chromatographischen Säule."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000659",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Gelpermeations-Chromatographiesystem"
  }, {
    "@language" : "en",
    "@value" : "gel permeation chromatography system"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000557"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A chromatography system used for separating and analyzing polymers based on their molecular size using gel permeation chromatography."
  }, {
    "@language" : "de",
    "@value" : "Ein Chromatographiesystem zur Trennung und Analyse von Polymeren basierend auf ihrer Molekülgröße durch Gelpermeationschromatographie."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000784",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Hochleistungsflüssigkeitschromatographiesystem"
  }, {
    "@language" : "en",
    "@value" : "high performance liquid chromatography system"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000557"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A chromatography system used for separating, identifying, and quantifying compounds in liquid samples through high performance liquid chromatography."
  }, {
    "@language" : "de",
    "@value" : "Ein Chromatographiesystem zur Trennung, Identifizierung und Quantifizierung von Verbindungen in Flüssigkeitsproben durch Hochleistungsflüssigkeitschromatographie."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000785",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Hochtemperatur-Gaschromatographiesystem"
  }, {
    "@language" : "en",
    "@value" : "high temperature gas chromatography system"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000657"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A gas chromatography system used for separating and analyzing compounds in a gas mixture at high temperatures using a chromatographic column."
  }, {
    "@language" : "de",
    "@value" : "Ein Gaschromatographiesystem zur Trennung und Analyse von Verbindungen in einem Gasgemisch bei hohen Temperaturen unter Verwendung einer chromatographischen Säule."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000796",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Ionenaustausch-Chromatographiesystem"
  }, {
    "@language" : "en",
    "@value" : "ion exchange chromatography system"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000557"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A chromatography system used for separating ions in a sample using ion exchange resins in a chromatographic column."
  }, {
    "@language" : "de",
    "@value" : "Ein Chromatographiesystem zur Trennung von Ionen in einer Probe unter Verwendung von Ionenaustauschharzen in einer chromatographischen Säule."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000797",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Ionenmikroskop"
  }, {
    "@language" : "en",
    "@value" : "ion microscope"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000855"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A microscope that uses ions to create high-resolution images of the surface or structure of a sample."
  }, {
    "@language" : "de",
    "@value" : "Ein Mikroskop, das Ionen verwendet, um hochauflösende Bilder der Oberfläche oder Struktur einer Probe zu erstellen."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000835",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Massenspektrometer"
  }, {
    "@language" : "en",
    "@value" : "mass spectrometer"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000602"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A device used to measure the mass-to-charge ratio of ions to identify and quantify compounds in a sample."
  }, {
    "@language" : "de",
    "@value" : "Ein Gerät zur Messung des Massen-zu-Ladung-Verhältnisses von Ionen zur Identifizierung und Quantifizierung von Verbindungen in einer Probe."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000855",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Mikroskop"
  }, {
    "@language" : "en",
    "@value" : "microscope"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000602"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A device used to magnify and view small objects or details that are not visible to the naked eye."
  }, {
    "@language" : "de",
    "@value" : "Ein Gerät zur Vergrößerung und Betrachtung kleiner Objekte oder Details, die mit bloßem Auge nicht sichtbar sind."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000874",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Optisches Mikroskop"
  }, {
    "@language" : "en",
    "@value" : "optical microscope"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000855"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A microscope that uses visible light and lenses to magnify and view small objects or details."
  }, {
    "@language" : "de",
    "@value" : "Ein Mikroskop, das sichtbares Licht und Linsen verwendet, um kleine Objekte oder Details zu vergrößern und zu betrachten."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000888",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@language" : "en",
    "@value" : "Classified by morphology."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "ClimOO Ontology comment:\nTill release 3.0.0-rc2, despite acknowledging the existence of natural polymer materials, PMDco focused the polymer classes on those of synthetic production. In the current release (3.0.0), PMDco changed the subsumption axiomatization of the “polymer” class from being a subclass of the “engineered material” class to the “material” class. We assume to extend its coverage to also include non-synthetic polymer materials (see included subclasses)and map accordingly. The definition of the PMDco “polymer” class, however, has not been changed yet, still referring to engineered materials."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "polymer"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000000"
  }, {
    "@id" : "_:genid360"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000246"
  }, {
    "@id" : "_:genid356"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A polymer is an engineered material that consists of many repeated subunits (monomers) to form long chains. The atoms within a polymer chain are bonded together by covalent bonds. The intermolecular forces between polymer chains are typically represented by van der waals forces and hydrogen bonds."
  } ],
  "https://w3id.org/pmd/co/PMD_0000060" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000890",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "connected material entity aggregate"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000027"
  } ],
  "http://www.w3.org/2004/02/skos/core#comment" : [ {
    "@language" : "en",
    "@value" : "ClimOO Ontology comment:\nWe included this class for possible implementations. Subclasses can be specified, for instance, for plastics, as needed."
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An object aggregate that is a mereological sum of separate material entities, which adhere to one another through chemical bonds or physical junctions that go beyond gravity."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "the atoms of a molecule, the molecules forming the membrane of a cell, the epidermis in a human body"
  } ],
  "https://w3id.org/pmd/co/PMD_0000060" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000891",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "disconnected material entity aggregate"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000027"
  } ],
  "http://www.w3.org/2004/02/skos/core#comment" : [ {
    "@language" : "en",
    "@value" : "ClimOO Ontology comment:\nWe included this class for possible implementations. Subclasses can be specified, for instance, for plastics, as needed."
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An object aggregate that is a mereological sum of scattered (i.e. spatially separated) material entities, which do not adhere to one another through chemical bonds or physical junctions but, instead, relate to one another merely on grounds of metric proximity. The material entities are separated from one another through space or through other material entities that do not belong to the group."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "a heap of stones, a colony of honeybees, a group of synapses, the trees of a forest, the canopy of a forest, the fish of a shoal, a group of commuters on the subway, the patients in a hospital"
  } ],
  "https://w3id.org/pmd/co/PMD_0000060" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000893",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "powder"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000891"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A powder is a dry, solid disconnected material entity aggregate composed of many very fine particles. These particles can flow freely when shaken or tilted."
  } ],
  "https://w3id.org/pmd/co/PMD_0000060" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000922",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Rasterelektronenmikroskop"
  }, {
    "@language" : "en",
    "@value" : "scanning electron microscope"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000624"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A scanning electron microscope (SEM) is a measuring device that produces high-resolution images of a sample surface by scanning it with a focused beam of electrons."
  }, {
    "@language" : "de",
    "@value" : "Ein Rasterelektronenmikroskop (REM) ist ein Messgerät, das hochauflösende Bilder einer Probenoberfläche erzeugt, indem es sie mit einem fokussierten Elektronenstrahl abtastet."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000963",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "supercritical fluid chromatography system"
  }, {
    "@language" : "de",
    "@value" : "Überkritisches Fluid-Chromatographiesystem"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000557"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A chromatography system for separating and analyzing compounds using supercritical fluids as the mobile phase in chromatography."
  }, {
    "@language" : "de",
    "@value" : "Ein Chromatographiesystem zur Trennung und Analyse von Verbindungen unter Verwendung überkritischer Flüssigkeiten als mobile Phase in der Chromatographie."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0000990",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Dünnschichtchromatographiesystem"
  }, {
    "@language" : "en",
    "@value" : "thin layer chromatography system"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000557"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A chromatography system used for separating compounds in a sample using a thin layer of adsorbent material on a plate."
  }, {
    "@language" : "de",
    "@value" : "Ein Chromatographiesystem zur Trennung von Verbindungen in einer Probe unter Verwendung einer dünnen Schicht adsorbierenden Materials auf einer Platte."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0001032",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0010033",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "polymerization"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000015"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The chemical process of reacting monomers, oligomers, or reactive precursors together to form longer macromolecular chains or three-dimensional networks"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0010034",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "curing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000015"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The toughening or hardening of a polymer material by cross-linking of polymer chains."
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0020115",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "aerosol"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000891"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An aerosol is a disconnected material entity aggregate which:\n1. consists of some portion of matter whose aggregate state quality concretizes gaseous and \n2. consists of some portion of matter whose aggregate state quality concretises solid or liquid (TODO: express that this portion is also a disconnected material entity aggregate)"
  } ],
  "https://w3id.org/pmd/co/PMD_0000060" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0020126",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "old defintion: A foam is a material entity aggregate that is also a composite material c. \nThe parts of c that have the filler role are vacuum-filled or gas filled pores. \nThe parts of c that have the matrix role consist of a material that is bearer of solid or liquid aggregate state. \nOne pore with its surrounding matrix is called 'cell'. \nDepending on the interconnectedness of the pores the foam is open- or closed-cell."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "foam"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000890"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A foam is a connected material entity aggregate that consists of a solid or liquid matrix containing gas-filled or vacuum-filled pores forming cellular structures."
  } ],
  "https://w3id.org/pmd/co/PMD_0000060" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0025008",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Transmissionselektronenmikroskop"
  }, {
    "@language" : "en",
    "@value" : "transmission electron microscope"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000624"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An electron microscope that produces high-resolution images of a sample's internal structure by transmitting electrons through the sample."
  }, {
    "@language" : "de",
