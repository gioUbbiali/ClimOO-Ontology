                                      rdfs:subClassOf <https://w3id.org/pmd/co/PMD_0050036> ;
                                      rdfs:label "polyhydroxyalkanoates"@en ;
                                      <http://www.w3.org/2004/02/skos/core#definition> "Polyhydroxyalkanoates are Biodegradable Polymers that are biosynthesized by microorganisms from sugars or lipids."@en ;
                                      <https://w3id.org/pmd/co/PMD_0000060> "true"^^xsd:boolean .


###  https://w3id.org/pmd/co/PMD_0050039
<https://w3id.org/pmd/co/PMD_0050039> rdf:type owl:Class ;
