###  https://w3id.org/sumso#SuMSO_0000085
<https://w3id.org/sumso#SuMSO_0000085> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000005> ;
                                       rdfs:comment "We envision conversations with subject matter experts to further detail this definition. Possible topics of discussion will cover the relation with plans and activities."@en ;
                                       rdfs:label "impact area"@en ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "An objective specification that generically depends on some complex system component or complex system environment component and describes an intended process endpoint concerning the change that the complex system component or complex system environment component wishes to see in the related complex system, according to its perspective."@en ;
                                       <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                                       <https://w3id.org/sco#SCO_0000039> <https://w3id.org/sumso#SuMSO_0000056> .


###  https://w3id.org/sumso#SuMSO_0000086
<https://w3id.org/sumso#SuMSO_0000086> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000016> ,
                                                       [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000016>
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000177> ;
                                                                                owl:someValuesFrom <https://w3id.org/sumso#SuMSO_0000089>
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ] ;
                                       <http://purl.org/dc/terms/source> """https://doi.org/10.1016/0047-2727(74)90006-1 
https://doi.org/10.2307/3439966  
https://tannerlectures.utah.edu/_resources/documents/a-to-z/s/sen80.pdf  
https://doi.org/10.1093/0198287976.001.0001 
https://scholar.harvard.edu/sen/publications/development-capability-expansion""" ;
                                       <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "well-being, wellbeing"@en ;
                                       <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> "welfare"@en ;
                                       rdfs:label "complex system component well-being"@en ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "A disposition whose realization leads the complex system component to freely choose among alternative combinations of valuable and considered-valuable functionings (doings and beings) that owns and among which it can opt to live a life worthy of value and that has the motive to value as a part of the complex system to which it belongs."@en ;
                                       <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                                       <https://w3id.org/sco#SCO_0000039> <https://w3id.org/sumso#SuMSO_0000052> ,
                                                                          <https://w3id.org/sumso#SuMSO_0000064> .


###  https://w3id.org/sumso#SuMSO_0000087
<https://w3id.org/sumso#SuMSO_0000087> rdf:type owl:Class ;
                                       owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/sumso#SuMSO_0000086>
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000059> ;
                                                                                    owl:someValuesFrom <https://w3id.org/sumso#SuMSO_0000093>
                                                                                  ]
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <http://purl.obolibrary.org/obo/RO_0000092> ;
                                                                                    owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/NCBITaxon_33208>
                                                                                                                              [ rdf:type owl:Class ;
                                                                                                                                owl:complementOf <http://purl.obolibrary.org/obo/NCBITaxon_9606>
                                                                                                                              ]
                                                                                                                            ) ;
                                                                                                         rdf:type owl:Class
                                                                                                       ]
                                                                                  ]
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <http://www.ontologyrepository.com/CommonCoreOntologies/is_subject_of> ;
                                                                                    owl:someValuesFrom <https://w3id.org/sumso#SuMSO_0000093>
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ] ;
                                       rdfs:subClassOf <https://w3id.org/sumso#SuMSO_0000086> ;
                                       <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> "animal well-being, animal wellbeing"@en ;
                                       rdfs:comment "Despite humans are animals, the term \"animal welfare\" is primarily used excluding reference to humans. We kept track of this feature, creating a separated class for human wellbeing. Possible revision of these classes may be required."@en ;
                                       rdfs:label "animal welfare"@en ;
                                       rdfs:seeAlso """http://purl.obolibrary.org/obo/OMIT_0002232 
http://opendata.inra.fr/Triphase/ID_0000301 
http://aims.fao.org/aos/agrovoc/xDef_2a5186fd""" ,
                                                    """https://www.ggrass.org/ 
https://regenscore.org/""" ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "A complex system component well-being that is bearered by an animal. Features related to animal welfare include freedom from hunger, thirst, discomfort, and any sort of harm or disease, access to adequate and salutary living spaces, clean water, and safe and nutritious food, freedom to express proper instinctive behaviors, freedom from distress and fear, absence of treatment with prohibited medications and substances, and a minimally painful demise."@en ;
                                       <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                                       <https://w3id.org/sco#SCO_0000039> <https://w3id.org/sumso#SuMSO_0000052> ,
                                                                          <https://w3id.org/sumso#SuMSO_0000056> .


###  https://w3id.org/sumso#SuMSO_0000089
<https://w3id.org/sumso#SuMSO_0000089> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000016> ,
                                                       [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000016>
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000059> ;
                                                                                owl:someValuesFrom <https://w3id.org/sumso#SuMSO_0000092>
                                                                              ]
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <http://purl.obolibrary.org/obo/RO_0000092> ;
                                                                                owl:someValuesFrom <https://www.w3id.org/sco#SCO_0000015>
                                                                              ]
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <http://www.ontologyrepository.com/CommonCoreOntologies/is_subject_of> ;
                                                                                owl:someValuesFrom <https://w3id.org/sumso#SuMSO_0000092>
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ] ,
                                                       [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000016>
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                                                                owl:someValuesFrom <https://w3id.org/sumso#SuMSO_0000086>
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ] ;
                                       <http://purl.org/dc/terms/source> """https://doi.org/10.1016/0047-2727(74)90006-1
https://doi.org/10.2307/3439966 
https://tannerlectures.utah.edu/_resources/documents/a-to-z/s/sen80.pdf 
https://doi.org/10.1093/0198287976.001.0001
https://scholar.harvard.edu/sen/publications/development-capability-expansion"""@en ;
                                       rdfs:comment "Here, the well-being of a whole complex system is seen as more than the simple sum of the well-being of all its parts."@en ;
                                       rdfs:label "complex system well-being"@en ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "A disposition whose realization leads all complex system components to choose freely and in an integrable manner among alternative combinations of valuable and considered-valuable functionings (doings and beings) that they interdependently own and among which they can opt to live a life worthy of value and that has the motive to value as a part of the complex system to which they belong."@en ;
                                       <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                                       <https://w3id.org/sco#SCO_0000039> <https://w3id.org/sumso#SuMSO_0000052> ,
                                                                          <https://w3id.org/sumso#SuMSO_0000064> .


