                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000117> ;
                                                                                owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                     owl:unionOf ( <https://w3id.org/sumso#SuMSO_0000027>
                                                                                                                   <https://w3id.org/sumso#SuMSO_0000029>
                                                                                                                 )
                                                                                                   ]
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ] ;
                                       rdfs:label "food system activity"@en ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "A complex system activity that has as occurrent parts some (at least one) interactions among food system components or interactions between food system components and food system environment components."@en ;
                                       <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> .


