                                       rdfs:subClassOf <https://www.w3id.org/sco#SCO_0000022> ,
                                                       [ owl:intersectionOf ( <https://www.w3id.org/sco#SCO_0000022>
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <https://www.w3id.org/sco#SCO_0000037> ;
                                                                                owl:someValuesFrom <https://w3id.org/sumso#SuMSO_0000025>
                                                                              ]
                                                                              [ rdf:type owl:Restriction ;
