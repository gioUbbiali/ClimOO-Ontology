###  http://purl.obolibrary.org/obo/ENVO_01000799
<http://purl.obolibrary.org/obo/ENVO_01000799> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_01000804> ;
                                               <http://purl.obolibrary.org/obo/IAO_0000115> "An object which is naturally occuring, bound together by gravitational or electromagnetic forces, and surrounded by space." ;
                                               <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> "celestial body" ;
                                               <http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/envo#envoAstro> ;
                                               rdfs:comment "Astronomical bodies are usually cohesive, thus the use of the term 'object' sensu BFO 'object'." ;
                                               rdfs:label "astronomical body"@en .

