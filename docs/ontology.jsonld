  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@language" : "en",
    "@value" : "pre-production plastic pellets"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic nurdle"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000258"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A plastic pellet that is manufactured in such a way that its size enables quick melting thereby making it usable for further downstream manufacturing processes."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom" : [ {
