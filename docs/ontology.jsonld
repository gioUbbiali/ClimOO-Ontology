  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000109",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "References to degradable polymers and degradability can be added as needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "biodegradable polymer molecule"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000242"
  }, {
    "@id" : "_:genid386"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
