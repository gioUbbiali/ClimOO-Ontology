###  http://purl.obolibrary.org/obo/ENVO_01000776
<http://purl.obolibrary.org/obo/ENVO_01000776> rdf:type owl:Class ;
                                               owl:equivalentClass _:genid178 ;
                                               rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_01001687> ,
