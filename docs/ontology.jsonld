    "@language" : "en",
    "@value" : "The system history of a complex system."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000024",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  }, {
    "@value" : "Future SCO implementations may deal with representing system environment boudaries."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "confine del sistema"
  }, {
    "@language" : "fr",
    "@value" : "frontière de système"
  }, {
    "@language" : "en",
    "@value" : "system boundary"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000146"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1567"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A fiat surface of a system."
  }, {
    "@language" : "it",
    "@value" : "Una superficie fiat di un sistema."
  }, {
    "@language" : "fr",
    "@value" : "Une surface fiat d’un système."
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000025",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Future SCO implementations may consider including classes also covering spatial region for the system environment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "regione spaziale del sistema"
  }, {
    "@language" : "fr",
    "@value" : "région d’espace de système"
  }, {
    "@language" : "en",
    "@value" : "system spatial region"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000028"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A three-dimensional spatial region of a system."
  }, {
    "@language" : "it",
    "@value" : "Una regione di spazio tridimensionale di un sistema."
  }, {
    "@language" : "fr",
    "@value" : "Une région d’espace tridimensionnelle d’un système."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000026",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@value" : "complex system environment element"
  }, {
    "@value" : "complex system environment variable"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "complex system environment component"
  }, {
    "@language" : "it",
    "@value" : "componente dell' ambiente del systema complesso"
  }, {
    "@language" : "fr",
    "@value" : "composante de l'environnement de système complexe"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000014"
  }, {
    "@id" : "_:genid1575"
  }, {
    "@id" : "_:genid1579"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000028"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1571"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A system evironment component that belongs to the system environment of a complex system."
  }, {
    "@language" : "it",
    "@value" : "Una componente dell'ambiente di sistema che appartiene all’ambiente di un sistema complesso."
  }, {
    "@language" : "fr",
    "@value" : "Une composante de l'environnement de système qui appartient à l’environnement d’un système complexe."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000027",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "We envision revisions of the current SCO theory of agency. This is due to the limited power of explainability of present representation. A sounder and deeper interpretation of the causal role of an agent in an interaction, compared to other participants, is required.\n\nTentative proposal: a possible direction of implementation is towards a telic vision of agency intended as end-point driven. On this more fundamental neutral vision, a second layer of representation may be constructed to model intentionality, goals, and plans in relation to agency. Here, SCO may harmonize and align with UFO-C representation. \n\nFor insight for discussion see: \nGuarino, N., & Guizzardi, G. (2024). Processes as variable embodiments. Synthese, 203(4), 104. https://doi.org/10.1007/s11229-024-04505-2\nGuizzardi, G., de Almeida Falbo, R., & Guizzardi, R. (2008). Grounding software domain ontologies in the unified foundational ontology (UFO): The case of the ODE. Memorias de la XI Conferencia Iberoamericana de Software Engineering (CIbSE 2008), Recife, Pernambuco, Brasil, February 13-17, 2008, 127–140."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "agent de l’environnement de système"
  }, {
    "@language" : "it",
    "@value" : "agente dell’ambiente del sistema"
  }, {
    "@language" : "en",
    "@value" : "system environnement agent"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000037"
  }, {
    "@id" : "https://www.w3id.org/sco#SCO_0000038"
  }, {
    "@language" : "en",
    "@value" : "comments to https://www.w3id.org/sco/sco-u#SCO_0000027 and https://www.w3id.org/sco/sco-u#SCO_0000029"
  }, {
    "@value" : "See information under the \"has agent at t\" property."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000014"
  } ],
