                                               <http://purl.obolibrary.org/obo/IAO_0000115> "A carbon emission process is any environmental process which outputs a carbon-bearing gas." ;
                                               <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> "carbon emission process" ;
                                               <http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/envo#envoPolar> ;
                                               rdfs:comment "Requested for SDGIO. Likely to be revised." ;
                                               rdfs:label "carbon-bearing gas emission process"@en .


