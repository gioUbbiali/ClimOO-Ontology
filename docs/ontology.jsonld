  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "natural rubber"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0050030"
  } ],
  "http://www.w3.org/2004/02/skos/core#comment" : [ {
    "@value" : "they are predominantly cis-1,4-polyisoprene,"
  }, {
    "@value" : "they are used widely in Heavy-duty truck tires"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "elastomer polymer, and a biopolymer harvested as plant latex; consisting of cis-1,4-polyisoprene chains; typically sulfur-vulcanized to create crosslinks between chains"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0050032",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "synthetic rubber"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0050030"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "elastomer that is produced through chemical synthesis to mimic natural rubber’s properties"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0050033",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "styrene-butadiene rubber"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0050032"
  } ],
  "http://www.w3.org/2004/02/skos/core#comment" : [ {
    "@value" : "used widely for its good abrasion resistance and tunable hardness, for instance in tire treads."
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "synthetic rubber and belongs to a family of synthetic random copolymer elastomers of styrene and butadiene, made by emulsion or solution polymerization and typically vulcanized"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0050034",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "nitrile butadiene rubber"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0050032"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@value" : "Nitrile "
  } ],
  "http://www.w3.org/2004/02/skos/core#comment" : [ {
    "@value" : "Oil resistance, Fuel resistance"
  }, {
    "@value" : "it can have tunable polarity and oil/fuel resistance"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "synthetic rubber that belongs to a family of synthetic acrylonitrile–butadiene copolymer elastomers"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : " it is widely used in oil/fuel resistance applicaitons such as seals, fuel hoses, and protective gloves"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0050035",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ethylene propylene diene monomer"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0050032"
  } ],
  "http://www.w3.org/2004/02/skos/core#comment" : [ {
    "@value" : "it offers excellent weather resistance"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "synthetic rubber produced from ethylene, propylene, and a diene monomer"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0050037",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "ClimOO Ontology comment:\nWe did not include the PMDco class for biodegradable polymers because PMDco erroneously refers to biodegradability in the portions of material and not to the constituting polymer molecules. We, however, imported PMDco “biodegradability” class and mapped it as equivalent to ClimOO “biodegradability” class. We also include the PMDco “polybutylene succinate” and “polylactic acid” classes, subclasses of and mapped as subclasses of the ClimOO “portion of biodegradable plastic” class. This aims to be an initial mapping till PMDco revises its class.\nSee: https://w3id.org/pmd/co/PMD_0050036 \nhttps://w3id.org/pmd/co/PMD_0200001"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "polylactic acid"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0050004"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000107"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "biodegradable thermoplastic polymer produced from renewable resources such as corn starch"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0050038",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "polyhydroxyalkanoates"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0000888"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "polyhydroxyalkanoates are biodegradable polymers that are biosynthesized by microorganisms from sugars or lipids"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0050039",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "polybutylene succinate"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0050004"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000107"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "biodegradable thermoplastic polymer polyester that is synthesized via the polycondensation of succinic acid and 1,4-butanediol"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0050117",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0060009",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The intent of the specification datum is to express the \"Sollwert\" of some qualitiy or behavioral material property. Then, the specification datum can be further specified by  some value specification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "specification datum"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000033"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A directive information entity that provides information of a setpoint of some value, i.e., it is an intended value."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "The setpoint value of a ultimate tensile strength of some steel material"
  } ],
  "https://w3id.org/pmd/co/PMD_0000060" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#boolean",
    "@value" : "true"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0090050",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "thermosetting polyurethane"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0050022"
  } ],
  "http://www.w3.org/2004/02/skos/core#comment" : [ {
    "@value" : "offers high versatility in mechanical properties"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "thermosetting polymer with carbamate crosslinks"
  } ],
  "https://w3id.org/pmd/co/PMD_0050117" : [ {
    "@value" : "PUR"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0090051",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "unsaturated polyester resins"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0050022"
  } ],
  "http://www.w3.org/2004/02/skos/core#comment" : [ {
    "@value" : "they are used for fiber-reinforced composites"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "thermosetting polymer system of unsaturated polyester prepolymers in reactive vinyl monomers; it cures by radical crosslinking into rigid networks"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0090052",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "silicone rubber"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0050032"
  } ],
  "http://www.w3.org/2004/02/skos/core#comment" : [ {
    "@value" : "it is available in multiple formulations and often filled."
  }, {
    "@value" : "wide service temperature range"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "synthetic rubber that belongs to crosslinked polysiloxane elastomer family, with organic side groups"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "widely used for its broad service temperature range in medical devices, gaskets, and culinary tools"
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0090053",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "polychloropren"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/pmd/co/PMD_0050032"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@value" : " Neoprene"
  } ],
  "http://www.w3.org/2004/02/skos/core#comment" : [ {
    "@value" : "it offers good weathering and ozone resistance."
  }, {
    "@value" : "weathering resistance; ozone resistance"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "synthetic rubber that belongs to the family of synthetic elastomeric rubbers; synthesised typically through emulsion polymerization of chloroprene"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : " it is widely used in gaskets and wetsuits. "
  } ]
}, {
  "@id" : "https://w3id.org/pmd/co/PMD_0200001",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "orginal: \"[biodegradability] [...] is understood as the microbial conversion of all its organic constituents to carbon dioxide (or carbon dioxide and methane in conditions where oxygen is not present), new microbial biomass and mineral salts, within a timescale short enough not to lead to lasting harm or accumulation in the open environment.\"\n\nEuropean Commission: Directorate-General for Research and Innovation, Biodegradability of plastics in the open environment, Publications Office of the European Union, 2021, https://data.europa.eu/doi/10.2777/690248"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "ClimOO Ontology comment:\nWe did not include the PMDco class for biodegradable polymers because PMDco erroneously refers to biodegradability in the portions of material and not to the constituting polymer molecules. We, however, imported PMDco “biodegradability” class and mapped it as equivalent to ClimOO “biodegradability” class. We also include the PMDco “polybutylene succinate” and “polylactic acid” classes, subclasses of and mapped as subclasses of the ClimOO “portion of biodegradable plastic” class. This aims to be an initial mapping till PMDco revises its class.\nSee: https://w3id.org/pmd/co/PMD_0050036 \nhttps://w3id.org/pmd/co/PMD_0050039\nhttps://w3id.org/pmd/co/PMD_0050037"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "de",
    "@value" : "Biologische Abbaubarkeit"
  }, {
    "@language" : "en",
    "@value" : "biodegradability"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000016"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000104"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "de",
    "@value" : "\"[Biologische Abbaubarkeit] [...] beschreibt die mikrobielle Umwandlung all seiner organischen Bestandteile in Kohlendioxid oder – unter sauerstofffreien Bedingungen – in Kohlendioxid und Methan, neue mikrobielle Biomasse und Mineralsalze verstanden, und zwar innerhalb eines Zeitraums, der so kurz ist, dass es nicht zu dauerhaften Schäden oder Anreicherungen in der offenen Umwelt kommt.\""
  }, {
    "@language" : "en",
    "@value" : "biodegradability is a disposition of a material which specifies its capability to be fully microbially converted into inorganic end products (CO₂, CH₄, mineral salts, biomass) within an environmentally non-harmful timescale."
  } ],
  "https://w3id.org/pmd/co/PMD_0001032" : [ {
    "@value" : "https://github.com/materialdigital/core-ontology/issues/126"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@value" : "Giorgio A. Ubbiali"
  }, {
    "@value" : "Ludger Jansen"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Giorgio A. Ubbiali"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "ClimOO Ontology is a reference ontology, modeling plastics, (micro-)plastic pollution, climate change, and their interrelation, with a primary focus on agricultural systems. The ClimOO Ontology is structured in a suite of nested ontological modules. The PlasticO module centers on representing polymer molecules, plastic materials, pieces of plastic, and plastic objects, along with corresponding life cycles and pollution processes. Emphasis is also dedicated to relevant assessment devices and related data, especially with regard to sustainability."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@value" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "ClimOO Ontology - PlasticO module"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#plastico-v1.0.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@language" : "en",
    "@value" : "V1.0.0."
  }, {
    "@value" : "2025-06-18"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Repository: https://www.w3id.org/climoo/repo\nDocumentation webpage: https://www.w3id.org/climoo/docs"
  }, {
    "@language" : "en",
    "@value" : "The most recent version of this file is available on GitHub at the following link: https://www.w3id.org/climoo/climoo-plastico."
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000072",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "This owl:NamedIndividual tracks the perspectives of ClimOO project participants according to which this ontology has been built."
  } ],
  "http://www.ontologyrepository.com/CommonCoreOntologies/definition" : [ {
    "@language" : "en",
    "@value" : "The perspective of the ClimOO project participants."
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000016"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ClimOO project perspective on plastics"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "https://pthsta.it/climoo"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "2025-08-08"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000074"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000075"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000228"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "This owl:NamedIndividual tracks the framework view proposed by Hartmann et al. (2019)."
  } ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "Hartmann, N. B., Hüffer, T., Thompson, R. C., Hassellöv, M., Verschoor, A., Daugaard, A. E., Rist, S., Karlsson, T., Brennholt, N., Cole, M., Herrling, M. P., Hess, M. C., Ivleva, N. P., Lusher, A. L., & Wagner, M. (2019). Are We Speaking the Same Language? Recommendations for a Definition and Categorization Framework for Plastic Debris. Environmental Science & Technology, 53(3), 1039–1047. https://doi.org/10.1021/acs.est.8b05297"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000016"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "See the following standards concerning microplastic classification. They recommend using the same size range as Hartmann et al. (2019) of 1 and 1000 µm in its largest dimension.\nISO/TR 21960:2020Plastics — Environmental aspects — State of knowledge and methodologies https://www.iso.org/standard/72300.html\nISO 4484-1:2023Textiles and textile products — Microplastics from textile sources Part 1: Determination of material loss from fabrics during washing https://www.iso.org/standard/82238.html"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Hartmann et al. (2019) perspective on microplastics"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000074",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "This owl:NamedIndividual tracks the framework view proposed by Rochman et al. (2019)."
  } ],
  "http://purl.org/dc/terms/source" : [ {
    "@value" : "Rochman, C. M., Brookson, C., Bikker, J., Djuric, N., Earn, A., Bucci, K., Athey, S., Huntington, A., McIlwraith, H., Munno, K., De Frond, H., Kolomijeca, A., Erdle, L., Grbic, J., Bayoumi, M., Borrelle, S. B., Wu, T., Santoro, S., Werbowski, L. M., … Hung, C. (2019). Rethinking microplastics as a diverse contaminant suite. Environmental Toxicology and Chemistry, 38(4), 703–711. https://doi.org/10.1002/etc.4371"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000016"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Rochman et al. (2019) perspective on microplastics"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000075",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
