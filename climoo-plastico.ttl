                                    ] ;
                rdfs:subClassOf :ClimOO_0000244 ;
                <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> "thermoset polymer material"@en ,
                                                                                 "thermosetting polymer material"@en ;
                rdfs:label "portion of cured thermosetting polymer material"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A portion of solid material that is an output of a polymer curing process."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000268
:ClimOO_0000268 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000055> ;
