}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0017005",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "anticoagulant-containing test tube contains measured amount 5 ml of blood specimen."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relation between a container and measurement datum that specifies the actual amount of material in the container."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0017006",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "anticoagulant-containing test tube has maximum capacity 10 ml."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relation that relates a container to a measurement datum that specifies the maximum capacity of the container. Capacity can refer to either weight or volume."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0017008",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "biobank organization owns a specimen"
  }, {
    "@value" : "hospital owns a laboratory facility"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A primitive relation that holds between entities x and y in which y is at x's full disposal."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0017009",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "freezer is owned by a biobank organization"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Inverse of the owns relation."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018001",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Helper relation for OWL definition of RO:0018002 myristoylates"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018002",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A molecularly-interacts-with relationship between two entities, where the subject catalyzes a myristoylation activity that takes the object as input"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018003",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "inverse of myristoylates"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018027",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "mibolerone (CHEBI:34849) is agonist of androgen receptor (PR:P10275)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "a relation between a ligand (material entity) and a receptor (material entity) that implies the binding of the ligand to the receptor activates some activity of the receptor"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018028",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "pimavanserin (CHEBI:133017) is inverse agonist of HTR2A (PR:P28223)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "a relation between a ligand (material entity) and a receptor (material entity) that implies the binding of the ligand to the receptor inhibits some activity of the receptor to below basal level"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018029",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "tretinoin (CHEBI:15367) is antagonist of Nuclear receptor ROR-beta (PR:Q92753)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "a relation between a ligand (material entity) and a receptor (material entity) that implies the binding of the ligand to the receptor reduces some activity of the receptor to basal level"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018031",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "pyruvate anion (CHEBI:15361) is the conjugate base of the neutral pyruvic acid (CHEBI:32816)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A is a direct conjugate base of B if and only if A is chemical entity that is a Brønsted–Lowry Base (i.e., can receive a proton) and by receiving a particular proton transforms it into B."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018032",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "neutral pyruvic acid (CHEBI:32816) is the conjugate acid of the pyruvate anion (CHEBI:15361)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A is a direct conjugate acid of B if and only if A is chemical entity that is a Brønsted–Lowry Acid (i.e., can give up a proton) and by removing a particular proton transforms it into B."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018033",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "(E)-cinnamoyl-CoA(4-) (CHEBI:57252) is a deprotonated form (E)-cinnamoyl-CoA (CHEBI:10956), which involves removing four protons."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A is a deprotonated form of B if and only if A is chemical entity that is a Brønsted–Lowry Base (i.e., can receive a proton) and by adding some nonzero number of protons transforms it into B.\n\nThis is a transitive relationship and follows this design pattern: https://oborel.github.io/obo-relations/direct-and-indirect-relations."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018034",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "(E)-cinnamoyl-CoA (CHEBI:10956) is a protonated form of (E)-cinnamoyl-CoA(4-) (CHEBI:57252), which involves adding four protons."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A is a protonated form of B if and only if A is chemical entity that is a Brønsted–Lowry Acid (i.e., can give up a proton) and by removing some nonzero number of protons transforms it into B.\n\nThis is a transitive relationship and follows this design pattern: https://oborel.github.io/obo-relations/direct-and-indirect-relations."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018035",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "phenol (CHEBI:15882) and aniline (CHEBI:17296) are matched molecular pairs because they differ by one chemical transformation i.e., the replacement of aryl primary amine with aryl primary alcohol."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A and B are a matched small molecular pair (MMP) if their chemical structures define by a single, relatively small, well-defined structural modification.\n\nWhile this is normally called \"matched molecular pair\" in the cheminformatics literaturel, it is labeled as \"matched small molecular pair\" so as to reduce confusion with peptides and other macromolecules, which are also referenced as \"molecules\" in some contexts.\n\nThis relationship is symmetric, meaning if A is a MMP with B iff B is a MMP with A.\n\nThis relationship is not transitive, meaning that A is a MMP with B and B is a MMP with C, then A is not necessarily an MMP with C."
  } ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@value" : "is MMP with"
  }, {
    "@value" : "is matched molecular pair with"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018036",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "3-carboxy-3-mercaptopropanoate (CHEBI:38707) is tautomer of 1,2-dicarboxyethanethiolate (CHEBI:38709) because 3-carboxy-3-mercaptopropanoate is deprotonated on the carboxylic acid whereas 1,2-dicarboxyethanethiolate is deprotonated on the secondary thiol."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Two chemicals are tautomers if they can be readily interconverted.\n\nThis commonly refers to prototropy in which a hydrogen's position is changed, such as between ketones and enols. This is also often observed in heterocyclic rings, e.g., ones containing nitrogens and/or have aryl functional groups containing heteroatoms."
  } ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@value" : "is desmotrope of"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018037",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "carboxylatoacetyl group (CHEBI:58957) is substituent group from malonate(1-) (CHEBI:30795)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Group A is a substituent group from Chemical B if A represents the functional part of A and includes information about where it is connected. A is not itself a chemical with a fully formed chemical graph, but is rather a partial graph with one or more connection points that can be used to attach to another chemical graph, typically as a functionalization."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018038",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "hydrocortamate hydrochloride (CHEBI:50854) has parent hydride hydrocortamate (CHEBI:50851)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Chemical A has functional parent Chemical B if there is chemical transformation through which chemical B can be produced from chemical A. \n\nFor example, the relationship between a salt and a freebased compound is a \"has functional parent\" relationship."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018039",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "dexmedetomidine hydrochloride (CHEBI:31472) is enantiomer of levomedetomidine hydrochloride (CHEBI:48557) because the stereochemistry of the central chiral carbon is swapped."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Chemicals A and B are enantiomers if they share the same molecular graph except the change of the configuration of substituents around exactly one chiral center.\n\nA chemical with no chiral centers can not have an enantiomer. A chemical with multiple chiral centers can have multiple enantiomers, but its enantiomers are not themselves enantiomers (they are diastereomers)."
  } ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@value" : "is optical isomer of"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0018040",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "pyranine (CHEBI:52083) has parent hydride pyrene (CHEBI:39106). Pyrene is molecule with four fused benzene rings, whereas pyranine has the same core ring structure with additional sulfates."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Chemical A has parent hydride Chemical B if there exists a molecular graphical transformation where functional groups on A are replaced with hydrogens in order to yield B."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0019000",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relationship that holds between a process and a characteristic in which process (P) regulates characteristic (C) iff: P results in the existence of C OR affects the intensity or magnitude of C."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@id" : "https://orcid.org/0000-0002-8688-6599"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "regulates characteristic"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002410"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0019001",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relationship that holds between a process and a characteristic in which process (P) positively regulates characteristic (C) iff: P results in an increase in the intensity or magnitude of C."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@id" : "https://orcid.org/0000-0002-8688-6599"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "positively regulates characteristic"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0019000"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0019002",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relationship that holds between a process and a characteristic in which process (P) negatively regulates characteristic (C) iff: P results in a decrease in the intensity or magnitude of C."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@id" : "https://orcid.org/0000-0002-8688-6599"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "negatively regulates characteristic"
  } ],
