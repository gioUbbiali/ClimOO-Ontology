                                                                                                  owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000004>
                                                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                                                                                              owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000017>
                                                                                                                                            ]
                                                                                                                                          ) ;
                                                                                                                       rdf:type owl:Class
                                                                                                                     ]
                                                                                                ] ;
                                                                                <http://www.ontologyrepository.com/CommonCoreOntologies/is_curated_in_ontology> "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/EventOntology"^^xsd:anyURI ;
                                                                                rdfs:label "Gain of Realizable Entity"@en ;
                                                                                <http://www.w3.org/2004/02/skos/core#definition> "A Gain of Specifically Dependent Continuant in which some Independent Continuant becomes the bearer of some Realizable Entity."@en ;
                                                                                <http://www.w3.org/2004/02/skos/core#example> "An informant becomes unreliable (disposition), A person begins to speak French (function), a person becomes a welder (role)." .


###  http://www.ontologyrepository.com/CommonCoreOntologies/GainOfRole
<http://www.ontologyrepository.com/CommonCoreOntologies/GainOfRole> rdf:type owl:Class ;
