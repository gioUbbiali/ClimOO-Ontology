    "@id" : "http://purl.obolibrary.org/obo/RO_0015009"
  } ],
  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "q1 similar_in_magnitude_relative_to q2 if and only if magnitude(q1) =~ magnitude(q2). Here, magnitude(q) is a function that maps a quality to a unit-invariant scale."
  } ]
}, {
  "@id" : "_:genid1730",
  "@type" : [ "http://www.w3.org/2002/07/owl#Axiom" ],
