                                                               _:genid370 ;
                                               <http://purl.obolibrary.org/obo/IAO_0000115> "A process in which includes the components of an environmental system as participants." ;
                                               rdfs:comment "This is a convenience class for organisation and should not be used for annotation." ;
                                               rdfs:label "environmental system process"@en .

_:genid370 rdf:type owl:Restriction ;
            owl:onProperty <http://purl.obolibrary.org/obo/RO_0000057> ;
            owl:someValuesFrom [ rdf:type owl:Class ;
                                 owl:unionOf ( <http://purl.obolibrary.org/obo/ENVO_00010483>
                                               <http://purl.obolibrary.org/obo/ENVO_01000254>
                                               <http://purl.obolibrary.org/obo/ENVO_01000799>
                                               <http://purl.obolibrary.org/obo/ENVO_01000804>
                                               <http://purl.obolibrary.org/obo/ENVO_01000813>
                                             )
