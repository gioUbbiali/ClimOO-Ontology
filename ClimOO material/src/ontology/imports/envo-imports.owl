###  http://purl.obolibrary.org/obo/ENVO_06105102
<http://purl.obolibrary.org/obo/ENVO_06105102> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_01000776> ;
                                               <http://purl.obolibrary.org/obo/IAO_0000115> "A piece of plastic which is greater than 1 metre in its longest dimension."@en ;
                                               <http://purl.org/dc/elements/1.1/contributor> <https://orcid.org/0000-0002-2996-719X> ,
                                                                                             <https://orcid.org/0000-0002-8166-0486> ;
