###  http://purl.obolibrary.org/obo/PATO_0000051
<http://purl.obolibrary.org/obo/PATO_0000051> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://purl.obolibrary.org/obo/PATO_0001241> ;
                                              <http://purl.obolibrary.org/obo/IAO_0000115> "A quality of a single physical entity inhering in the bearer by virtue of the bearer's size or shape or structure." ;
                                              <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "quality" ;
                                              <http://www.geneontology.org/formats/oboInOwl#id> "PATO:0000051" ;
                                              <http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/pato#attribute_slim> ;
                                              rdfs:label "morphology" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://purl.obolibrary.org/obo/PATO_0000051> ;
   owl:annotatedProperty <http://purl.obolibrary.org/obo/IAO_0000115> ;
   owl:annotatedTarget "A quality of a single physical entity inhering in the bearer by virtue of the bearer's size or shape or structure." ;
   <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PATOC:GVG"
 ] .


###  http://purl.obolibrary.org/obo/PATO_0000052
<http://purl.obolibrary.org/obo/PATO_0000052> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://purl.obolibrary.org/obo/PATO_0000051> ;
                                              <http://purl.obolibrary.org/obo/IAO_0000115> "A morphological quality inhering in a bearer by virtue of the bearer's ratios of distances between its features (points, edges, surfaces and also holes etc)." ;
                                              <http://www.geneontology.org/formats/oboInOwl#hasAlternativeId> "PATO:0001647" ;
                                              <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "relational shape quality" ;
                                              <http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> "quality" ;
                                              <http://www.geneontology.org/formats/oboInOwl#id> "PATO:0000052" ;
                                              <http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/pato#attribute_slim> ;
                                              rdfs:comment "Shapes are invariant on size transformations. Shapes can be subdivided into 2D and 3D shapes, We can also make a distinction between shapes of complete self-connected objects, and shapes of parts of objects." ;
                                              rdfs:label "shape" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://purl.obolibrary.org/obo/PATO_0000052> ;
   owl:annotatedProperty <http://purl.obolibrary.org/obo/IAO_0000115> ;
   owl:annotatedTarget "A morphological quality inhering in a bearer by virtue of the bearer's ratios of distances between its features (points, edges, surfaces and also holes etc)." ;
   <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PATOC:GVG"
 ] .


