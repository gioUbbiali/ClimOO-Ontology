  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "has primary input or output"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0000057"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004008",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "p has primary output c if (a) p has output c and (b) the goal of process is to modify, produce, or transform c."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#created_by" : [ {
