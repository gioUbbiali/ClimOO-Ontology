###  https://www.w3id.org/climoo/climoo-sdc2#Solid_Terrestrial_Water
:Solid_Terrestrial_Water rdf:type owl:Class ;
                         rdfs:subClassOf :Cryospheric_Material_Entity ,
                                         [ owl:intersectionOf ( :Water
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                                  owl:someValuesFrom <http://purl.obolibrary.org/obo/PATO_0001546>
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                         rdfs:comment """ClimOO Ontology comment:
we include axiomatization over the PATO solid quality class and implement axiomatizations of some subclasses."""@en ;
                         rdfs:label "portion of solid terrestrial water"@en ;
                         <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


