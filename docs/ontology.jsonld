  }, {
    "@id" : "_:genid1545"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000022"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An interaction that occurs among at least two complex system environment components."
  }, {
    "@language" : "fr",
    "@value" : "Une interaction qui se produit entre au moins deux composantes de l’environnement d’un système complexe."
  }, {
    "@language" : "it",
    "@value" : "Un’interazione che avviene tra almeno due componenti dell’ambiente di un sistema complesso."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/sco#SCO_0000022",
