  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A portion of synthetic polymer-based material that incorporates non-polymeric molecules as reinforcement within the polymer matrix."
  } ],
