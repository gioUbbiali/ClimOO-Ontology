    "@id" : "http://purl.obolibrary.org/obo/IAO_0000428"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "x has potential to developmentally induce y iff x developmentally induces y or x is capable of developmentally inducing y"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002387",
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000428"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "x has the potential to develop into y iff x develops into y or if x is capable of developing into y"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ]
