    "@value" : "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/QualityOntology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Blue"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
