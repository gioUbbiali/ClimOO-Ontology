                                                                                                           ]
                                                                                                         ) ;
                                                                                      rdf:type owl:Class
                                                                                    ]
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://purl.obolibrary.org/obo/RO_0002418> ;
