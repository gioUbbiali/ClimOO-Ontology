  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Reference to fossil and nonfossil feedstocks, such asrenewable feedstock, fossil fuel feedstock, biomass feedstock, related roles, and specific types, such as petroleum and biomasses, can be added as needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "bio-based plastic manufacturing process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000278"
  }, {
    "@id" : "_:genid375"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
