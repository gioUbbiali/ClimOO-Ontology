###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000301
:ClimOO_0000301 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000304 ;
                rdfs:label "climate change"@en ;
                rdfs:seeAlso "http://purl.obolibrary.org/obo/ENVO_01000629" ;
                <http://www.w3.org/2004/02/skos/core#definition> "A climate system process that alters the climate of a climate system for an extended period of time (typically decades or longer), and can be identified by the variation of the mean and/or the variability of the attributes, according to which that climate is statistically described."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "https://www.ipcc.ch/report/ar6/syr/downloads/report/IPCC_AR6_SYR_FullVolume.pdf" ;
