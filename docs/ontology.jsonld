}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000157",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "We primarily focused on mineralization processes in relation to synthetic plastics, related polymers and items. Reference to such processes concerning plastics more in general, for instance in relation to natural plastics, or in relation to polymer-based materials can be added as needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic biomineralization process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000271"
  }, {
    "@id" : "_:genid526"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid518"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A polymer biomineralization process that  applies to some biodegradable polymer molecules constituting some portion of biodegradable plastic"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000158",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "We currently focus this class on pieces of synthetic plastic. Implementations will expand current representations to plastic materials and polymers. Also, reference to the combustion of pieces of synthetic polymer-based materials can be included, as needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic combustion process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000015"
  }, {
    "@id" : "_:genid527"
  }, {
    "@id" : "_:genid532"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An exothermic chemical reaction process between some plastic and an oxidant (usually oxygen), which is sometimes accompanied by the production of light."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom" : [ {
    "@value" : "http://purl.obolibrary.org/obo/CHMO_0001473"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000159",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic composting process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000113"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid533"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A composting process that applies to polymer molecules constituting portions of plastic of which some waste piece of biodegradable synthetic plastic, used as input or part of the input of this process, is made. Packaging applications: The pieces of biodegradable synthetic plastic must be broken down into particles smaller than 2 mm in their largest dimension within the first 12 weeks (according to EU EN 13432, standardized laboratory test conditions). Presence of heavy metals in the output compost must be below harmful levels with no negative consequences concerning agronomic value and plant growth ecotoxicity (See EU standard directly).  (See also UNI EN ISO 20200 and Regulation - 2023/2055 - EN - EUR-Lex)."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000160",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@language" : "en",
    "@value" : "plastic debris agglomerate"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "References to plastic debris aggregate formation and participation in pollution processes can be added as needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic debris aggregate"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000027"
  }, {
    "@id" : "_:genid556"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid552"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An aggregate that has member part at least a plastic debris."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000072"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000074"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000075"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000228"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000161",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic debris degradation process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000275"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid566"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An polymer degradation process that leads some polymer molecules constituting some portion of polymer-based material composing some plastic debris to vary their physical and chemical qualities due to interactions with factors such as heat, light, or chemical entities, resulting in a decrease in their molecular weight."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000072"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000074"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000075"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000228"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000162",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic debris fragmentation process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000128"
  }, {
    "@id" : "_:genid578"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A fragmentation process of a piece of synthetic polymer-based material process that leads to breaking pieces of plastic debris down into pieces of a smaller size."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000072"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000074"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000075"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000228"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000163",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@language" : "en",
    "@value" : "plastic debris"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym" : [ {
    "@language" : "en",
    "@value" : "plastic litter"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Classification systems for plastic debris vary, especially according to particle size. For instance, EnvO considers 5 mm as the upper-level threshold to define microplastic particles, as this is a commonly recognized size edge in discussions on microplastic litter. Nevertheless, this is merely an operative definition, and there is no complete consensus on employing it (Hartmann et al., 2019). Hartmann et al. (2019) propose a range of 1-1000 micrometers. For illustrative purposes, the ClimOO ontology includes EnvO classification of plastic debris particles and maps it with that proposed by Hartmann et al. (2019), (covered by the ClimOO Ontology). The focus of the mpping is only on prticle size. See also comments to EnvO \"piece of plastic\" class.\n\nThese classifications differentiate for the size range of micro-, macro-, and meso-plastic particles. The shared size ranges for mega- and nano-plastic particles. This is also intended to be an initial guideline to align and map different classification systems."
  }, {
    "@language" : "en",
    "@value" : "Ontology implementations can extend the modelling of environmental persistence concerning pieces and materials made of plastics and synthetic polymers."
  }, {
    "@language" : "en",
    "@value" : "The term “environment” can be interpreted as referring to both systems and their environments contingent upon the focus of the analysis."
  }, {
    "@language" : "en",
    "@value" : "The term “litter” is used sometimes as a synonym of that of “debris”, sometimes with a slightly different meaning. Currently, the ClimOO Ontology focuses on debris, maintaining a neutral stance with regard to litter. Implementations will deal with possible sematic discrepancies by offering models to accommodate different usages of these terms."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic debris particle"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000150"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid587"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "a piece of synthetic polymer-based material that, at a certain time, is 1) solid, 2) not soluble in water (water solubility), 3) persistent in an environment (bearing a disposition to environmental persistence), generally as pollutant, 4) mobile (bearing a disposition to motion in the environment), and 5) is no longer used for a purpose."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000072"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000074"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000075"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000228"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000164",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "plastic debris sink may be temporary or permanent."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic debris sink"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000040"
  }, {
    "@id" : "_:genid604"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid600"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A material entity with a plastic debris sink role."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000165",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic debris sink role"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000023"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A role that inheres in a material entity (normally not a portion of plastics or polymer-based synthetic material) that participates in a plastic pollution process."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000166",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "From a material science perspective (which is the one we have to refer to for classifying plastics and polymers) plastic materials are constituted by polymers that are thermosetting and thermoplastic, and not, for instance, by elastic polymers. There exist, however, some synthetic combinations, such as thermoplastic elastomer-based synthetic materials, that are composed by polymers presenting both elastic and plastic properties. Strictly speaking, the last are not plastics (material science perspective). However, these materials are included in the count of debris (from an environmental perspective which is the one we have to refer to for classifying debris and pollution). So, the ClimOO Ontology accounts for these two perspectives, modeling differences and interconnection."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic debris source"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000040"
  }, {
    "@id" : "_:genid620"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid614"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A material entity that has as part some polymer-based synthetic material and bears some plastic debris source role. It is generally a piece of synthetic plastic, especially plastic objects."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000167",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic debris source role"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000023"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A role that inheres in a material entity having as part some portion of polymer-based synthetic material that participates in a plastic pollution process."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000168",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@language" : "en",
    "@value" : "plastic weathering"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic degradation process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "http://purl.allotrope.org/ontologies/process#AFP_0003641"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000269"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid630"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An process that leads some polymer molecules constituting some portion of plastic to vary their physical and chemical qualities due to interactions with factors such as heat, light, or chemical entities, resulting in a decrease in their molecular weight."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000072"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000074"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000075"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000228"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000169",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.\n\nIt is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.\n\nWe envision implementing such definitions in accordance with regulation revisions and novel research findings."
  }, {
    "@language" : "en",
    "@value" : "Reference to specific types of plastic materials and items can be added as needed."
  }, {
    "@value" : "The hierarchy position of this class is to be further discussed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic fragmentation process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000273"
  }, {
    "@id" : "_:genid638"
  }, {
    "@id" : "_:genid639"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A process that leads to breaking pieces of plastic down into pieces of a smaller size."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000072"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000074"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000075"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000228"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000171",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@language" : "en",
    "@value" : "plastic item"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Further details concerning stakeholders and objective and action specifications can be added to the axiomatixation of this class, as needed."
  }, {
    "@language" : "en",
    "@value" : "References to objects made of other synthetic polymer-based materials can be included if needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000153"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid640"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
