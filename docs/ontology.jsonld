  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "Compendium of polymer terminology and nomenclature: IUPAC recommendations, 2008. (2009). Choice (Middletown), 47(01), 47-0284-47–0284.\n\nVert, M., Doi, Y., Hellwich, K.-H., Hess, M., Hodge, P., Kubisa, P., Rinaudo, M., & Schué, F. (2012). Terminology for biorelated polymers and applications (IUPAC Recommendations 2012). Pure Appl. Chem., 84(2), 377–410."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
