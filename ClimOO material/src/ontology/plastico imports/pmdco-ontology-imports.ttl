   owl:annotatedTarget "A concentration unit which denotes the number of moles of solute as a proportion of the total number of moles in a solution." ;
   <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "Wikipedia:Wikipedia"
 ] .


###  http://purl.obolibrary.org/obo/UO_0000163
<http://purl.obolibrary.org/obo/UO_0000163> rdf:type owl:Class ;
                                            rdfs:subClassOf <http://purl.obolibrary.org/obo/UO_1000163> ;
                                            <http://purl.obolibrary.org/obo/IAO_0000115> "A dimensionless concentration unit which denotes the mass of a substance in a mixture as a percentage of the mass of the entire mixture." ;
                                            <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "w/w" ,
                                                                                                           "weight-weight percentage" ;
