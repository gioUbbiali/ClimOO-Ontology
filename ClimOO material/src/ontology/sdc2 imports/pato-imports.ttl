    <!-- http://purl.obolibrary.org/obo/PATO_0000001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <obo:IAO_0000115>A dependent entity that inheres in a bearer by virtue of how the bearer is related to other entities</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/envo.owl"/>
        <rdfs:label>quality</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0000125 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000125">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0001018"/>
        <obo:IAO_0000115>A physical quality that inheres in a bearer by virtue of the proportion of the bearer&apos;s amount of matter.</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>quality</oboInOwl:hasOBONamespace>
        <oboInOwl:id>PATO:0000125</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/pato#attribute_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/pato#relational_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/pato#scalar_slim"/>
        <rdfs:comment>For any biological use of PATO, the concept that should be used is &apos;mass&apos; and not &apos;weight&apos;. For example, increased weight of an organism.</rdfs:comment>
        <rdfs:label>mass</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PATO_0000125"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A physical quality that inheres in a bearer by virtue of the proportion of the bearer&apos;s amount of matter.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>PATOC:GVG</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0000146 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0000146">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0001018"/>
