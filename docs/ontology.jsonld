    "@value" : "A subset ontology module that is intended to be imported from another ontology."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@language" : "en",
    "@value" : "TODO: add axioms that indicate this is the output of a module extraction process."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@language" : "en",
    "@value" : "import file"
  } ]
}, {
