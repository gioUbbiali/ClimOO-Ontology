###  https://www.w3id.org/climoo/climoo-sdc2#Biosphere
:Biosphere rdf:type owl:Class ;
           rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000024> ,
                           [ rdf:type owl:Class ;
                             owl:unionOf ( [ rdf:type owl:Class ;
                                             owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                           <https://www.w3id.org/sco#SCO_0000006>
                                                         )
                                           ]
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                             owl:someValuesFrom [ rdf:type owl:Class ;
                                                                  owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                                                <https://www.w3id.org/sco#SCO_0000006>
                                                                              )
                                                                ]
                                           ]
                                         )
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                             owl:someValuesFrom :ClimOO_0000298
                           ] ;
           rdfs:label "portion of biosphere"@en ;
           rdfs:seeAlso "http://purl.obolibrary.org/obo/ENVO_01000817" ;
           <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo/climoo-sdc2#CO
:CO rdf:type owl:Class ;
    rdfs:subClassOf :Short-lived_Gas ;
    <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "potion of CO"@en ;
    rdfs:label "portion of carbon monoxide"@en ;
    <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo/climoo-sdc2#CO2_Sink
:CO2_Sink rdf:type owl:Class ;
          rdfs:subClassOf :Sink ;
          rdfs:comment """ClimOO Ontoloy comment:
We did not include original subclasses, as those classes should be modeled by reclassifying ocean and land classes as CO2 sinks via axiomatization if needed.

http://www.semanticweb.org/Davarpanah-Babaie/ontologies/2021/9/ClimateOnSDG1267#Global_Land_CO2_Sink 
http://www.semanticweb.org/Davarpanah-Babaie/ontologies/2021/9/ClimateOnSDG1267#Global_Ocean_CO2_Sink"""@en ;
          rdfs:label "CO2 sink material entity"@en ;
          <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


