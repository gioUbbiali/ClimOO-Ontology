  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relationship between a disease and an anatomical structure where the material basis of the disease is some pathological change in the structure. Anatomical structure includes cellular and sub-cellular entities, such as chromosome and organelles."
  } ]
