                                                            "https://en.wikipedia.org/wiki/Planet"
 ] .


###  http://purl.obolibrary.org/obo/ENVO_01000804
<http://purl.obolibrary.org/obo/ENVO_01000804> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000030> ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000051> ;
                                                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_01000799>
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://purl.obolibrary.org/obo/RO_0000086> ;
                                                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_01001164>
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://purl.obolibrary.org/obo/RO_0002219> ;
                                                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/ENVO_01000637>
                                                               ] ;
                                               <http://purl.obolibrary.org/obo/IAO_0000115> "An object which is composed of one or more gravitationally bound structures that are associated with a position in space." ;
                                               <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> "celestial object" ;
                                               <http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/envo#envoAstro> ;
                                               rdfs:comment "If there is only one astronomical body involved, this class is equivalent to ENVO:01000799. This may be problematic with reasoning, but it seems to be true to the rather fuzzy definitions found thus far." ;
                                               rdfs:label "astronomical object"@en .

