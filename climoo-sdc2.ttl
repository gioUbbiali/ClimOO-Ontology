#################################################################

###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000297
:ClimOO_0000297 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000016> ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                         owl:someValuesFrom :ClimOO_0000304
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                         owl:allValuesFrom :ClimOO_0000304
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                         owl:someValuesFrom :ClimOO_0000298
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                         owl:allValuesFrom :ClimOO_0000298
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:label "climate"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A disposition that is realized in some climate system process and is statistically described in terms of the mean and variability of relevant attributes (usually temperature, precipitation, and wind) over a period of time ranging from months to thousands or millions of years. Note: typically it realizes in seasonal cycles."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "https://www.ipcc.ch/report/ar6/syr/downloads/report/IPCC_AR6_SYR_FullVolume.pdf" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000306 ,
                                                       :ClimOO_0000308 .


###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000298
:ClimOO_0000298 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( <https://www.w3id.org/sco#SCO_0000015>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                             owl:someValuesFrom :ClimOO_0000297
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf <https://www.w3id.org/sco#SCO_0000015> ,
                                [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                                         owl:someValuesFrom :ClimOO_0000302
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000111> ;
                                                         owl:someValuesFrom :ClimOO_0000310
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000166> ;
                                                         owl:someValuesFrom :ClimOO_0000319
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000185> ;
                                                         owl:someValuesFrom :ClimOO_0000315
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000211> ;
                                                         owl:someValuesFrom :ClimOO_0000311
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002163> ;
                                                         owl:someValuesFrom :ClimOO_0000313
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000185> ;
                                                         owl:allValuesFrom :ClimOO_0000315
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                owl:disjointWith :ClimOO_0000313 ;
                rdfs:label "climate system"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A complex system that bears a climate disposition. Earth climate systemt is mainly composed of the atmosphere, the hydrosphere, the cryosphere, the lithosphere and the biosphere."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "https://www.ipcc.ch/report/ar6/syr/downloads/report/IPCC_AR6_SYR_FullVolume.pdf" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000306 ,
                                                       :ClimOO_0000307 ,
                                                       :ClimOO_0000308 .


###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000299
:ClimOO_0000299 rdf:type owl:Class ;
                rdfs:subClassOf <http://www.ontologyrepository.com/CommonCoreOntologies/MeasurementInformationContentEntity> ;
                rdfs:label "climate variability - measurement"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "An information content entity that is a measurement of the deviations of climate over a period of time from the long-term climate statistics for the corresponding calendar period.An information content entity that is a measurement of the deviations of climate over a period of time from the long-term climate statistics for the corresponding calendar period."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "https://unterm.un.org/unterm2/en/view/e0be578f-2cfc-401c-b536-7d5de7fe8559" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000306 ,
                                                       :ClimOO_0000308 .


###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000300
:ClimOO_0000300 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000144> ;
                rdfs:label "climate variability - process profile"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A process profile that is an occurrent part of some climate system process and is measured by some climate variability - measurement."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "https://unterm.un.org/unterm2/en/view/e0be578f-2cfc-401c-b536-7d5de7fe8559" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000306 ,
                                                       :ClimOO_0000308 .


###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000301
:ClimOO_0000301 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000304 ;
                rdfs:label "climate change"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A climate system process that alters the climate of a climate system for an extended period of time (typically decades or longer), and can be identified by the variation of the mean and/or the variability of the attributes, according to which that climate is statistically described."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "https://www.ipcc.ch/report/ar6/syr/downloads/report/IPCC_AR6_SYR_FullVolume.pdf" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000306 ,
                                                       :ClimOO_0000307 ,
                                                       :ClimOO_0000308 .


###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000302
:ClimOO_0000302 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( <https://www.w3id.org/sco#SCO_0000028>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                             owl:someValuesFrom :ClimOO_0000298
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf <https://www.w3id.org/sco#SCO_0000028> ;
                owl:disjointWith :ClimOO_0000312 ;
                rdfs:comment "Reference to stakeholders of climate systems can be added as needed."@en ;
                rdfs:label "climate system component"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A complex system component that is part of a climate system."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "http://www.semanticweb.org/Davarpanah-Babaie/ontologies/2021/9/ClimateOnSDG1267#Climate_System_Component" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000306 ,
                                                       :ClimOO_0000308 .


###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000303
:ClimOO_0000303 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                  owl:someValuesFrom :atmosphere
                                ] ;
                rdfs:comment "We refer to weather primarily at the mesospheric level of analysis. We do not refer to weather, for instance, when we deal with the molecular composition of the atmosphere."@en ;
                rdfs:label "atmospheric weather"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A quality that is realized in an atmospheric process and is described in terms of meteorological attributes, such as temperature, precipitation, atmospheric pressure, wind, and humidity."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom> "https://wmo.int/topics/weather; https://unterm.un.org/unterm2/en/" ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000306 ,
                                                       :ClimOO_0000307 ,
                                                       :ClimOO_0000308 .


###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000304
:ClimOO_0000304 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000167> ;
                                  owl:someValuesFrom :ClimOO_0000298
                                ] ;
                rdfs:comment "Climate system processes have the climate system as participant, meaning that any occurrence happening in a portion of a climate system component/climate system component also affects the overall climate system."@en ;
                rdfs:label "climate system process"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A process that pertains to a climate system."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000306 ,
                                                       :ClimOO_0000308 .


###  https://www.w3id.org/climoo/climoo-sdc2#ClimOO_0000305
:ClimOO_0000305 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000304 ;
                rdfs:label "atmospheric process"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A process that pertains to some portion of atmosphere."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000308 .


