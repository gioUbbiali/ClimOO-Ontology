}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004011",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Relates a gene to condition, such that a mutation in this gene in a germ cell provides a new function of the corresponding product and that is sufficient to produce the condition and that can be passed on to offspring[modified from orphanet]."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004012",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Relates a gene to condition, such that a mutation in this gene in a germ cell impairs the function of the corresponding product and that is sufficient to produce the condition and that can be passed on to offspring[modified from orphanet]."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004013",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Relates a gene to condition, such that a mutation in this gene is sufficient to produce the condition and that can be passed on to offspring[modified from orphanet]."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004014",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Relates a gene to condition, such that a mutation in this gene is sufficient to produce the condition but that cannot be passed on to offspring[modified from orphanet]."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004015",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Relates a gene to condition, such that a mutation in this gene predisposes to the development of a condition  and that is necessary but not sufficient to develop the condition[modified from orphanet]."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004016",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "Relates a gene to condition, such that a mutation in this gene partially contributes to the presentation of this condition[modified from orphanet]."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004020",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relation that holds between the disease and a material entity where the physical basis of the disease is a disorder of that material entity that affects its function."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004021",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relation that holds between the disease and a process where the physical basis of the disease disrupts execution of a key biological process."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004022",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relation that holds between the disease and a feature (a phenotype or other disease) where the physical basis of the disease is the feature."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004024",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relationship between a disease and a process where the disease process disrupts the execution of the process."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004026",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relationship between a disease and an anatomical entity where the disease has one or more features that are located in that entity."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "TODO: complete range axiom once more of CARO has been mireoted in to this ontology"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004027",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relationship between a disease and an anatomical entity where the disease is triggered by an inflammatory response to stimuli occurring in the anatomical entity"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0004028",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relationship between a realizable entity R (e.g. function or disposition) and a material entity M where R is realized in response to a process that has an input stimulus of M."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
