<https://www.w3id.org/climoo/climoo-piccomela> rdf:type owl:Ontology ;
                                            owl:versionIRI :piccomela-v1.0.0 ;
                                            owl:imports <https://www.w3id.org/climoo/climoo-picco#picco-v1.0.0> ;
