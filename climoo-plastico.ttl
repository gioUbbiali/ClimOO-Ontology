[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://purl.obolibrary.org/obo/CHEBI_24431> ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget <http://purl.obolibrary.org/obo/BFO_0000040> ;
   rdfs:comment """We included this axiom in accordance to the ChEBI-BFO alignment, findable here: https://ftp.ebi.ac.uk/pub/databases/chebi/archive/chebi_legacy/ontology/chebi-in-bfo.owl 

Source: https://ftp.ebi.ac.uk/pub/databases/chebi/archive/chebi_legacy/ontology/

Reference: Hastings J, De Matos P, Dekker A, Ennis M, Harsha B, Kale N, et al. The ChEBI reference database and ontology for biologically relevant chemistry: enhancements for 2013. Nucleic Acids Res. 2012 Nov 23;41(D1):D456–63."""@en
 ] .


