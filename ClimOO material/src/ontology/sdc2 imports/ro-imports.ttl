               rdfs:subPropertyOf obo:RO_0002233 ,
                                  obo:RO_0004007 ;
               obo:IAO_0000115 "p has primary input c if (a) p has input c and (b) the goal of process is to modify, consume, or transform c." ;
               obo:IAO_0000412 obo:ro.owl ;
