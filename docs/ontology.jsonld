  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "manufacturing process of a piece of synthetic polymer-based material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/COB_0000110"
  }, {
    "@id" : "_:genid1209"
  }, {
    "@id" : "_:genid1214"
  }, {
