                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0000081> ;
                                  owl:someValuesFrom :Sink
                                ] ;
                rdfs:label "sink role"@en ;
                rdfs:seeAlso """See for instance:
https://doi.org/10.1086/284280 
https://doi.org/10.1086/284880"""@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A role that inheres in a material entity in virtue of its ability to absorb and possibly accumulate certain material entities of interest as a proper part by participating in some flowing dynamical process."@en ;
