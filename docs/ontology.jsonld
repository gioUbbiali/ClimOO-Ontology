    "@language" : "en",
    "@value" : "exclusion subset ontology module"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A subset of an ontology that is intended to be excluded for some purpose. For example, a blacklist of classes."
  } ],
