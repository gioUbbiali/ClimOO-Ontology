###  http://purl.unep.org/sdg/SDGIO_00010021
<http://purl.unep.org/sdg/SDGIO_00010021> rdf:type owl:Class ;
                                          rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000016> ,
                                                          <https://www.w3id.org/sco#SCO_0000041> ,
                                                          [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000016>
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://purl.obolibrary.org/obo/RO_0000092> ;
                                                                                   owl:someValuesFrom <https://www.w3id.org/sco#SCO_0000015>
                                                                                 ]
                                                                               ) ;
                                                            rdf:type owl:Class
                                                          ] ;
                                          <http://purl.obolibrary.org/obo/IAO_0000114> <http://purl.obolibrary.org/obo/IAO_0000125> ;
                                          <http://purl.obolibrary.org/obo/IAO_0000115> "A disposition of an entity to recover its previous composition, qualities, and functionality following some perturbation."@en ;
                                          <http://purl.obolibrary.org/obo/IAO_0000118> "system resilience"@en ;
                                          <http://purl.org/dc/terms/source> """SuMSO definition sources:
1-55963-856-7 
https://pure.iiasa.ac.at/id/eprint/26/1/RP-73-003.pdf 
https://pure.iiasa.ac.at/id/eprint/13667/?template=default_internal"""@en ;
                                          <http://purl.unep.org/sdg/SDGIO_00000064> "https://uneplive.unep.org/community/discussion/view/23243/resilience" ;
                                          rdfs:comment """SuMSO developer comment:
Currently, we focused on complex systems but this class may be refer directly to systems. Once more, this will be cover into SCO implementations."""@en ,
                                                       """SuMSO developer comment:
Further classes are needed to represent system states and perturbations. Implementations will cover these aspects.
Revisions will be carried out in accordance with SCO implementations regarding system behaviors."""@en ,
                                                       """SuMSO developer comment:
We decided to include the SDGIO class as judged adequate to represent system resilience. We, however, decided to provide an alternative definition, more focused on complex systems as considered useful in the context of sustainability and complexity."""@en ,
                                                       "This disposition is distinct from robustness, which pertains to an entity's ability to resist change when encountering perturbing forces."@en ;
                                          rdfs:label "resilience"@en ;
                                          <http://www.w3.org/2004/02/skos/core#definition> """SuMSO definition:
A disposition whose realization leads the system to persist in its stable state of equilibrium in response to a perturbation."""@en .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://purl.unep.org/sdg/SDGIO_00010021> ;
   owl:annotatedProperty <http://purl.obolibrary.org/obo/IAO_0000118> ;
   owl:annotatedTarget "system resilience"@en ;
   <https://w3id.org/sco#SCO_0000039> <https://w3id.org/sumso#SuMSO_0000052>
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource <http://purl.unep.org/sdg/SDGIO_00010021> ;
   owl:annotatedProperty <http://www.w3.org/2004/02/skos/core#definition> ;
   owl:annotatedTarget """SuMSO definition:
A disposition whose realization leads the system to persist in its stable state of equilibrium in response to a perturbation."""@en ;
   <https://w3id.org/sco#SCO_0000039> <https://w3id.org/sumso#SuMSO_0000052>
 ] .


