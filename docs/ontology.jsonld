  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1561"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "it",
    "@value" : "La storia del sistema di un sistema complesso."
  }, {
    "@language" : "fr",
    "@value" : "L’historique de système d’un système complexe."
