  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1205"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A material processing that has as a primary input some portion of synthetic polymer-based material and as a primary output a piece of synthetic polymer-based material."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000278",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic manufacturing process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000276"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1216"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A synthetic polymer-based material manufacturing process that has as a primary output a portion of synthetic plastic."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000279",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Depending on the regulations and standards of reference, recycling may or may not be classified as a method of disposal. Sustainability impacts and implications may diverge equally across methods. \nCurrently, the ClimOO Ontology remains agnostic in those stances, making these two classes not disjoint. Users can specify the model based on their needs and according to endorsed standards.\nSee, for instance, https://www.iso.org/standard/77957.html"
  }, {
    "@language" : "en",
    "@value" : "Due to the main emphasis on the demise of wastes in literature and policy standards, currently, the ClimOO Ontology focuses this class on such a feature. Nevertheless, the notion of disposal is also often interpreted in terms of transportation. We envision discussions with subject matter experts to improve the current model."
  }, {
    "@language" : "en",
    "@value" : "Implementations may deal with disposal of pieces of polymer-based material that are not synthetic, as needed."
  }, {
    "@language" : "en",
    "@value" : "Reference to specific types of disposal processes, such as incineration and landfill, can be added as needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "disposal process of a piece of synthetic polymer-based material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/COB_0000035"
  }, {
    "@id" : "_:genid1220"
  }, {
    "@id" : "_:genid1225"
  }, {
    "@id" : "_:genid1230"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A planned process that applies to piece of synthetic polymer-based material deemed to be waste, resulting in its removal and demise."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000280",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "disposal process of a piece of synthetic plastic"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000279"
  }, {
    "@id" : "_:genid1231"
  }, {
