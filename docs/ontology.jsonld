    "@value" : "A Color that lacks any hues as parts."
  } ]
}, {
  "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Blue",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
