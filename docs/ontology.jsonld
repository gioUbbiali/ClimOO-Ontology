    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://purl.obolibrary.org/obo/RO_0002579" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002213"
  } ],
