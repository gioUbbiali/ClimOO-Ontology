  }, {
    "@id" : "_:genid939"
  }, {
    "@id" : "_:genid940"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid935"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A manufacturing process that has some portion of synthetic plastic as the main input and some piece of synthetic plastic as the main output."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000228",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "This owl:NamedIndividual aims to track current view endorsed by the Europeen Union."
  } ],
  "http://purl.org/dc/terms/source" : [ {
    "@language" : "en",
    "@value" : "EU Commission Press Release ip_23_4581. https://ec.europa.eu/commission/presscorner/detail/en/ip_23_4581 \n\nEU EN 13432 bioplastic policy. https://www.en-standard.eu/bs-en-13432-2000-packaging.-requirements-for-packaging-recoverable-through-composting-and-biodegradation.-test-scheme-and-evaluation-criteria-for-the-final-acceptance-of-packaging/ \n\nEUR - Lex document 32023R2055. https://eur-lex.europa.eu/eli/reg/2023/2055/oj/eng\n\nUNI EN ISO 20200:2023 - Plastics — Determination of the degree of disintegration of plastic materials under composting conditions in a laboratory-scale test. https://www.iso.org/standard/81932.html\n\nUNI EN ISO 24187:2023 - Principles for the analysis of microplastics present in the environment. https://www.iso.org/standard/78033.html"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#creation_date" : [ {
    "@language" : "en",
    "@value" : "2025-10-31"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://www.w3id.org/sco#SCO_0000016"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "European Union and Italy perspective on plastics, plastic pollution, biodegradability, and compostability"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000229",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "For insights on definitions, see, for instance:\nhttps://www.merriam-webster.com/dictionary/transparent \nhttps://en.wikipedia.org/wiki/Transparency_and_translucency"
  }, {
    "@language" : "en",
    "@value" : "We include this class as a subclass of color for reasons of simplicity. We are aware that this is not an accurate representation of transparency and related optical properties. For ClimOO Ontology purposes, however, this is acceptable. Implementations will revise this class to establish an adequate representation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "transparent"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.ontologyrepository.com/CommonCoreOntologies/Color"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000230",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A possible way to align the two systems of classification concerning microplastic size ranges is to include a “large microplastic” class covering microplastic from 1 to 5 mm.\nSee, for instance, ISO/TR 21960:2020Plastics — Environmental aspects — State of knowledge and methodologies https://www.iso.org/standard/72300.html"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "microplastic particle - Hartmann et al. (2019) classification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000231"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000232"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000233"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000261"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A plastic debris particle that is between 1 and 1000 µm in its largest dimension."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000231",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class has only been created for grouping purposes. Do not use it directly."
  }, {
    "@language" : "en",
    "@value" : "We included the double-inheritance axiom, even if it’s not the preferred practice, because some of these classes pertain to both classification systems."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic debris particle - Hartmann et al. (2019) size classification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000163"
