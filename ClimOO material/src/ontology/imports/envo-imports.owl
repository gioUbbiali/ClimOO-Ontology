###  http://purl.obolibrary.org/obo/ENVO_01001078
<http://purl.obolibrary.org/obo/ENVO_01001078> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://purl.obolibrary.org/obo/ENVO_01001081> ;
                                               <http://purl.obolibrary.org/obo/IAO_0000115> "Environmental variability which inheres in an astronomical body part or in outer space." ;
                                               rdfs:comment "This class refers to all weather, including atmospheric and space weather. Please use a subclass for more specificity." ;
                                               rdfs:label "weather"@en .

