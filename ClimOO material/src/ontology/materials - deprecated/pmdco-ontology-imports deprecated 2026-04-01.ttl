                                      rdfs:isDefinedBy <https://w3id.org/pmd/co/PMD_0200001> ;
                                      rdfs:label "biodegradable polymers"@en ;
                                      <http://www.w3.org/2004/02/skos/core#definition> "Biodegradable Polymers are Polymers that have the biodegradability disposition. They can be decomposed by biological organisms into environmentally benign substances (carbon dioxide and methane, mineral salts or new biomass) in a non-harmful timescale."@en ;
                                      <https://w3id.org/pmd/co/PMD_0000060> "true"^^xsd:boolean ;
                                      <https://w3id.org/pmd/co/PMD_0001032> "https://github.com/materialdigital/core-ontology/issues/126" .


###  https://w3id.org/pmd/co/PMD_0050037
<https://w3id.org/pmd/co/PMD_0050037> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://w3id.org/pmd/co/PMD_0050036> ;
                                      rdfs:label "polylactic acid"@en ;
                                      <http://www.w3.org/2004/02/skos/core#definition> "Polylactic Acid is a Biodegradable Polymer produced from renewable resources such as corn starch."@en ;
                                      <https://w3id.org/pmd/co/PMD_0000060> "true"^^xsd:boolean .


###  https://w3id.org/pmd/co/PMD_0050038
