<http://purl.obolibrary.org/obo/OBI_0000417> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/OBI_0000833> ;
                                             rdfs:domain <http://purl.obolibrary.org/obo/OBI_0000011> ;
