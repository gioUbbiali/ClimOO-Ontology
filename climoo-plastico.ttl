###  https://www.w3id.org/climoo#ClimOO_0000177
:ClimOO_0000177 rdf:type owl:Class ;
                rdfs:subClassOf :ClimOO_0000163 ;
                rdfs:label "plastic surface coating debris particle"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A debris particle of polymer composite-based synthetic material that is or derives from some plastic-based surface coatings, such as paints, and has been released into some environmental material."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000178
:ClimOO_0000178 rdf:type owl:Class ;
                rdfs:subClassOf [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/COB_0000110>
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                         owl:someValuesFrom :ClimOO_0000253
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <http://purl.obolibrary.org/obo/RO_0002418> ;
                                  owl:someValuesFrom :ClimOO_0000238
                                ] ;
                rdfs:comment "Currently, the ClimOO Ontology imports EnvO representation of waste role and includes a class for plastic upcycling. This is adequate for current ontology purposes. Given the strict interconnection between upcycling and recycling processes, however, we envision discussions with subject matter expert for possible implementations."@en ,
                             "Implementations will regard whether and when upcycling pertains to molecules, materials, and/or plastic items."@en ;
                rdfs:label "plastic upcycling process"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A material  processing that has as an input some piece of synthetic plastic or corresponding waste, as output at least one material entity to which some stakehoder ascribes a higher value (compared to the value of the plastic input)."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ClimOO_0000178 ;
   owl:annotatedProperty rdfs:comment ;
   owl:annotatedTarget "Currently, the ClimOO Ontology imports EnvO representation of waste role and includes a class for plastic upcycling. This is adequate for current ontology purposes. Given the strict interconnection between upcycling and recycling processes, however, we envision discussions with subject matter expert for possible implementations."@en ;
   rdfs:comment "For insights on ongoing conversations on these topics see the “Food, Waste, and Sustainability: Synergizing Ontology Efforts” workshop at ICBO2025 https://sites.google.com/view/fws2025workshop/home-page"@en ;
   rdfs:seeAlso :ClimOO_0000175
 ] .


###  https://www.w3id.org/climoo#ClimOO_0000180
:ClimOO_0000180 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :ClimOO_0000269
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                             owl:someValuesFrom :ClimOO_0000109
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :ClimOO_0000263 ,
                                [ owl:intersectionOf ( :ClimOO_0000269
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty <http://purl.obolibrary.org/obo/RO_0002233> ;
                                                         owl:someValuesFrom :ClimOO_0000109
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:comment """Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.

It is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.

We envision implementing such definitions in accordance with regulation revisions and novel research findings."""@en ;
                rdfs:label "polymer biodegradation process"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A biodegradation process that applies to some polymer molecules (biodegradable polymer molecules)."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> ;
                <https://www.w3id.org/sco#SCO_0000039> :ClimOO_0000072 ,
                                                       :ClimOO_0000073 ,
                                                       :ClimOO_0000074 ,
                                                       :ClimOO_0000075 ,
                                                       :ClimOO_0000228 .


