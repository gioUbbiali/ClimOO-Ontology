  "http://purl.obolibrary.org/obo/IAO_0000111" : [ {
    "@language" : "en",
    "@value" : "has ontology root term"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "Ontology annotation property. Relates an ontology to a term that is a designated root term of the ontology. Display tools like OLS can use terms annotated with this property as the starting point for rendering the ontology class hierarchy. There can be more than one root."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@language" : "en",
    "@value" : "Nicolas Matentzoglu"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/IAO_0006011",
