  }, {
    "@id" : "_:genid1077"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A piece of solid (at room temperature) synthetic plastic which is 1) hard, 2) has a smooth external surface, and 3) has a roughly spherical or granular shape."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom" : [ {
    "@value" : "http://purl.obolibrary.org/obo/ENVO_06105010"
