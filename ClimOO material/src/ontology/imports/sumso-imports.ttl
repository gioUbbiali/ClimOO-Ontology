@prefix : <urn:absolute:h/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <urn:absolute:h/> .

<http://ClimOO/climoo/imports/sumso-imports> rdf:type owl:Ontology ;
                                              owl:versionIRI <http://ClimOO/climoo/import/sumso-imports#2025-06-16> ;
                                              <http://purl.org/dc/terms/description> """This file contains ClimOO ontology imports from the Sustainable Meat Systems Ontology (SuMSO). It also includes imports from the Common Core Ontology suite (CCO), Information Artifact Ontology (IAO); Ontology for Biomedical Investigations (OBI), Environment Ontology (EnvO), Relation Ontology (RO), NCBITaxon Ontology (NCBITaxon), Phenotype And Trait Ontology (PATO), Vaccine Ontology (VO),Agronomy Ontology (AgrO), and Sustainable Development Goals Interface Ontology (SDGIO) that have been reused in SuMSO. 

This aims to capitalize on  SuMSO  extensions of these imports, benefiting from implementations such as, for instance, preliminary work in aligning CCO and IAO/OBI models of information and related entities, and revisions of SDGIO representation of complex system properties.

Imports have been manually collected and revised.""" ;
                                              rdfs:seeAlso """https://w3id.org/sumso/repo 
https://github.com/CommonCoreOntology/CommonCoreOntologies 
https://obi-ontology.org/ 
https://github.com/information-artifact-ontology/IAO/ 
https://github.com/SDG-InterfaceOntology/sdgio
https://github.com/vaccineontology/VO
https://github.com/pato-ontology/pato/ 
https://www.ncbi.nlm.nih.gov/taxonomy 
https://sites.google.com/site/environmentontology/
https://oborel.github.io/
https://bigdata.cgiar.org/resources/agronomy-ontology/""" ;
                                              owl:versionInfo "2025-06-16" .

