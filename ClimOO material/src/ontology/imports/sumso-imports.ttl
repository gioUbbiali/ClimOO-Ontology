                                                                                                    <http://purl.obolibrary.org/obo/valid_for_gocam> ;
                                            rdfs:label "constitutively upstream of"@en ;
                                            rdfs:seeAlso "https://wiki.geneontology.org/Constitutively_upstream_of"^^xsd:anyURI .


###  http://purl.obolibrary.org/obo/RO_0012010
