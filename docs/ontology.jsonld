  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000246"
  }, {
    "@id" : "_:genid857"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A portion of polymer-based material that in which some synthetic polymer molecules constitute the material matrix (frame)."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000212",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Here, we aim to track molecules that have already been added to polymers to obtain (plastic) polymer materials, not molecules that will be added. Currently, the ClimOO ontology does not intend such molecules to be already additive. Revisions can implement the ClimOO Ontology representation in this sense."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "synthetic polymer-based material additive"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
