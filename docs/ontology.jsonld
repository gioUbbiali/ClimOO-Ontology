    "@value" : "A polymer molecule that bears a disposition to biodegradation (biodegradability)."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000111",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@language" : "en",
    "@value" : "production process of biodegradable plastic material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "biodegradable synthetic plastic manufacturing process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000278"
  }, {
    "@id" : "_:genid391"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid387"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A plastic manufacturing process that has some biodegradable synthetic polymer molecules as the main input and some portion of biodegradable plastic as the main output."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000112",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "biodegradation process of a piece of sythetic plastic"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000113"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid395"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A biodegradation of synthetic plastic that applies to some polymer molecules constituting some portion of plastic that composes some piece of biodegradable synthetic plastic."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000113",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "biodegradation process of synthetic plastic"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000264"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid410"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A biodegradation of plastic that applies to some synthetic polymer molecules, constituting some portion of synthetic plastic (portion of biodegradable synthetic plastic). Packaging applications: 90% of the total polymer molecular weight must be degraded till mineralization into H2O, CO2, and mineral salts, in the presence of oxygen, and methane, H2O, CO2, and mineral salts, in the absence of oxygen, within the first 6 months (according to EU EN 13432, standardized laboratory test conditions). (See EU EN 13432, UNI EN ISO 20200, and Regulation - 2023/2055 - EN - EUR-Lex)."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000114",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "portion of compost"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "http://purl.obolibrary.org/obo/ENVO_00002170"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000245"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid421"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A portion of amorphous solid material that is obtained by composting organic wastes, generally composed of vegetable, fruit, and garden residues, sometimes with other organic materials. The input wastes contain a limited amount of minerals.  (See EU EN 13432, UNI EN ISO 20200, and Regulation - 2023/2055 - EN - EUR-Lex)."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000115",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A biodegradability disposition whose realization leads an environmental material to biodegrade while participating in a composting process."
  }, {
    "@language" : "en",
    "@value" : "Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.\n\nIt is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.\n\nWe envision implementing such definitions in accordance with regulation revisions and novel research findings."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "compostability"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000104"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid425"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000072"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000074"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000075"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000228"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000116",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "compostable plastic object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000108"
  }, {
    "@id" : "_:genid429"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A plastic object that is primarily made of compostable plastic."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000117",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "portion of compostable synthetic plastic material"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000205"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A portion of biodegradable synthetic plastic material that is copmosed of polymer molecules that bear a disposition to be degraded during a plastic composting process (compostability)."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000119",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.\n\nIt is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.\n\nWe envision implementing such definitions in accordance with regulation revisions and novel research findings."
  }, {
    "@language" : "en",
    "@value" : "Reference to anaerobic composting can be added as needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "composting process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000263"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid437"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A biodegradation process that occurs in the presence of oxygen, has, as main input, some organic waste, and has, a main output, some compost.  (See EU EN 13432, UNI EN ISO 20200, and Regulation - 2023/2055 - EN - EUR-Lex)."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
