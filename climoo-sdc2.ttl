                                                 owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                               <https://www.w3id.org/sco#SCO_0000006>
                                                             )
                                               ]
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                 owl:someValuesFrom [ rdf:type owl:Class ;
                                                                      owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                                                    <https://www.w3id.org/sco#SCO_0000006>
                                                                                  )
                                                                    ]
                                               ]
                                             )
                               ] ;
               <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> "portion of water"@en ;
               rdfs:comment """ClimOO Ontology comment:
We refer to this class primarily to liquid portions of water, such as rivers, lakes, and oceans. Revisions may be required, especially wth respect to cryospheric material entity classes."""@en ;
