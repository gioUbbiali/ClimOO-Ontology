  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A plastic manufacturing process that has some bio-based plastic polymer molecules as the main input and some portion of bio-based plastic material as the main output."
  } ],
