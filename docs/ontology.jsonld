  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ncbi.nlm.nih.gov/pubmed/20226267"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002514",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relation that holds between two entities that have the property of being sequences or having sequences. "
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ncbi.nlm.nih.gov/pubmed/20226267"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002515",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "Every UTR is adjacent to a CDS of the same transcript"
  }, {
    "@value" : "Two consecutive DNA residues are sequentially adjacent"
  }, {
    "@value" : "Two exons on a processed transcript that were previously connected by an intron are adjacent"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x is sequentially adjacent to y iff x and y do not overlap and if there are no base units intervening between x and y"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ncbi.nlm.nih.gov/pubmed/20226267"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002516",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "Every CDS has as a start sequence the start codon for that transcript"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x has start sequence y if the start of x is identical to the start of y, and x has y as a subsequence"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@value" : "started by"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ncbi.nlm.nih.gov/pubmed/20226267"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002517",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "inverse of has start sequence"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@value" : "starts"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ncbi.nlm.nih.gov/pubmed/20226267"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002518",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "Every CDS has as an end sequence the stop codon for that transcript (note this follows from the SO definition of CDS, in which stop codons are included)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x has end sequence y if the end of x is identical to the end of y, and x has y as a subsequence"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@value" : "ended by"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ncbi.nlm.nih.gov/pubmed/20226267"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002519",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "inverse of has end sequence"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@value" : "ends"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ncbi.nlm.nih.gov/pubmed/20226267"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002520",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x is a consecutive sequence of y iff x has subsequence y, and all the parts of x are made of zero or more repetitions of y or sequences as the same type as y."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@value" : "In the SO paper, this was defined as an instance-type relation"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "http://www.ncbi.nlm.nih.gov/pubmed/20226267"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002521",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "Human Shh and Mouse Shh are sequentially aligned, by cirtue of the fact that they derive from the same ancestral sequence."
  } ],
