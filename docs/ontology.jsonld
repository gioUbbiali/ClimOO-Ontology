  "@id" : "http://purl.obolibrary.org/obo/RO_0007000",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relation between two entities, in which one of the entities is any natural or human-influenced factor that directly or indirectly causes a change in the other entity."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0007001",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A relation between an entity and a disease of a host, in which the entity is not part of the host itself, and the condition results in pathological processes."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0008501",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "An interaction relationship wherein a plant or algae is living on the outside surface of another plant."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "https://en.wikipedia.org/wiki/Epiphyte"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0008502",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "inverse of epiphyte of"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0008503",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A sub-relation of parasite of in which a parasite steals resources from another organism, usually food or nest material"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "https://en.wikipedia.org/wiki/Kleptoparasitism"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0008504",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "inverse of kleptoparasite of"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0008505",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "An interaction relationship wherein one organism creates a structure or environment that is lived in by another organism."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0008506",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "An interaction relationship describing organisms that often occur together at the same time and space or in the same environment."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0008507",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "An interaction relationship in which organism a lays eggs on the outside surface of organism b. Organism b is neither helped nor harmed in the process of egg laying or incubation."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0008508",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "inverse of lays eggs on"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0008509",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "Flying foxes (Pteropus giganteus) has_roost banyan tree (Ficus benghalensis)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x 'has roost' y if and only if: x is an organism, y is a habitat, and y can support rest behaviors x."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0009001",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@language" : "en",
    "@value" : "muffin 'has substance added' some 'baking soda'"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000428"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "\"has substance added\" is a relation existing between a (physical) entity and a substance in which the entity has had the substance added to it at some point in time."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000116" : [ {
    "@language" : "en",
    "@value" : "The relation X 'has substance added' some Y doesn't imply that X still has Y in any detectable fashion subsequent to the addition. Water in dehydrated food or ice cubes are examples, as is food that undergoes chemical transformation. This definition should encompass recipe ingredients."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-8844-9165"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0009002",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@language" : "en",
    "@value" : "'egg white' 'has substance removed' some 'egg yolk'"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000428"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "\"has substance removed\" is a relation existing between two physical entities in which the first entity has had the second entity (a substance) removed from it at some point in time."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-8844-9165"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0009003",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@language" : "en",
    "@value" : "sardines 'immersed in' some 'oil and mustard'"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000428"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "\"immersed in\" is a relation between a (physical) entity and a fluid substance in which the entity is wholely or substantially surrounded by the substance."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-8844-9165"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0009004",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@language" : "en",
    "@value" : "sardine has consumer some homo sapiens"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000428"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "'has consumer' is a relation between a material entity and an organism in which the former can normally be digested or otherwise absorbed by the latter without immediate or persistent ill effect."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-8844-9165"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0009005",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@language" : "en",
    "@value" : "bread 'has primary substance added' some 'flour'"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000114" : [ {
    "@id" : "http://purl.obolibrary.org/obo/IAO_0000428"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "'has primary substance added' indicates that an entity has had the given substance added to it in a proportion greater than any other added substance."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-8844-9165"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0009006",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@language" : "en",
    "@value" : "A mass measurement assay measures an material's mass characteristic. A radioactivity detection assay measures the amount of radiation (alpha, beta or gamma ray emmissions) coming from a material."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "A relation between an assay and a characteristic, in which the assay generates a data item which is a measure of a characteristic."
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0009007",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@language" : "en",
    "@value" : "Inverse of 'assay measures characteristic'"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0009501",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "A drought sensitivity trait that inheres in a whole plant is realized in a systemic response process in response to exposure to drought conditions."
  }, {
    "@value" : "An inflammatory disease that is realized in response to an inflammatory process occurring in the gut (which is itself the realization of a process realized in response to harmful stimuli in the mucosal lining of th gut)"
  }, {
    "@value" : "Environmental polymorphism in butterflies: These butterflies have a 'responsivity to day length trait' that is realized in response to the duration of the day, and is realized in developmental processes that lead to increased or decreased pigmentation in the adult morph."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "r 'realized in response to' s iff, r is a realizable (e.g. a plant trait such as responsivity to drought), s is an environmental stimulus (a process), and s directly causes the realization of r."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@id" : "https://orcid.org/0000-0001-6996-0040"
  }, {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  }, {
    "@id" : "https://orcid.org/0000-0002-7073-9172"
  }, {
    "@id" : "https://orcid.org/0000-0002-8461-9745"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@value" : "triggered by process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "realized in response to"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "https://docs.google.com/document/d/1KWhZxVBhIPkV6_daHta0h6UyHbjY2eIrnON1WIRGgdY/edit"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002410"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0010001",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "Genetic information generically depend on molecules of DNA."
  }, {
    "@value" : "The novel *War and Peace* generically depends on this copy of the novel."
  }, {
    "@value" : "The pattern shared by chess boards generically depends on any chess board."
  }, {
    "@value" : "The score of a symphony g-depends on a copy of the score."
  }, {
    "@value" : "This pdf file generically depends on this server."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A generically dependent continuant *b* generically depends on an independent continuant *c* at time *t* means: there inheres in *c* a specifically deendent continuant which concretizes *b* at *t*."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "[072-ISO]"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@value" : "g-depends on"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0010002",
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "Molecules of DNA are carriers of genetic information."
  }, {
    "@value" : "This copy of *War and Peace* is carrier of the novel written by Tolstoy."
  }, {
    "@value" : "This hard drive is carrier of these data items."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "*b* is carrier of *c* at time *t* if and only if *c* *g-depends on* *b* at *t*"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000119" : [ {
    "@value" : "[072-ISO]"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0011002",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "The entity A has an activity that regulates an activity of the entity B. For example, A and B are gene products where the catalytic activity of A regulates the kinase activity of B."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0003-4639-4431"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0011003",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "The entity A has an activity that regulates the quantity or abundance or concentration of the entity B."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0003-4639-4431"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "regulates quantity of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002566"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0011004",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "The entity A is not immediately upstream of the entity B but A has an activity that regulates an activity performed by B."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0003-4639-4431"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0011007",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "The entity A has an activity that down-regulates by repression the quantity of B. The down-regulation is due to A having an effect on an intermediate entity (typically a DNA or mRNA element) which can produce B.\n\nFor example, protein A (transcription factor) indirectly decreases by repression the quantity of protein B (gene product) if and only if A negatively regulates the process of transcription or translation of a nucleic acid element that produces B."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0003-4639-4431"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "decreases by repression quantity of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0011023"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0011008",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "The entity A has an activity that up-regulates by expression the quantity of B. The up-regulation is due to A having an effect on an intermediate entity (typically a DNA or mRNA element) which can produce B.\n\nFor example, protein A (transcription factor) indirectly increases by expression the quantity of protein B (gene product) if and only if A positively regulates the process of transcription or translation of a nucleic acid element that produces B."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0003-4639-4431"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "increases by expression quantity of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0011024"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0011009",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "The entity A has an activity that directly positively regulates the quantity of B."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0003-4639-4431"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "directly positively regulates quantity of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0011021"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0011010",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "The entity A has an activity that directly negatively regulates the quantity of B."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0003-4639-4431"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "directly negatively regulates quantity of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0011021"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0011013",
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "The entity A is not immediately upstream of the entity B and has an activity that up-regulates an activity performed by B."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0003-4639-4431"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000118" : [ {
    "@value" : "indirectly activates"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0011014",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000112" : [ {
    "@value" : "AKT1 destabilizes quantity of FOXO (interaction from Signor database: SIGNOR-252844)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "An entity A directly interacts with B and A has an activity that decreases the amount of an entity B by degradating it."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0003-4639-4431"
