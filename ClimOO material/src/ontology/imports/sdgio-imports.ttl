  owl:annotatedSource <http://purl.obolibrary.org/obo/CHEBI_77853>;
  owl:annotatedProperty <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym>;
  owl:annotatedTarget "POP";
  <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ChEBI" .

