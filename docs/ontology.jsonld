  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000262",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "primary microplastic particle"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000230"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A microplastic debris particle that was, at the origin, intentionally designed and produced of this size (1-1000 µm)."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom" : [ {
    "@value" : "http://purl.obolibrary.org/obo/ENVO_01000945"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000263",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Definitions of plastic properties, such as biodegradability and composability, and related processes, currently covered in the ClimOO Ontology, refer to existing policy standards. This aims to stress the significance of such regulations concerning defining such entities and, especially, the consequences in terms of pollution and sustainability interventions.\n\nIt is noteworthy to mention that such standards present limitations. See, for instance, the work of Rayns et al. (2021), Steiner et al. (2022, 2024), concerning plastic biodegradability.\n\nWe envision implementing such definitions in accordance with regulation revisions and novel research findings."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "biodegradation process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/GO_0008150"
  }, {
    "@id" : "_:genid1082"
  }, {
    "@id" : "_:genid1083"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A process driven by biological entities that changes the physical and chemical qualities of some molecular entities, resulting in a decrease in their molecular weight."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000264",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "To date, the ClimOO ontology does not restrict such classes to solely refer to wasted plastics. Implementations may extend the current representation in such a direction, if needed. The only exception is the “plastic composting process” class, given that the aimed specific focus on composting of waste plastics."
  }, {
    "@language" : "en",
    "@value" : "We primarily focused on biodegradability in relation to synthetic plastics, related polymers and items. Reference to biodegradability concerning plastics more in general, for instance in relation to natural plastics, or in relation to polymer-based materials can be added as needed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "biodegradation process of plastic"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000168"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid1088"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "a polymer biodegradation that applies to some biodegradable polymer molecules constituting a portion of biodegradable plastic."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000265",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "According to EnvO, we consider this class as provisional. We envision implementations."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "transportation process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000015"
  }, {
    "@id" : "_:genid1096"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A process during which material entities are displaced from a location and moved either to a new location or back to the original location."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/adaptedFrom" : [ {
    "@value" : "http://purl.obolibrary.org/obo/ENVO_03000010"
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000266",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Implementations will expand current representation to distinguish intentional from unintentional plastic pollution processes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "plastic pollution process"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@language" : "en",
    "@value" : "http://purl.obolibrary.org/obo/ENVO_02500040"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/BFO_0000015"
  }, {
    "@id" : "_:genid1101"
  }, {
    "@id" : "_:genid1106"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A process during which plastic debris particles are released into and possibly accumulated in an environment, from some plastic debris source to some plastic debris sink."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
    "@id" : "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"
  } ],
  "https://www.w3id.org/sco#SCO_0000039" : [ {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000072"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000073"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000074"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000075"
  }, {
    "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000228"
  } ]
}, {
  "@id" : "https://www.w3id.org/climoo/climoo-plastico#ClimOO_0000267",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym" : [ {
    "@language" : "en",
    "@value" : "thermoset polymer material"
