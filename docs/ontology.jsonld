  } ],
  "http://www.w3.org/2002/07/owl#annotatedTarget" : [ {
    "@value" : "q1 decreased_in_magnitude_relative_to q2 if and only if magnitude(q1) < magnitude(q2). Here, magnitude(q) is a function that maps a quality to a unit-invariant scale."
  } ]
}, {
  "@id" : "_:genid1729",
  "@type" : [ "http://www.w3.org/2002/07/owl#Axiom" ],
