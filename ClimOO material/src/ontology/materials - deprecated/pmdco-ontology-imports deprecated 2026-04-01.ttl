                                            rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000020> ;
                                            <http://purl.obolibrary.org/obo/IAO_0000115> "Inverse of 'assay measures characteristic'"@en ;
                                            rdfs:label "characteristic measured by assay"@en .


