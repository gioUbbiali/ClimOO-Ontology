                                                                                                    <http://purl.obolibrary.org/obo/valid_for_gocam> ;
                                            rdfs:label "removes input for"@en ;
                                            rdfs:seeAlso "https://wiki.geneontology.org/Removes_input_for"^^xsd:anyURI .


###  http://purl.obolibrary.org/obo/RO_0012011
