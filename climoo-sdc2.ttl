:Capacity rdf:type owl:Class ;
          rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ;
          rdfs:comment """ClimOO Ontology comment:
We envision discussions with subject matter experts and implementations concerning this class as related subclasses."""@en ;
          rdfs:label "capacity"@en ;
          <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional> .


