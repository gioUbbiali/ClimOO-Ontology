  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "existence starts with"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002488"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002490",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x existence overlaps y if and only if either (a) the start of x is part of y or (b) the end of x is part of y. Formally: x existence starts and ends during y iff (α(x) >= α(y) & α(x) <= ω(y)) OR (ω(x) <= ω(y) & ω(x) >= α(y))"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The relations here were created based on work originally by Fabian Neuhaus and David Osumi-Sutherland. The work has not yet been vetted and errors in definitions may have occurred during transcription."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "existence overlaps"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002487"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002491",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x exists during y if and only if: 1) the time point at which x begins to exist is after or equal to the time point at which y begins and 2) the time point at which x ceases to exist is before or equal to the point at which y ends. Formally: x existence starts and ends during y iff α(x) >= α(y) & α(x) <= ω(y) & ω(x) <= ω(y) & ω(x) >= α(y)"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
    "@id" : "http://purl.obolibrary.org/obo/ro.owl"
  } ],
  "http://www.geneontology.org/formats/oboInOwl#hasExactSynonym" : [ {
    "@value" : "exists during"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The relations here were created based on work originally by Fabian Neuhaus and David Osumi-Sutherland. The work has not yet been vetted and errors in definitions may have occurred during transcription."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "existence starts and ends during"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002488"
  }, {
    "@id" : "http://purl.obolibrary.org/obo/RO_0002492"
  } ]
}, {
  "@id" : "http://purl.obolibrary.org/obo/RO_0002492",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "x existence ends during y if and only if the time point at which x ends is before or equivalent to the time point at which y ends and after or equivalent to the point at which y starts. Formally: x existence ends during y iff ω(x) <= ω(y) and ω(x) >= α(y)."
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000117" : [ {
    "@id" : "https://orcid.org/0000-0002-6601-2165"
  } ],
  "http://purl.obolibrary.org/obo/IAO_0000412" : [ {
