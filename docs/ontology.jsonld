  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A degradation process of a piece of synthetic polymer-based material that leads some synthetic polymer molecules constituting some portion of synthetic polymer-bsed material composing some piece of syntehtic polymer-based material to vary their physical and chemical qualities due to interactions with factors such as heat, light, or chemical entities, resulting in a decrease in their molecular weight."
  } ],
  "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity" : [ {
