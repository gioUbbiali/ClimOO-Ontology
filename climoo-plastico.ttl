                owl:equivalentClass [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/RO_0000087> ;
                                                             owl:someValuesFrom :ClimOO_0000165
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ,
                                [ rdf:type owl:Class ;
                                  owl:unionOf ( [ rdf:type owl:Class ;
                                                  owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                                <https://www.w3id.org/sco#SCO_0000006>
                                                              )
                                                ]
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                  owl:someValuesFrom [ rdf:type owl:Class ;
                                                                       owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                                                     <https://www.w3id.org/sco#SCO_0000006>
                                                                                   )
                                                                     ]
                                                ]
                                              )
                                ] ;
                rdfs:comment "plastic debris sink may be temporary or permanent."@en ;
                rdfs:label "plastic debris sink"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A material entity with a plastic debris sink role."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000165
:ClimOO_0000165 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000023> ;
                rdfs:label "plastic debris sink role"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A role that inheres in a material entity (normally not a portion of plastics or polymer-based synthetic material) that participates in a plastic pollution process."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000166
:ClimOO_0000166 rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                                             owl:someValuesFrom :ClimOO_0000150
                                                           ]
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/RO_0000087> ;
                                                             owl:someValuesFrom :ClimOO_0000167
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ,
                                [ rdf:type owl:Class ;
                                  owl:unionOf ( [ rdf:type owl:Class ;
                                                  owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                                <https://www.w3id.org/sco#SCO_0000006>
                                                              )
                                                ]
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                  owl:someValuesFrom [ rdf:type owl:Class ;
                                                                       owl:unionOf ( <http://purl.obolibrary.org/obo/RO_0002577>
                                                                                     <https://www.w3id.org/sco#SCO_0000006>
                                                                                   )
                                                                     ]
                                                ]
                                              )
                                ] ;
                rdfs:comment "From a material science perspective (which is the one we have to refer to for classifying plastics and polymers) plastic materials are constituted by polymers that are thermosetting and thermoplastic, and not, for instance, by elastic polymers. There exist, however, some synthetic combinations, such as thermoplastic elastomer-based synthetic materials, that are composed by polymers presenting both elastic and plastic properties. Strictly speaking, the last are not plastics (material science perspective). However, these materials are included in the count of debris (from an environmental perspective which is the one we have to refer to for classifying debris and pollution). So, the ClimOO Ontology accounts for these two perspectives, modeling differences and interconnection."@en ;
                rdfs:label "plastic debris source"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A material entity that has as part some polymer-based synthetic material and bears some plastic debris source role. It is generally a piece of synthetic plastic, especially plastic objects."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000167
:ClimOO_0000167 rdf:type owl:Class ;
                rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000023> ;
                rdfs:label "plastic debris source role"@en ;
                <http://www.w3.org/2004/02/skos/core#definition> "A role that inheres in a material entity having as part some portion of polymer-based synthetic material that participates in a plastic pollution process."@en ;
                <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/maturity> <https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Released> .


###  https://www.w3id.org/climoo#ClimOO_0000168
:ClimOO_0000168 rdf:type owl:Class ;
